<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Limpieza</p>
    <h2 class="mb-0">Limpieza masiva de locales</h2>
  </div>
  <div class="mt-3 mt-md-0">
    <%= link_to 'Volver a locales', black_coffee_venues_path, class: 'btn btn-outline-dark mr-2' %>
    <%= link_to 'Importador Google', black_coffee_google_imports_path, class: 'btn btn-outline-primary' %>
  </div>
</div>

<div class="alert alert-warning">
  <strong>Herramienta sensible.</strong>
  Puedes usarla en modo destructivo para borrar locales Black Coffee, o en modo revision para marcarlos masivamente como rechazados sin eliminarlos. El borrado sigue limpiando el importador como antes; el rechazo conserva el local y lo oculta de la app mediante su estado de revision.
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-header bg-white">
    <strong>1. Elegir alcance</strong>
  </div>
  <div class="card-body">
    <%= form_with url: black_coffee_cleanup_path, method: :get, local: true do %>
      <div class="row align-items-end">
        <div class="col-lg-3 col-md-6 mb-3">
          <%= label_tag :operation, 'Accion masiva' %>
          <%= select_tag :operation,
                         options_for_select(@operation_options.map { |value, label| [label, value] }, @cleanup.operation),
                         class: 'form-control' %>
          <small class="text-muted">Eliminar borra; rechazar conserva el local y cambia su revision.</small>
        </div>
        <div class="col-lg-2 col-md-6 mb-3">
          <%= label_tag :category, 'Categoria' %>
          <%= select_tag :category,
                         options_for_select([['Todas las categorias', '']] + @categories.map { |category| [category, category] }, @cleanup.category),
                         class: 'form-control' %>
        </div>
        <div class="col-lg-2 col-md-6 mb-3">
          <%= label_tag :source, 'Origen' %>
          <%= select_tag :source,
                         options_for_select(@source_options.map { |value, label| [label, value] }, @cleanup.source),
                         class: 'form-control' %>
        </div>
        <div class="col-lg-2 col-md-6 mb-3">
          <%= label_tag :visibility, 'Visibilidad' %>
          <%= select_tag :visibility,
                         options_for_select(@visibility_options.map { |value, label| [label, value] }, @cleanup.visibility),
                         class: 'form-control' %>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <%= label_tag :google_primary_type, 'Primary type Google (opcional)' %>
          <%= text_field_tag :google_primary_type, @cleanup.google_primary_type, class: 'form-control', placeholder: 'Ej: supermarket' %>
          <small class="text-muted">Coincide con el tipo principal guardado o inferido.</small>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <%= label_tag :google_tag, 'Etiqueta Google (opcional)' %>
          <%= text_field_tag :google_tag, @cleanup.google_tag, class: 'form-control', placeholder: 'Ej: butcher_shop' %>
          <small class="text-muted">Busca en las etiquetas internas guardadas en Black Coffee.</small>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <%= label_tag :review_rejection_reason, 'Motivo si rechazas' %>
          <%= select_tag :review_rejection_reason,
                         options_for_select(@rejection_reason_options, @cleanup.review_rejection_reason),
                         class: 'form-control' %>
          <small class="text-muted">Solo se aplica con la accion "Marcar como rechazados".</small>
        </div>
        <div class="col-lg-6 col-md-6 mb-3">
          <%= label_tag :review_rejection_note, 'Nota interna si rechazas (opcional)' %>
          <%= text_field_tag :review_rejection_note,
                             @cleanup.review_rejection_note,
                             class: 'form-control',
                             placeholder: 'Ej: limpieza masiva por categoria incorrecta' %>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
          <%= submit_tag 'Previsualizar accion', class: 'btn btn-primary btn-block text-white' %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-3 mb-3 mb-md-0">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted text-uppercase mb-2"><%= @cleanup.reject_operation? ? 'Locales a rechazar' : 'Locales a borrar' %></p>
        <h2 class="mb-0 <%= @cleanup.reject_operation? ? 'text-warning' : 'text-danger' %>"><%= number_with_delimiter(@preview[:venue_count]) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3 mb-md-0">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted text-uppercase mb-2">Con Google Place ID</p>
        <h2 class="mb-0"><%= number_with_delimiter(@preview[:google_linked_count]) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3 mb-md-0">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted text-uppercase mb-2"><%= @cleanup.reject_operation? ? 'Aprobados a pasar a rechazado' : 'Candidatos aprobados a reabrir' %></p>
        <h2 class="mb-0 text-warning"><%= number_with_delimiter(@cleanup.reject_operation? ? @preview[:review_approved_count] : @preview[:linked_approved_candidates_count]) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted text-uppercase mb-2"><%= @cleanup.reject_operation? ? 'Ya estaban rechazados' : 'Duplicados a reabrir' %></p>
        <h2 class="mb-0 text-warning"><%= number_with_delimiter(@cleanup.reject_operation? ? @preview[:review_rejected_count] : @preview[:linked_duplicate_candidates_count]) %></h2>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-5 mb-4">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-header bg-white">
        <strong>Resumen por categoria</strong>
      </div>
      <div class="card-body p-0">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>Categoria</th>
              <th class="text-right">Locales</th>
            </tr>
          </thead>
          <tbody>
            <% if @preview[:category_counts].any? %>
              <% @preview[:category_counts].each do |category, count| %>
                <tr>
                  <td><%= category %></td>
                  <td class="text-right"><%= number_with_delimiter(count) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="2" class="text-center text-muted py-4">No hay locales con estos filtros.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-7 mb-4">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-header bg-white">
        <strong>Muestra de locales afectados</strong>
      </div>
      <div class="card-body p-0 table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>Local</th>
              <th>Categoria</th>
              <th>Google</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody>
            <% if @preview[:sample_venues].any? %>
              <% @preview[:sample_venues].each do |venue| %>
                <tr>
                  <td>
                    <strong><%= venue.name %></strong>
                    <div class="text-muted small"><%= venue.city %></div>
                    <% if venue.google_primary_type_for_dashboard.present? %>
                      <div class="text-muted small mt-1">Primary: <%= venue.google_primary_type_for_dashboard %></div>
                    <% end %>
                    <% if Array(venue.tags).any? %>
                      <div class="small mt-1">
                        <% Array(venue.tags).first(4).each do |tag| %>
                          <span class="badge badge-light border mr-1 mb-1"><%= tag %></span>
                        <% end %>
                      </div>
                    <% end %>
                  </td>
                  <td><%= venue.category %></td>
                  <td>
                    <% if venue.google_connected? %>
                      <span class="badge badge-success">Google</span>
                    <% else %>
                      <span class="badge badge-light">Manual</span>
                    <% end %>
                  </td>
                  <td>
                    <span class="badge badge-<%= venue.review_status_badge_class %> mr-1"><%= venue.review_status_label %></span>
                    <% if venue.review_rejection_reason.present? %>
                      <div class="text-muted small mb-1"><%= venue.review_rejection_reason_label %></div>
                    <% end %>
                    <% if venue.internal_test_for_dashboard? %>
                      <span class="badge badge-info mr-1">Interno</span>
                    <% end %>
                    <% if venue.visible_to_app? %>
                      <span class="badge badge-success">Visible</span>
                    <% else %>
                      <span class="badge badge-secondary">Oculto</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center text-muted py-4">No hay muestra porque el alcance esta vacio.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<% cleanup_is_reject = @cleanup.reject_operation? %>
<% can_run_cleanup = cleanup_is_reject ? @preview[:venue_count].to_i.positive? : (@preview[:venue_count].to_i.positive? || @preview[:orphaned_approved_candidates_count].to_i.positive? || @preview[:orphaned_duplicate_candidates_count].to_i.positive?) %>
<% confirmation_border_class = cleanup_is_reject ? 'border-warning' : 'border-danger' %>
<% confirmation_header_class = cleanup_is_reject ? 'bg-warning text-dark' : 'bg-danger text-white' %>
<% confirmation_button_class = cleanup_is_reject ? 'btn btn-warning text-dark font-weight-bold' : 'btn btn-danger text-white' %>

<div class="card <%= confirmation_border_class %> shadow-sm mb-5">
  <div class="card-header <%= confirmation_header_class %>">
    <strong>2. Confirmar <%= cleanup_is_reject ? 'rechazo masivo' : 'borrado' %></strong>
  </div>
  <div class="card-body">
    <% if !cleanup_is_reject && (@preview[:orphaned_approved_candidates_count].to_i.positive? || @preview[:orphaned_duplicate_candidates_count].to_i.positive?) %>
      <div class="alert alert-info">
        Tambien se limpiaran enlaces antiguos ya huerfanos del importador:
        <strong><%= @preview[:orphaned_approved_candidates_count] %></strong> aprobados y
        <strong><%= @preview[:orphaned_duplicate_candidates_count] %></strong> duplicados.
      </div>
    <% end %>

    <% if cleanup_is_reject %>
      <div class="alert alert-light border">
        Esta accion marcara como <strong>rechazados</strong> <strong><%= number_with_delimiter(@preview[:venue_count]) %></strong> locales sin borrarlos.
        Motivo: <strong><%= Venue.rejection_reason_label(@cleanup.review_rejection_reason) %></strong>.
        Los locales rechazados no se devuelven a la app, pero quedan disponibles en el dashboard para auditoria o correccion posterior.
      </div>
    <% else %>
      <p>
        Esta accion borrara <strong><%= number_with_delimiter(@preview[:venue_count]) %></strong> locales y reabrira candidatos del importador que dependian de ellos.
        No borra las corridas de Google; las deja consistentes para revisar o aprobar de nuevo.
      </p>
    <% end %>

    <%= form_with url: black_coffee_cleanup_path, method: :post, local: true do %>
      <%= hidden_field_tag :operation, @cleanup.operation %>
      <%= hidden_field_tag :category, @cleanup.category %>
      <%= hidden_field_tag :source, @cleanup.source %>
      <%= hidden_field_tag :visibility, @cleanup.visibility %>
      <%= hidden_field_tag :google_primary_type, @cleanup.google_primary_type %>
      <%= hidden_field_tag :google_tag, @cleanup.google_tag %>
      <%= hidden_field_tag :review_rejection_reason, @cleanup.review_rejection_reason %>
      <%= hidden_field_tag :review_rejection_note, @cleanup.review_rejection_note %>

      <div class="form-group">
        <%= label_tag :confirm_text, "Escribe #{@confirmation_text} para confirmar" %>
        <%= text_field_tag :confirm_text, nil, class: 'form-control', placeholder: @confirmation_text, autocomplete: 'off' %>
      </div>

      <%= submit_tag(cleanup_is_reject ? 'Marcar locales como rechazados' : 'Ejecutar limpieza masiva',
                     class: confirmation_button_class,
                     disabled: !can_run_cleanup,
                     data: { confirm: cleanup_is_reject ? "Confirmar rechazo masivo? Se marcaran #{@preview[:venue_count]} locales como rechazados con motivo #{Venue.rejection_reason_label(@cleanup.review_rejection_reason)}." : "Confirmar limpieza masiva? Se borraran #{@preview[:venue_count]} locales Black Coffee y se reabriran enlaces huerfanos del importador. Esta accion no se puede deshacer." }) %>
    <% end %>
  </div>
</div>
