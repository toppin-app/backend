<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Limpieza</p>
    <h2 class="mb-0">Limpieza masiva de locales</h2>
  </div>
  <div class="mt-3 mt-md-0">
    <%= link_to 'Volver a locales', black_coffee_venues_path, class: 'btn btn-outline-dark mr-2' %>
    <%= link_to 'Importador Google', black_coffee_google_imports_path, class: 'btn btn-outline-primary' %>
  </div>
</div>

<div class="alert alert-warning">
  <strong>Herramienta destructiva.</strong>
  Borra locales Black Coffee segun los filtros elegidos y despues limpia el importador: los candidatos aprobados o duplicados que apuntaban a esos locales vuelven a <strong>pending</strong>, para que puedas revisarlos e importarlos otra vez.
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-header bg-white">
    <strong>1. Elegir alcance</strong>
  </div>
  <div class="card-body">
    <%= form_with url: black_coffee_cleanup_path, method: :get, local: true do %>
      <div class="row align-items-end">
        <div class="col-lg-2 col-md-6 mb-3">
          <%= label_tag :category, 'Categoria' %>
          <%= select_tag :category,
                         options_for_select([['Todas las categorias', '']] + @categories.map { |category| [category, category] }, @cleanup.category),
                         class: 'form-control' %>
        </div>
        <div class="col-lg-2 col-md-6 mb-3">
          <%= label_tag :source, 'Origen' %>
          <%= select_tag :source,
                         options_for_select(@source_options.map { |value, label| [label, value] }, @cleanup.source),
                         class: 'form-control' %>
        </div>
        <div class="col-lg-2 col-md-6 mb-3">
          <%= label_tag :visibility, 'Visibilidad' %>
          <%= select_tag :visibility,
                         options_for_select(@visibility_options.map { |value, label| [label, value] }, @cleanup.visibility),
                         class: 'form-control' %>
        </div>
        <div class="col-lg-4 col-md-6 mb-3">
          <%= label_tag :google_tag, 'Etiqueta Google (opcional)' %>
          <%= text_field_tag :google_tag, @cleanup.google_tag, class: 'form-control', placeholder: 'Ej: butcher_shop' %>
          <small class="text-muted">Busca en las etiquetas internas guardadas en Black Coffee.</small>
        </div>
        <div class="col-lg-2 col-md-6 mb-3">
          <%= submit_tag 'Previsualizar limpieza', class: 'btn btn-primary btn-block text-white' %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-md-3 mb-3 mb-md-0">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted text-uppercase mb-2">Locales a borrar</p>
        <h2 class="mb-0 text-danger"><%= number_with_delimiter(@preview[:venue_count]) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3 mb-md-0">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted text-uppercase mb-2">Con Google Place ID</p>
        <h2 class="mb-0"><%= number_with_delimiter(@preview[:google_linked_count]) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3 mb-3 mb-md-0">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted text-uppercase mb-2">Candidatos aprobados a reabrir</p>
        <h2 class="mb-0 text-warning"><%= number_with_delimiter(@preview[:linked_approved_candidates_count]) %></h2>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted text-uppercase mb-2">Duplicados a reabrir</p>
        <h2 class="mb-0 text-warning"><%= number_with_delimiter(@preview[:linked_duplicate_candidates_count]) %></h2>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-5 mb-4">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-header bg-white">
        <strong>Resumen por categoria</strong>
      </div>
      <div class="card-body p-0">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>Categoria</th>
              <th class="text-right">Locales</th>
            </tr>
          </thead>
          <tbody>
            <% if @preview[:category_counts].any? %>
              <% @preview[:category_counts].each do |category, count| %>
                <tr>
                  <td><%= category %></td>
                  <td class="text-right"><%= number_with_delimiter(count) %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="2" class="text-center text-muted py-4">No hay locales con estos filtros.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-7 mb-4">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-header bg-white">
        <strong>Muestra de locales afectados</strong>
      </div>
      <div class="card-body p-0 table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th>Local</th>
              <th>Categoria</th>
              <th>Google</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody>
            <% if @preview[:sample_venues].any? %>
              <% @preview[:sample_venues].each do |venue| %>
                <tr>
                  <td>
                    <strong><%= venue.name %></strong>
                    <div class="text-muted small"><%= venue.city %></div>
                    <% if Array(venue.tags).any? %>
                      <div class="small mt-1">
                        <% Array(venue.tags).first(4).each do |tag| %>
                          <span class="badge badge-light border mr-1 mb-1"><%= tag %></span>
                        <% end %>
                      </div>
                    <% end %>
                  </td>
                  <td><%= venue.category %></td>
                  <td>
                    <% if venue.google_connected? %>
                      <span class="badge badge-success">Google</span>
                    <% else %>
                      <span class="badge badge-light">Manual</span>
                    <% end %>
                  </td>
                  <td>
                    <% if venue.internal_test_for_dashboard? %>
                      <span class="badge badge-info mr-1">Interno</span>
                    <% end %>
                    <% if venue.visible_to_app? %>
                      <span class="badge badge-success">Visible</span>
                    <% else %>
                      <span class="badge badge-secondary">Oculto</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center text-muted py-4">No hay muestra porque el alcance esta vacio.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="card border-danger shadow-sm mb-5">
  <div class="card-header bg-danger text-white">
    <strong>2. Confirmar borrado</strong>
  </div>
  <div class="card-body">
    <% can_run_cleanup = @preview[:venue_count].to_i.positive? || @preview[:orphaned_approved_candidates_count].to_i.positive? || @preview[:orphaned_duplicate_candidates_count].to_i.positive? %>

    <% if @preview[:orphaned_approved_candidates_count].to_i.positive? || @preview[:orphaned_duplicate_candidates_count].to_i.positive? %>
      <div class="alert alert-info">
        Tambien se limpiaran enlaces antiguos ya huerfanos del importador:
        <strong><%= @preview[:orphaned_approved_candidates_count] %></strong> aprobados y
        <strong><%= @preview[:orphaned_duplicate_candidates_count] %></strong> duplicados.
      </div>
    <% end %>

    <p>
      Esta accion borrara <strong><%= number_with_delimiter(@preview[:venue_count]) %></strong> locales y reabrira candidatos del importador que dependian de ellos.
      No borra las corridas de Google; las deja consistentes para revisar o aprobar de nuevo.
    </p>

    <%= form_with url: black_coffee_cleanup_path, method: :post, local: true do %>
      <%= hidden_field_tag :category, @cleanup.category %>
      <%= hidden_field_tag :source, @cleanup.source %>
      <%= hidden_field_tag :visibility, @cleanup.visibility %>
      <%= hidden_field_tag :google_tag, @cleanup.google_tag %>

      <div class="form-group">
        <%= label_tag :confirm_text, "Escribe #{@confirmation_text} para confirmar" %>
        <%= text_field_tag :confirm_text, nil, class: 'form-control', placeholder: @confirmation_text, autocomplete: 'off' %>
      </div>

      <%= submit_tag "Ejecutar limpieza masiva",
                     class: 'btn btn-danger text-white',
                     disabled: !can_run_cleanup,
                     data: { confirm: "Confirmar limpieza masiva? Se borraran #{@preview[:venue_count]} locales Black Coffee y se reabriran enlaces huerfanos del importador. Esta accion no se puede deshacer." } %>
    <% end %>
  </div>
</div>
