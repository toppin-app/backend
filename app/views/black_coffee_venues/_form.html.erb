<%= form_with model: @venue, url: @venue.persisted? ? black_coffee_venue_path(@venue) : black_coffee_venues_path, local: true, html: { multipart: true }, data: { black_coffee_venue_form: true, subcategories: @subcategory_options_json } do |form| %>
  <% if @venue.errors.any? %>
    <div class="alert alert-danger">
      <h4 class="mb-3"><%= pluralize(@venue.errors.count, 'error') %> impidieron guardar el local:</h4>
      <ul class="mb-0">
        <% @venue.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <p class="text-muted mb-1">Black Coffee / Editor</p>
      <h2 class="mb-0"><%= @venue.persisted? ? "Editar #{@venue.name}" : 'Nuevo local' %></h2>
    </div>
    <div>
      <%= link_to 'Volver', black_coffee_venues_path, class: 'btn btn-outline-secondary' %>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <div class="mb-3">
            <%= form.label :name, 'Nombre del local *' %>
            <%= form.text_field :name, class: 'form-control', required: true %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <%= form.label :category, 'Categoria *' %>
            <%= form.select :category, options_for_select(@categories.map { |category| [category, category] }, @venue.category), { include_blank: 'Selecciona una categoria' }, class: 'form-control', required: true, id: 'venue-category-select' %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="mb-3">
            <%= label_tag 'venue_subcategory_name', 'Subcategoria' %>
            <%= text_field_tag 'venue[subcategory_name]', @subcategory_input, class: 'form-control', list: 'venue-subcategories-list', id: 'venue-subcategory-input', placeholder: 'Ej: brunch, cocteleria, artesanal' %>
            <small class="form-text text-muted">
              Puedes escribir una nueva subcategoria o elegir una existente.
              <%= link_to 'Gestionarlas', black_coffee_subcategories_path %>
            </small>
          </div>
        </div>
        <div class="col-12">
          <div class="mb-3">
            <%= form.label :description, 'Descripcion *' %>
            <%= form.text_area :description, class: 'form-control', rows: 3, required: true, placeholder: 'Describe el local en una o dos frases' %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="mb-3">
            <%= form.label :address, 'Direccion *' %>
            <%= form.text_field :address, class: 'form-control', required: true %>
          </div>
        </div>
        <div class="col-md-2">
          <div class="mb-3">
            <%= form.label :city, 'Ciudad *' %>
            <%= form.text_field :city, class: 'form-control', required: true %>
          </div>
        </div>
        <div class="col-md-2">
          <div class="mb-3">
            <%= form.label :latitude, 'Latitud *' %>
            <%= form.number_field :latitude, class: 'form-control', step: '0.0000001', required: true %>
          </div>
        </div>
        <div class="col-md-2">
          <div class="mb-3">
            <%= form.label :longitude, 'Longitud *' %>
            <%= form.number_field :longitude, class: 'form-control', step: '0.0000001', required: true %>
          </div>
        </div>
        <div class="col-md-8">
          <div class="mb-0">
            <%= label_tag 'venue_tag_list', 'Tags' %>
            <%= text_field_tag 'venue[tag_list]', @tag_list_input, class: 'form-control', id: 'venue-tag-list', placeholder: 'romantico, terraza, craft beer' %>
            <small class="form-text text-muted">Introduce etiquetas separadas por coma.</small>
          </div>
        </div>
        <div class="col-md-4 d-flex align-items-end">
          <div class="form-check mb-3">
            <%= form.check_box :featured, class: 'form-check-input' %>
            <%= form.label :featured, 'Destacar editorialmente', class: 'form-check-label' %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header bg-white">
      <div>
        <h4 class="mb-0">Imagenes del local</h4>
        <small class="text-muted">Puedes mezclar links externos y archivos manuales. La primera imagen sera la portada en la app.</small>
      </div>
    </div>
    <div class="card-body">
      <div class="d-flex flex-wrap mb-3">
        <button type="button" class="btn btn-outline-primary btn-sm mr-2 mb-2" id="add-remote-image-button">
          Agregar link externo
        </button>
        <button type="button" class="btn btn-outline-dark btn-sm mb-2" id="add-upload-image-button">
          Agregar imagen manual
        </button>
      </div>

      <%= hidden_field_tag 'venue[image_order_payload]', @image_order_payload, id: 'venue-image-order-payload' %>
      <script type="application/json" id="venue-image-initial-state"><%= raw json_escape(@image_entries.to_json) %></script>
      <div id="venue-image-list"></div>
      <small class="form-text text-muted">
        Puedes subir archivos propios o usar links externos, por ejemplo los de Google Maps. Usa las flechas para reordenar y eliminar.
      </small>
    </div>
  </div>

  <div class="card mb-4">
    <div class="card-header bg-white">
      <h4 class="mb-0">Horario semanal</h4>
      <small class="text-muted">Permite franjas multiples por dia para soportar horario partido.</small>
    </div>
    <div class="card-body">
      <%= hidden_field_tag 'venue[schedule_payload]', @schedule_payload, id: 'venue-schedule-payload', data: { initial_schedule: @schedule_payload } %>
      <div id="schedule-editor"></div>
    </div>
  </div>

  <datalist id="venue-subcategories-list"></datalist>

  <div class="pb-5">
    <%= form.submit(@venue.persisted? ? 'Actualizar local' : 'Crear local', class: 'btn btn-success text-white') %>
    <%= link_to 'Cancelar', black_coffee_venues_path, class: 'btn btn-secondary text-white' %>
  </div>
<% end %>

<script>
  document.addEventListener('turbolinks:load', function () {
    var form = document.querySelector('[data-black-coffee-venue-form="true"]');
    if (!form || form.dataset.initialized === 'true') {
      return;
    }

    form.dataset.initialized = 'true';

    var categorySelect = document.getElementById('venue-category-select');
    var subcategoryInput = document.getElementById('venue-subcategory-input');
    var subcategoriesList = document.getElementById('venue-subcategories-list');
    var imageList = document.getElementById('venue-image-list');
    var imageOrderField = document.getElementById('venue-image-order-payload');
    var imageInitialState = document.getElementById('venue-image-initial-state');
    var addRemoteImageButton = document.getElementById('add-remote-image-button');
    var addUploadImageButton = document.getElementById('add-upload-image-button');
    var scheduleField = document.getElementById('venue-schedule-payload');
    var scheduleEditor = document.getElementById('schedule-editor');
    var scheduleData = [];

    try {
      scheduleData = JSON.parse(scheduleField.dataset.initialSchedule || '[]');
    } catch (error) {
      scheduleData = [];
    }

    function parseInitialImageEntries() {
      if (!imageInitialState) {
        return [];
      }

      try {
        return JSON.parse(imageInitialState.textContent || '[]');
      } catch (error) {
        return [];
      }
    }

    function randomKey(prefix) {
      return prefix + '_' + Math.random().toString(36).slice(2, 10);
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function rowTitle(index) {
      return index === 0 ? 'Portada' : 'Imagen ' + (index + 1);
    }

    function syncImagePayload() {
      if (!imageOrderField) {
        return;
      }

      var payload = Array.prototype.slice.call(imageList.querySelectorAll('.venue-image-row')).map(function (row) {
        var kind = row.dataset.kind;

        if (kind === 'existing') {
          return { kind: 'existing', id: Number(row.dataset.imageId) };
        }

        if (kind === 'remote') {
          return {
            kind: 'remote',
            url: (row.querySelector('.remote-image-url-input').value || '').trim()
          };
        }

        if (kind === 'upload') {
          return {
            kind: 'upload',
            upload_key: row.dataset.uploadKey
          };
        }

        return null;
      }).filter(function (entry) {
        if (!entry) {
          return false;
        }

        if (entry.kind === 'remote') {
          return entry.url.length > 0;
        }

        return true;
      });

      imageOrderField.value = JSON.stringify(payload);
    }

    function refreshImageRows() {
      var rows = Array.prototype.slice.call(imageList.querySelectorAll('.venue-image-row'));

      if (rows.length === 0) {
        imageList.innerHTML = '<div class="border rounded p-4 text-center text-muted">Todavia no has agregado imagenes para este local.</div>';
        syncImagePayload();
        return;
      }

      rows.forEach(function (row, index) {
        var title = row.querySelector('.venue-image-title');
        var moveUpButton = row.querySelector('.move-image-up-button');
        var moveDownButton = row.querySelector('.move-image-down-button');

        if (title) {
          title.textContent = rowTitle(index);
        }

        if (moveUpButton) {
          moveUpButton.disabled = index === 0;
        }

        if (moveDownButton) {
          moveDownButton.disabled = index === rows.length - 1;
        }
      });

      syncImagePayload();
    }

    function updatePreview(wrapper, previewUrl) {
      var preview = wrapper.querySelector('.venue-image-preview');
      var placeholder = wrapper.querySelector('.venue-image-placeholder');

      if (previewUrl) {
        preview.src = previewUrl;
        preview.classList.remove('d-none');
        placeholder.classList.add('d-none');
      } else {
        preview.removeAttribute('src');
        preview.classList.add('d-none');
        placeholder.classList.remove('d-none');
      }
    }

    function moveRow(wrapper, direction) {
      var sibling = direction < 0 ? wrapper.previousElementSibling : wrapper.nextElementSibling;
      if (!sibling) {
        return;
      }

      if (direction < 0) {
        imageList.insertBefore(wrapper, sibling);
      } else {
        imageList.insertBefore(sibling, wrapper);
      }

      refreshImageRows();
    }

    function buildImageRow(entry) {
      var wrapper = document.createElement('div');
      wrapper.className = 'card mb-3 venue-image-row';
      wrapper.dataset.kind = entry.kind;

      if (entry.kind === 'existing') {
        wrapper.dataset.imageId = entry.id;
      }

      if (entry.kind === 'upload') {
        wrapper.dataset.uploadKey = entry.upload_key || randomKey('upload');
      }

      wrapper.innerHTML = '' +
        '<div class="card-body">' +
          '<div class="row align-items-start">' +
            '<div class="col-md-4 mb-3 mb-md-0">' +
              '<div class="border rounded overflow-hidden" style="height: 180px; background: #f8f9fa;">' +
                '<img class="venue-image-preview ' + (entry.preview_url ? '' : 'd-none') + '" src="' + escapeHtml(entry.preview_url || '') + '" style="width: 100%; height: 100%; object-fit: cover;" alt="Preview de imagen">' +
                '<div class="venue-image-placeholder d-flex align-items-center justify-content-center h-100 text-muted ' + (entry.preview_url ? 'd-none' : '') + '">' +
                  '<span>Sin previsualizacion</span>' +
                '</div>' +
              '</div>' +
            '</div>' +
            '<div class="col-md-8">' +
              '<div class="d-flex justify-content-between align-items-start mb-2">' +
                '<div>' +
                  '<h5 class="mb-1 venue-image-title">Imagen</h5>' +
                  '<span class="badge badge-light border">' + escapeHtml(entry.source_label || 'Imagen') + '</span>' +
                '</div>' +
                '<div class="text-nowrap">' +
                  '<button type="button" class="btn btn-sm btn-outline-secondary move-image-up-button mr-1">Subir</button>' +
                  '<button type="button" class="btn btn-sm btn-outline-secondary move-image-down-button mr-1">Bajar</button>' +
                  '<button type="button" class="btn btn-sm btn-outline-danger remove-image-button">Quitar</button>' +
                '</div>' +
              '</div>' +
              '<div class="venue-image-input-container"></div>' +
            '</div>' +
          '</div>' +
        '</div>';

      var inputContainer = wrapper.querySelector('.venue-image-input-container');

      if (entry.kind === 'existing') {
        inputContainer.innerHTML = '' +
          '<p class="text-muted mb-0">Imagen ya guardada. Si quieres cambiar la fuente, quitala y agrega una nueva.</p>';
      }

      if (entry.kind === 'remote') {
        inputContainer.innerHTML = '' +
          '<label class="mb-2">Link externo</label>' +
          '<input type="url" class="form-control remote-image-url-input" placeholder="https://..." value="' + escapeHtml(entry.url || '') + '">' +
          '<small class="form-text text-muted">Ideal para fotos remotas de Google Maps u otras fuentes externas.</small>';

        var remoteInput = inputContainer.querySelector('.remote-image-url-input');
        remoteInput.addEventListener('input', function () {
          var value = remoteInput.value.trim();
          updatePreview(wrapper, value);
          syncImagePayload();
        });
      }

      if (entry.kind === 'upload') {
        var uploadKey = wrapper.dataset.uploadKey;
        inputContainer.innerHTML = '' +
          '<label class="mb-2">Archivo manual</label>' +
          '<input type="file" name="venue[new_images][' + uploadKey + ']" accept="image/*" class="form-control-file upload-image-input">' +
          '<small class="form-text text-muted upload-image-help">' + (entry.requires_selection ? 'Vuelve a seleccionar el archivo antes de guardar.' : 'Se almacenara en el storage propio de Black Coffee.') + '</small>';

        var fileInput = inputContainer.querySelector('.upload-image-input');
        var fileHelp = inputContainer.querySelector('.upload-image-help');

        fileInput.addEventListener('change', function () {
          var file = fileInput.files && fileInput.files[0];
          if (!file) {
            updatePreview(wrapper, null);
            fileHelp.textContent = 'Selecciona un archivo para esta imagen manual.';
            syncImagePayload();
            return;
          }

          var reader = new FileReader();
          reader.onload = function (loadEvent) {
            updatePreview(wrapper, loadEvent.target.result);
          };
          reader.readAsDataURL(file);
          fileHelp.textContent = 'Archivo listo para subirse.';
          syncImagePayload();
        });
      }

      wrapper.querySelector('.move-image-up-button').addEventListener('click', function () {
        moveRow(wrapper, -1);
      });

      wrapper.querySelector('.move-image-down-button').addEventListener('click', function () {
        moveRow(wrapper, 1);
      });

      wrapper.querySelector('.remove-image-button').addEventListener('click', function () {
        wrapper.remove();
        refreshImageRows();
      });

      return wrapper;
    }

    function ensureImageListContainer() {
      if (imageList.querySelector('.venue-image-row')) {
        return;
      }

      imageList.innerHTML = '';
    }

    function addImageRow(entry) {
      ensureImageListContainer();
      imageList.appendChild(buildImageRow(entry));
      refreshImageRows();
    }

    parseInitialImageEntries().forEach(function (entry) {
      addImageRow(entry);
    });

    refreshImageRows();

    addRemoteImageButton.addEventListener('click', function () {
      addImageRow({
        kind: 'remote',
        url: '',
        preview_url: null,
        source_label: 'Link externo'
      });
    });

    addUploadImageButton.addEventListener('click', function () {
      addImageRow({
        kind: 'upload',
        upload_key: randomKey('upload'),
        preview_url: null,
        source_label: 'Archivo manual',
        requires_selection: false
      });
    });

    function updateSubcategoryOptions() {
      var currentCategory = categorySelect.value;
      var allSubcategories = [];

      try {
        allSubcategories = JSON.parse(form.dataset.subcategories || '[]');
      } catch (error) {
        allSubcategories = [];
      }

      var filtered = allSubcategories.filter(function (subcategory) {
        return !currentCategory || subcategory.category === currentCategory;
      });

      subcategoriesList.innerHTML = '';
      filtered.forEach(function (subcategory) {
        var option = document.createElement('option');
        option.value = subcategory.name;
        subcategoriesList.appendChild(option);
      });
    }

    categorySelect.addEventListener('change', function () {
      updateSubcategoryOptions();
      if (subcategoryInput.value) {
        subcategoryInput.value = '';
      }
    });

    function normalizeScheduleData() {
      var dayOrder = ['L', 'M', 'X', 'J', 'V', 'S', 'D'];
      return dayOrder.map(function (dayKey) {
        var existing = scheduleData.find(function (entry) { return entry.day === dayKey; });
        return existing || { day: dayKey, closed: true, slots: [] };
      });
    }

    function slotRow(dayKey, slot) {
      var row = document.createElement('div');
      row.className = 'd-flex align-items-center mb-2 slot-row';
      row.innerHTML = '' +
        '<input type="time" class="form-control mr-2 slot-open" value="' + (slot.open || '') + '">' +
        '<input type="time" class="form-control mr-2 slot-close" value="' + (slot.close || '') + '">' +
        '<button type="button" class="btn btn-outline-danger btn-sm remove-slot-button">Quitar</button>';

      row.querySelector('.remove-slot-button').addEventListener('click', function () {
        row.remove();
      });

      return row;
    }

    function renderScheduleEditor() {
      var labels = {
        'L': 'Lunes',
        'M': 'Martes',
        'X': 'Miercoles',
        'J': 'Jueves',
        'V': 'Viernes',
        'S': 'Sabado',
        'D': 'Domingo'
      };

      scheduleEditor.innerHTML = '';

      normalizeScheduleData().forEach(function (entry) {
        var card = document.createElement('div');
        card.className = 'border rounded p-3 mb-3 schedule-day-card';
        card.dataset.day = entry.day;
        card.innerHTML = '' +
          '<div class="d-flex justify-content-between align-items-center mb-3">' +
            '<div>' +
              '<h5 class="mb-1">' + labels[entry.day] + '</h5>' +
              '<small class="text-muted">Clave: ' + entry.day + '</small>' +
            '</div>' +
            '<div class="form-check">' +
              '<input type="checkbox" class="form-check-input day-closed-toggle" ' + (entry.closed ? 'checked' : '') + '>' +
              '<label class="form-check-label">Cerrado</label>' +
            '</div>' +
          '</div>' +
          '<div class="slots-container"></div>' +
          '<button type="button" class="btn btn-outline-primary btn-sm add-slot-button mt-2">Agregar franja</button>';

        var slotsContainer = card.querySelector('.slots-container');
        var closedToggle = card.querySelector('.day-closed-toggle');
        var addSlotButton = card.querySelector('.add-slot-button');

        function syncClosedState() {
          var closed = closedToggle.checked;
          slotsContainer.style.display = closed ? 'none' : 'block';
          addSlotButton.style.display = closed ? 'none' : 'inline-block';

          if (!closed && slotsContainer.children.length === 0) {
            slotsContainer.appendChild(slotRow(entry.day, { open: '', close: '' }));
          }
        }

        (entry.slots || []).forEach(function (slot) {
          slotsContainer.appendChild(slotRow(entry.day, slot));
        });

        closedToggle.addEventListener('change', syncClosedState);
        addSlotButton.addEventListener('click', function () {
          slotsContainer.appendChild(slotRow(entry.day, { open: '', close: '' }));
          syncClosedState();
        });

        scheduleEditor.appendChild(card);
        syncClosedState();
      });
    }

    function collectSchedulePayload() {
      var payload = [];

      Array.prototype.slice.call(scheduleEditor.querySelectorAll('.schedule-day-card')).forEach(function (card) {
        var closed = card.querySelector('.day-closed-toggle').checked;
        var slots = [];

        if (!closed) {
          Array.prototype.slice.call(card.querySelectorAll('.slot-row')).forEach(function (row) {
            var openInput = row.querySelector('.slot-open').value;
            var closeInput = row.querySelector('.slot-close').value;
            if (openInput && closeInput) {
              slots.push({ open: openInput, close: closeInput });
            }
          });
        }

        payload.push({
          day: card.dataset.day,
          closed: closed || slots.length === 0,
          slots: closed ? [] : slots
        });
      });

      scheduleField.value = JSON.stringify(payload);
    }

    form.addEventListener('submit', function () {
      collectSchedulePayload();
    });

    updateSubcategoryOptions();
    refreshImageLabels();
    renderScheduleEditor();
  });
</script>
