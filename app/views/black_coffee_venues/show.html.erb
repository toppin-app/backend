<style>
  .black-coffee-detail-header {
    gap: 16px;
  }

  .black-coffee-detail-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .black-coffee-detail-actions .btn,
  .black-coffee-detail-actions form {
    margin: 0 !important;
  }

  .black-coffee-detail-actions .btn {
    align-items: center;
    display: inline-flex;
    justify-content: center;
    line-height: 1.15;
  }

  .black-coffee-detail-section-label {
    color: #64748b;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .black-coffee-tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .black-coffee-tag-cloud .badge {
    margin: 0 !important;
    white-space: normal;
  }

  .black-coffee-detail-image {
    max-height: 220px;
    object-fit: cover;
    width: 100%;
  }

  .black-coffee-image-card-header {
    align-items: center;
    display: flex;
    gap: 12px;
    justify-content: space-between;
  }

  .black-coffee-image-card-header form {
    margin: 0;
  }

  .black-coffee-image-card-header .btn {
    align-items: center;
    display: inline-flex;
    font-weight: 800;
    justify-content: center;
    line-height: 1.15;
    min-height: 34px;
  }

  .black-coffee-review-panel {
    background: #f8fafc;
    border: 1px solid #dbe3ef;
    border-radius: 18px;
    padding: 18px;
  }

  .black-coffee-review-panel-header {
    align-items: flex-start;
    display: flex;
    gap: 16px;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .black-coffee-review-panel-title {
    color: #1f2937;
    font-size: 19px;
    font-weight: 900;
    line-height: 1.2;
    margin: 0;
  }

  .black-coffee-review-status-summary {
    align-items: flex-end;
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 150px;
  }

  .black-coffee-review-source-badge,
  .black-coffee-review-source-badge:focus,
  .black-coffee-review-source-badge:hover {
    color: #ffffff !important;
  }

  .black-coffee-review-meta-grid {
    display: grid;
    gap: 10px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-bottom: 16px;
  }

  .black-coffee-review-meta-item {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 12px;
  }

  .black-coffee-review-meta-value {
    color: #1f2937;
    font-weight: 800;
    margin-top: 4px;
  }

  .black-coffee-review-actions-layout {
    display: grid;
    gap: 12px;
    grid-template-columns: minmax(180px, 0.75fr) minmax(260px, 1.25fr);
  }

  .black-coffee-review-action-card {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 14px;
  }

  .black-coffee-review-control-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .black-coffee-review-control-actions form {
    margin: 0;
  }

  .black-coffee-review-control-actions .btn,
  .black-coffee-review-reject-form .btn {
    align-items: center;
    display: inline-flex;
    font-weight: 800;
    justify-content: center;
    line-height: 1.15;
    min-height: 38px;
  }

  .black-coffee-review-reject-form textarea {
    min-height: 74px;
  }

  .black-coffee-review-sidebar {
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
  }

  .black-coffee-review-sidebar .black-coffee-review-panel-header,
  .black-coffee-review-sidebar .black-coffee-review-status-summary {
    align-items: stretch;
    flex-direction: column;
  }

  .black-coffee-review-sidebar .black-coffee-review-meta-grid,
  .black-coffee-review-sidebar .black-coffee-review-actions-layout {
    grid-template-columns: 1fr;
  }

  .black-coffee-review-sidebar .black-coffee-review-reject-form .col-md-5,
  .black-coffee-review-sidebar .black-coffee-review-reject-form .col-md-7 {
    flex: 0 0 100%;
    max-width: 100%;
  }

  .black-coffee-review-sidebar .black-coffee-review-control-actions form,
  .black-coffee-review-sidebar .black-coffee-review-control-actions .btn {
    width: 100%;
  }

  @media (max-width: 767px) {
    .black-coffee-detail-header {
      align-items: stretch !important;
      flex-direction: column;
    }

    .black-coffee-detail-header h2 {
      font-size: 26px;
      line-height: 1.15;
      word-break: break-word;
    }

    .black-coffee-detail-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .black-coffee-detail-actions .btn,
    .black-coffee-detail-actions form,
    .black-coffee-detail-actions form .btn,
    .black-coffee-review-control-actions .btn,
    .black-coffee-review-control-actions form,
    .black-coffee-review-control-actions form .btn,
    .black-coffee-review-reject-form .btn {
      min-height: 44px;
      width: 100%;
    }

    .black-coffee-review-panel-header,
    .black-coffee-review-status-summary {
      align-items: stretch;
      flex-direction: column;
    }

    .black-coffee-review-meta-grid,
    .black-coffee-review-actions-layout {
      grid-template-columns: 1fr;
    }

    .black-coffee-detail-card .card-body {
      padding: 18px;
    }

    .black-coffee-schedule-table thead {
      display: none;
    }

    .black-coffee-schedule-table,
    .black-coffee-schedule-table tbody,
    .black-coffee-schedule-table tr,
    .black-coffee-schedule-table td {
      display: block;
      width: 100%;
    }

    .black-coffee-schedule-table tr {
      border-bottom: 1px solid #e5e7eb;
      padding: 12px 16px;
    }

    .black-coffee-schedule-table td {
      border: 0;
      padding: 3px 0;
      width: 100% !important;
    }

    .black-coffee-schedule-table td::before {
      color: #64748b;
      content: attr(data-label);
      display: block;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.06em;
      margin-bottom: 2px;
      text-transform: uppercase;
    }

    .black-coffee-detail-image {
      max-height: none;
    }

    .black-coffee-image-card-header {
      align-items: stretch;
      flex-direction: column;
    }

    .black-coffee-image-card-header form,
    .black-coffee-image-card-header .btn {
      width: 100%;
    }
  }
</style>

<% linked_images_count = @venue.venue_images.to_a.count(&:external_image?) %>

<div class="d-flex justify-content-between align-items-center mb-4 black-coffee-detail-header">
  <div>
    <p class="text-muted mb-1">Black Coffee / Local</p>
    <h2 class="mb-0"><%= @venue.name %></h2>
  </div>
  <div class="black-coffee-detail-actions">
    <%= link_to 'Volver', black_coffee_venues_path, class: 'btn btn-outline-secondary mr-2' %>
    <% if @venue.google_connected? %>
      <%= link_to 'Ver en Google',
                  @venue.google_maps_url,
                  class: 'btn btn-outline-dark mr-2',
                  target: '_blank',
                  rel: 'noopener' %>
      <%= button_to 'Actualizar desde Google',
                    black_coffee_venue_google_syncs_path(venue_id: @venue.id),
                    method: :post,
                    class: 'btn btn-outline-info mr-2',
                    form_class: 'd-inline-block',
                    data: { confirm: "Se preparara una sincronizacion Google para #{@venue.name}. Continuar?" } %>
    <% end %>
    <%= link_to 'Editar', edit_black_coffee_venue_path(@venue), class: 'btn btn-primary text-white' %>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card mb-4 black-coffee-detail-card">
      <div class="card-body">
        <div class="row">
          <div class="col-md-8">
            <p class="black-coffee-detail-section-label mb-2">Descripcion</p>
            <% if @venue.description_present? %>
              <p><%= @venue.description %></p>
            <% else %>
              <p class="text-muted mb-0">Sin descripcion todavia.</p>
            <% end %>
          </div>
          <div class="col-md-4">
            <p class="black-coffee-detail-section-label mb-2">Estado editorial</p>
            <% if @venue.featured? %>
              <span class="badge badge-success p-2">Destacado</span>
            <% else %>
              <span class="badge badge-light p-2">No destacado</span>
            <% end %>
          </div>
        </div>

        <hr>

        <div class="row">
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Visibilidad</p>
            <% if @venue.visible_to_app? %>
              <span class="badge badge-success p-2">Visible en la app</span>
            <% else %>
              <span class="badge badge-danger p-2">Oculto en la app</span>
            <% end %>
          </div>
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Pago</p>
            <% if @venue.payment_current_for_dashboard? %>
              <span class="badge badge-success p-2">Pago al dia</span>
            <% else %>
              <span class="badge badge-warning p-2">Pago pendiente</span>
            <% end %>
          </div>
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Uso interno</p>
            <% if @venue.internal_test_for_dashboard? %>
              <span class="badge badge-info p-2">Sitio de prueba interno</span>
            <% else %>
              <span class="badge badge-light p-2">Sitio real</span>
            <% end %>
          </div>
        </div>

        <hr>

        <div class="row">
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Conexion Google</p>
            <% if @venue.google_connected? %>
              <span class="badge badge-success p-2">Conectado</span>
              <div class="text-muted small mt-2"><%= @venue.google_place_id %></div>
              <div class="mt-3">
                <%= link_to 'Ver ficha en Google',
                            @venue.google_maps_url,
                            class: 'btn btn-sm btn-outline-dark mr-2 mb-2',
                            target: '_blank',
                            rel: 'noopener' %>
                <%= button_to 'Actualizar ahora desde Google',
                              black_coffee_venue_google_syncs_path(venue_id: @venue.id),
                              method: :post,
                              class: 'btn btn-sm btn-outline-info mb-2',
                              form_class: 'd-inline-block',
                              data: { confirm: "Se preparara una sincronizacion Google para #{@venue.name}. Continuar?" } %>
              </div>
            <% else %>
              <span class="badge badge-light p-2">Sin Google Place ID</span>
            <% end %>
          </div>
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Etiqueta principal Google</p>
            <% if @venue.google_primary_type_for_dashboard.present? %>
              <div>
                <span class="badge badge-primary p-2"><%= @venue.google_primary_type_for_dashboard %></span>
              </div>
              <% if @venue.google_primary_type_inferred? %>
                <div class="text-warning small mt-2">Inferido desde etiquetas antiguas. Se confirmara al sincronizar con Google.</div>
              <% end %>
            <% else %>
              <span class="text-muted">Sin etiqueta principal guardada</span>
            <% end %>
          </div>
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Pais</p>
            <strong><%= @venue.country.presence || 'Sin pais' %></strong>
            <% if @venue.country_code.present? %>
              <div class="text-muted small"><%= @venue.country_code %></div>
            <% end %>
          </div>
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Estado / Region</p>
            <strong><%= @venue.state.presence || 'Sin region' %></strong>
          </div>
        </div>

        <hr>

        <div class="row">
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Categoria</p>
            <strong><%= Venue.category_label_for(@venue.category) %></strong>
          </div>
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Subcategoria</p>
            <strong><%= BlackCoffeeTaxonomy.label_for(@venue.category, @venue.subcategory_name).presence || 'Sin subcategoria' %></strong>
            <% if @venue.subcategory_name.present? %>
              <div class="text-muted small"><%= @venue.subcategory_name %></div>
            <% end %>
          </div>
          <div class="col-md-4 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Favoritos</p>
            <strong><%= @venue.favorites_count %></strong>
          </div>
          <div class="col-md-6 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Direccion</p>
            <strong><%= @venue.address %></strong>
          </div>
          <div class="col-md-3 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Ciudad</p>
            <strong><%= @venue.city %></strong>
          </div>
          <div class="col-md-3 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Codigo postal</p>
            <strong><%= @venue.postal_code.presence || 'Sin codigo postal' %></strong>
          </div>
          <div class="col-md-3 mb-3">
            <p class="black-coffee-detail-section-label mb-2">Coordenadas</p>
            <strong><%= number_with_precision(@venue.latitude, precision: 6) %>, <%= number_with_precision(@venue.longitude, precision: 6) %></strong>
          </div>
        </div>

        <p class="black-coffee-detail-section-label mb-2">Mapa de etiquetas Google</p>
        <% if @venue.google_primary_type_for_dashboard.present? %>
          <div class="mb-2">
            <span class="badge badge-primary mr-2 mb-2 p-2"><%= @venue.google_primary_type_for_dashboard %></span>
            <span class="text-muted small">Etiqueta principal</span>
          </div>
        <% end %>
        <p class="black-coffee-detail-section-label mb-2">Etiquetas Google secundarias</p>
        <div class="black-coffee-tag-cloud mb-0">
          <% if @venue.google_secondary_type_list.any? %>
            <% @venue.google_secondary_type_list.each do |tag| %>
              <span class="badge badge-dark mr-2 mb-2 p-2"><%= tag %></span>
            <% end %>
            <p class="text-muted small mb-0">Estas etiquetas incluyen los tipos secundarios guardados por Google. Se usan para filtros internos y limpieza masiva.</p>
          <% elsif Array(@venue.tags).any? %>
            <% Array(@venue.tags).each do |tag| %>
              <span class="badge badge-dark mr-2 mb-2 p-2"><%= tag %></span>
            <% end %>
            <p class="text-warning small mb-0">Todavia no tenemos el desglose primario/secundario persistido en este local. El detalle se completara al sincronizarlo con Google.</p>
          <% else %>
            <p class="text-muted mb-0">Sin etiquetas internas.</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header bg-white">
        <h4 class="mb-0">Horarios</h4>
      </div>
      <div class="card-body p-0">
        <table class="table mb-0 black-coffee-schedule-table">
          <thead>
            <tr>
              <th>Dia</th>
              <th>Franja</th>
            </tr>
          </thead>
          <tbody>
            <% @venue.weekly_schedule.each do |entry| %>
              <tr>
                <td data-label="Dia" style="width: 180px;"><strong><%= Venue.day_name(entry[:day]) %></strong></td>
                <td data-label="Franja">
                  <% if entry[:closed] %>
                    <span class="text-muted">Cerrado</span>
                  <% else %>
                    <% entry[:slots].each do |slot| %>
                      <span class="badge badge-light mr-2 mb-2 p-2"><%= slot[:open] %> - <%= slot[:close] %></span>
                    <% end %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card">
      <div class="card-header bg-white black-coffee-image-card-header">
        <h4 class="mb-0">Imagenes</h4>
        <% if linked_images_count.positive? %>
          <%= button_to 'Transformar links en binarios',
                        convert_linked_images_black_coffee_venue_path(@venue),
                        method: :post,
                        class: 'btn btn-sm btn-outline-info',
                        data: {
                          confirm: "Se descargaran #{linked_images_count} imagen(es) enlazadas y se reemplazaran por archivos internos. Las imagenes que fallen quedaran sin cambios. Continuar?"
                        } %>
        <% end %>
      </div>
      <div class="card-body">
        <% if linked_images_count.positive? %>
          <p class="text-muted small mb-3">
            <strong><%= linked_images_count %></strong> imagen(es) siguen como link externo.
          </p>
        <% end %>
        <% if @venue.image_urls(base_url: request.base_url).any? %>
          <% @venue.image_urls(base_url: request.base_url).each do |image_url| %>
            <div class="mb-3">
              <%= image_tag image_url, class: 'img-fluid rounded border black-coffee-detail-image' %>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">Este local todavia no tiene imagenes.</p>
        <% end %>
      </div>
    </div>

    <% review_source = black_coffee_review_source_for(@venue) %>
    <div class="black-coffee-review-panel black-coffee-review-sidebar mt-4">
      <div class="black-coffee-review-panel-header">
        <div>
          <p class="black-coffee-detail-section-label mb-2">Revision Black Coffee</p>
          <h3 class="black-coffee-review-panel-title">Gestion manual del estado de revision</h3>
          <p class="text-muted mb-0">Cambia el estado de este local sin tener que abrir un lote completo.</p>
        </div>
        <div class="black-coffee-review-status-summary">
          <span class="badge badge-<%= @venue.review_status_badge_class %> p-2"><%= @venue.review_status_label %></span>
          <% if review_source[:kind] == :batch %>
            <%= link_to review_source[:label],
                        black_coffee_review_path(review_source[:batch]),
                        class: 'badge badge-info p-2 black-coffee-review-source-badge' %>
          <% elsif review_source[:kind] == :manual %>
            <span class="badge badge-info p-2 black-coffee-review-source-badge"><%= review_source[:label] %></span>
          <% else %>
            <span class="badge badge-light p-2"><%= review_source[:label] %></span>
          <% end %>
        </div>
      </div>

      <div class="black-coffee-review-meta-grid">
        <div class="black-coffee-review-meta-item">
          <div class="black-coffee-detail-section-label">Motivo</div>
          <div class="black-coffee-review-meta-value">
            <%= @venue.review_rejection_reason.present? ? @venue.review_rejection_reason_label : 'Sin motivo' %>
          </div>
        </div>
        <div class="black-coffee-review-meta-item">
          <div class="black-coffee-detail-section-label">Reviewer</div>
          <div class="black-coffee-review-meta-value">
            <%= @venue.reviewed_by&.name.presence || @venue.reviewed_by&.email.presence || 'Sin reviewer' %>
          </div>
        </div>
        <div class="black-coffee-review-meta-item">
          <div class="black-coffee-detail-section-label">Fecha</div>
          <div class="black-coffee-review-meta-value">
            <%= @venue.reviewed_at&.strftime('%d/%m/%Y %H:%M') || 'Sin fecha' %>
          </div>
        </div>
        <div class="black-coffee-review-meta-item">
          <div class="black-coffee-detail-section-label">Nota interna</div>
          <div class="black-coffee-review-meta-value">
            <%= @venue.review_rejection_note.presence || 'Sin nota' %>
          </div>
        </div>
      </div>

      <div class="black-coffee-review-actions-layout">
        <div class="black-coffee-review-action-card">
          <div class="black-coffee-detail-section-label mb-2">Acciones rapidas</div>
          <div class="black-coffee-review-control-actions">
            <%= button_to 'Aprobar',
                          review_black_coffee_venue_path(@venue),
                          method: :patch,
                          params: { review_status: Venue::REVIEW_STATUS_APPROVED },
                          class: 'btn btn-sm btn-success text-white',
                          data: { confirm: "¿Marcar #{@venue.name} como aprobado?" } %>
            <%= button_to 'Volver a pendiente',
                          review_black_coffee_venue_path(@venue),
                          method: :patch,
                          params: { review_status: Venue::REVIEW_STATUS_PENDING },
                          class: 'btn btn-sm btn-outline-warning',
                          data: { confirm: "¿Devolver #{@venue.name} a pendiente de revision?" } %>
          </div>
        </div>

        <div class="black-coffee-review-action-card">
          <%= form_with url: review_black_coffee_venue_path(@venue),
                        method: :patch,
                        local: true,
                        html: { class: 'black-coffee-review-reject-form' } do %>
            <%= hidden_field_tag :review_status, Venue::REVIEW_STATUS_REJECTED %>
            <div class="row">
              <div class="col-md-5 mb-3">
                <%= label_tag :review_rejection_reason, 'Rechazar con motivo', class: 'black-coffee-detail-section-label mb-2' %>
                <%= select_tag :review_rejection_reason,
                               options_for_select(Venue::REJECTION_REASON_LABELS.map { |code, label| [label, code] }, @venue.review_rejection_reason),
                               class: 'form-control form-control-sm' %>
              </div>
              <div class="col-md-7">
                <%= label_tag :review_rejection_note, 'Nota interna opcional', class: 'black-coffee-detail-section-label mb-2' %>
                <%= text_area_tag :review_rejection_note,
                                  @venue.review_rejection_note,
                                  class: 'form-control form-control-sm',
                                  placeholder: 'Ej: clasificado por Google como cine, pero es un local que no encaja.' %>
              </div>
            </div>
            <%= submit_tag 'Rechazar local',
                           class: 'btn btn-sm btn-outline-danger btn-block mt-3',
                           data: { confirm: "¿Marcar #{@venue.name} como rechazado?" } %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
