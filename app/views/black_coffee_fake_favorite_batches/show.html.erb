<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Favoritos fake</p>
    <h2 class="mb-0">Lote #<%= @batch.id %></h2>
  </div>
  <div class="mt-3 mt-md-0">
    <%= link_to 'Volver a la utilidad', black_coffee_fake_favorite_batches_path, class: 'btn btn-outline-dark mr-2' %>
    <% if @batch.active? %>
      <button type="button" class="btn btn-success text-white" id="fake-favorites-continue-button">Seguir procesando</button>
    <% elsif @batch.retryable? %>
      <%= button_to 'Reiniciar lote',
                    retry_black_coffee_fake_favorite_batch_path(@batch),
                    method: :post,
                    class: 'btn btn-danger text-white',
                    form_class: 'd-inline-block',
                    data: { confirm: 'Se borraran otra vez los favoritos fake actuales y se regenerara el lote completo. Continuar?' } %>
    <% end %>
  </div>
</div>

<div class="alert alert-info">
  Este lote trabaja solo con usuarios fake. Primero limpia sus favoritos anteriores y luego crea nuevos favoritos aleatorios por ciudad/region y categoria, en bloques cortos para no colgar el dashboard.
</div>

<div id="black-coffee-fake-favorites-batch"
     data-advance-url="<%= advance_black_coffee_fake_favorite_batch_path(@batch) %>"
     data-status-url="<%= status_black_coffee_fake_favorite_batch_path(@batch) %>">
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <div>
          <strong>Progreso de la regeneracion</strong>
          <div class="text-muted small" id="fake-favorites-live-note">
            Estado actual del lote de favoritos fake.
          </div>
        </div>
        <span class="badge badge-secondary p-2" id="fake-favorites-status-badge"><%= @batch.status %></span>
      </div>

      <div class="progress mb-3" style="height: 14px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated"
             id="fake-favorites-progress-bar"
             role="progressbar"
             style="width: <%= [@batch.completion_percentage, 100].min %>%"
             aria-valuenow="<%= @batch.completion_percentage %>"
             aria-valuemin="0"
             aria-valuemax="100"></div>
      </div>

      <div class="row text-center">
        <div class="col-md-2 col-6 mb-3 mb-md-0">
          <div class="text-muted small text-uppercase">Avance</div>
          <h4 class="mb-0" id="fake-favorites-progress-value"><%= @batch.completion_percentage %>%</h4>
        </div>
        <div class="col-md-2 col-6 mb-3 mb-md-0">
          <div class="text-muted small text-uppercase">Usuarios</div>
          <h4 class="mb-0" id="fake-favorites-processed-value"><%= number_with_delimiter(@batch.processed_users_count) %>/<%= number_with_delimiter(@batch.total_users_count) %></h4>
        </div>
        <div class="col-md-2 col-6">
          <div class="text-muted small text-uppercase">Favoritos borrados</div>
          <h4 class="mb-0 text-warning" id="fake-favorites-deleted-value"><%= number_with_delimiter(@batch.deleted_favorites_count) %></h4>
        </div>
        <div class="col-md-2 col-6">
          <div class="text-muted small text-uppercase">Favoritos creados</div>
          <h4 class="mb-0 text-success" id="fake-favorites-created-value"><%= number_with_delimiter(@batch.created_favorites_count) %></h4>
        </div>
        <div class="col-md-2 col-6 mt-3 mt-md-0">
          <div class="text-muted small text-uppercase">Errores</div>
          <h4 class="mb-0 text-danger" id="fake-favorites-failed-value"><%= number_with_delimiter(@batch.failed_users_count) %></h4>
        </div>
        <div class="col-md-2 col-6 mt-3 mt-md-0">
          <div class="text-muted small text-uppercase">Pendientes</div>
          <h4 class="mb-0" id="fake-favorites-pending-value"><%= number_with_delimiter(@batch.pending_users_count) %></h4>
        </div>
      </div>

      <div class="row text-center mt-3">
        <div class="col-md-4 col-6 mb-2 mb-md-0">
          <div class="text-muted small text-uppercase">Combinaciones</div>
          <h5 class="mb-0" id="fake-favorites-combinations-value"><%= number_with_delimiter(@batch.combinations_count) %></h5>
        </div>
        <div class="col-md-4 col-6">
          <div class="text-muted small text-uppercase">Sin locales</div>
          <h5 class="mb-0" id="fake-favorites-empty-value"><%= number_with_delimiter(@batch.combinations_without_venues_count) %></h5>
        </div>
        <div class="col-md-4 col-12 mt-2 mt-md-0">
          <div class="text-muted small text-uppercase">Ultimo usuario</div>
          <h5 class="mb-0" id="fake-favorites-last-user-value"><%= @batch.last_processed_user_name.presence || @batch.last_processed_user_id.presence || '-' %></h5>
        </div>
      </div>

      <div class="mt-3 small text-muted" id="fake-favorites-current-line">
        <% if @batch.current_user_name.present? %>
          Procesando ahora: <strong><%= @batch.current_user_name %></strong>
        <% elsif @batch.finished? %>
          No quedan usuarios fake pendientes en este lote.
        <% else %>
          Esperando al siguiente bloque...
        <% end %>
      </div>

      <div class="mt-3" id="fake-favorites-error-container" style="<%= @batch.error_message.present? ? '' : 'display: none;' %>">
        <div class="alert alert-danger mb-0" id="fake-favorites-error-message"><%= @batch.error_message %></div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-6 mb-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white">
          <strong>Resumen del alcance</strong>
        </div>
        <div class="card-body">
          <p class="mb-2"><strong>Ciudades o regiones detectadas:</strong> <%= number_with_delimiter(@batch.states.size) %></p>
          <p class="mb-2"><strong>Categorias detectadas:</strong> <%= number_with_delimiter(@batch.categories.size) %></p>
          <p class="mb-0"><strong>Reseteo inicial hecho:</strong> <%= @batch.favorites_reset_at.present? ? l(@batch.favorites_reset_at, format: :short) : 'Todavia no' %></p>
        </div>
      </div>
    </div>

    <div class="col-lg-6 mb-4">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-header bg-white">
          <strong>Combinaciones sin locales</strong>
        </div>
        <div class="card-body">
          <% empty_labels = @batch.empty_combinations.map { |entry| entry['label'] } %>
          <% if empty_labels.any? %>
            <ul class="mb-0 pl-3">
              <% empty_labels.first(12).each do |label| %>
                <li class="mb-2"><%= label %></li>
              <% end %>
            </ul>
            <% if empty_labels.size > 12 %>
              <div class="text-muted small mt-3">
                Mostrando 12 de <%= number_with_delimiter(empty_labels.size) %> combinaciones vacias.
              </div>
            <% end %>
          <% else %>
            <p class="text-muted mb-0">Todas las combinaciones detectadas tienen al menos un local disponible.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="fake-favorites-initial-state"><%= raw json_escape(@progress_payload.to_json) %></script>

<script>
  (function() {
    const container = document.getElementById('black-coffee-fake-favorites-batch');
    const initialStateNode = document.getElementById('fake-favorites-initial-state');
    if (!container || !initialStateNode) return;

    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
    const formatter = new Intl.NumberFormat('es-ES');
    let state = JSON.parse(initialStateNode.textContent);
    let pollTimer = null;
    let requestInFlight = false;

    const statusBadge = document.getElementById('fake-favorites-status-badge');
    const progressBar = document.getElementById('fake-favorites-progress-bar');
    const progressValue = document.getElementById('fake-favorites-progress-value');
    const processedValue = document.getElementById('fake-favorites-processed-value');
    const deletedValue = document.getElementById('fake-favorites-deleted-value');
    const createdValue = document.getElementById('fake-favorites-created-value');
    const failedValue = document.getElementById('fake-favorites-failed-value');
    const pendingValue = document.getElementById('fake-favorites-pending-value');
    const combinationsValue = document.getElementById('fake-favorites-combinations-value');
    const emptyValue = document.getElementById('fake-favorites-empty-value');
    const lastUserValue = document.getElementById('fake-favorites-last-user-value');
    const currentLine = document.getElementById('fake-favorites-current-line');
    const liveNote = document.getElementById('fake-favorites-live-note');
    const errorContainer = document.getElementById('fake-favorites-error-container');
    const errorMessage = document.getElementById('fake-favorites-error-message');
    const continueButton = document.getElementById('fake-favorites-continue-button');

    function badgeClass(status) {
      if (status === 'completed') return 'badge badge-success p-2';
      if (status === 'failed') return 'badge badge-danger p-2';
      if (status === 'running') return 'badge badge-primary p-2';
      if (status === 'cancelled') return 'badge badge-dark p-2';
      return 'badge badge-secondary p-2';
    }

    function progressClass(status, active) {
      if (status === 'completed') return 'progress-bar bg-success';
      if (status === 'failed') return 'progress-bar bg-danger';
      if (active) return 'progress-bar bg-primary progress-bar-striped progress-bar-animated';
      return 'progress-bar bg-secondary';
    }

    function render(data) {
      state = data;

      statusBadge.className = badgeClass(data.status);
      statusBadge.textContent = data.status;

      progressBar.className = progressClass(data.status, data.active);
      progressBar.style.width = `${Math.min(data.completionPercentage || 0, 100)}%`;
      progressBar.setAttribute('aria-valuenow', data.completionPercentage || 0);

      progressValue.textContent = `${data.completionPercentage || 0}%`;
      processedValue.textContent = `${formatter.format(data.processedUsers || 0)}/${formatter.format(data.totalUsers || 0)}`;
      deletedValue.textContent = formatter.format(data.deletedFavorites || 0);
      createdValue.textContent = formatter.format(data.createdFavorites || 0);
      failedValue.textContent = formatter.format(data.failedUsers || 0);
      pendingValue.textContent = formatter.format(data.pendingUsers || 0);
      combinationsValue.textContent = formatter.format(data.combinationsCount || 0);
      emptyValue.textContent = formatter.format(data.combinationsWithoutVenues || 0);
      lastUserValue.textContent = data.lastProcessedUserName || data.lastProcessedUserId || '-';

      if (data.currentUserName) {
        currentLine.innerHTML = `Procesando ahora: <strong>${data.currentUserName}</strong>`;
      } else if (data.finished) {
        currentLine.textContent = 'No quedan usuarios fake pendientes en este lote.';
      } else {
        currentLine.textContent = 'Esperando al siguiente bloque...';
      }

      if (data.active) {
        liveNote.textContent = 'Procesando bloques cortos automaticamente. Asi regeneramos favoritos fake sin bloquear el panel.';
      } else if (data.status === 'completed') {
        liveNote.textContent = 'Lote completado. Ya puedes revisar los destacados o lanzar otra regeneracion.';
      } else if (data.status === 'failed') {
        liveNote.textContent = 'La regeneracion se detuvo con error. Puedes reiniciarla desde cero.';
      } else {
        liveNote.textContent = 'Proceso en pausa.';
      }

      if (data.errorMessage) {
        errorContainer.style.display = '';
        errorMessage.textContent = data.errorMessage;
      } else {
        errorContainer.style.display = 'none';
        errorMessage.textContent = '';
      }

      if (continueButton) {
        continueButton.disabled = !data.active && data.status !== 'pending' && data.status !== 'running';
      }
    }

    function scheduleNext(delayMs) {
      window.clearTimeout(pollTimer);
      if (!state.active) return;
      pollTimer = window.setTimeout(tick, delayMs);
    }

    function tick() {
      if (requestInFlight || !state.active) return;
      requestInFlight = true;

      fetch(container.dataset.advanceUrl, {
        method: 'POST',
        headers: {
          'Accept': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        credentials: 'same-origin'
      })
        .then(response => response.json().then(data => ({ ok: response.ok, data })))
        .then(({ ok, data }) => {
          render(data);
          if (!ok) {
            scheduleNext(3000);
            return;
          }
          scheduleNext(1000);
        })
        .catch(() => {
          liveNote.textContent = 'Hubo un problema temporal de conexion. Reintentando en unos segundos...';
          scheduleNext(3000);
        })
        .finally(() => {
          requestInFlight = false;
        });
    }

    if (continueButton) {
      continueButton.addEventListener('click', function() {
        if (requestInFlight) return;
        tick();
      });
    }

    render(state);
    if (state.active) {
      scheduleNext(600);
    }
  })();
</script>
