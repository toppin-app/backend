<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div>
    <div class="text-muted font-weight-bold">Black Coffee / Importaciones</div>
    <h1 class="mb-1">Importador FanMusicFest</h1>
    <p class="text-muted mb-0">Trae festivales futuros de Espana desde FanMusicFest con dry-run, filtro estricto e imagenes guardadas como binario.</p>
  </div>
  <div class="mt-3 mt-md-0">
    <%= link_to 'Volver a locales', black_coffee_venues_path, class: 'btn btn-outline-secondary mr-2' %>
    <%= link_to 'Importador Google', black_coffee_google_imports_path, class: 'btn btn-outline-primary' %>
  </div>
</div>

<div class="alert alert-info">
  <strong>Herramienta controlada.</strong>
  Respeta robots.txt de FanMusicFest y fuerza un delay minimo de 10 segundos entre peticiones. El formulario manual ejecuta dry-run por defecto y no crea locales.
</div>

<div class="card border-0 shadow-sm mb-4 border-left-success">
  <div class="card-body">
    <div class="d-flex flex-wrap justify-content-between align-items-start">
      <div class="mr-3">
        <h4 class="mb-1">Importacion completa de Espana</h4>
        <p class="text-muted mb-0">
          Recorre todas las paginas del calendario (hasta <%= BlackCoffeeFestivalImportsController::MAX_PAGES %>),
          se queda solo con festivales de Espana cuya fecha es futura, consulta cada ficha de detalle
          y descarga las imagenes como binario. Los locales quedan visibles en la app pero pendientes de revision.
        </p>
        <p class="text-muted small mb-0 mt-2">
          Se ejecuta en segundo plano respetando el delay entre peticiones, asi que puede tardar
          desde varios minutos hasta cerca de una hora. Puedes cerrar la pagina; se puede cancelar
          en cualquier momento y volver a lanzarla sin duplicar los festivales ya creados.
        </p>
      </div>
    </div>
    <%= form_with url: black_coffee_festival_imports_path, method: :post, local: true, class: 'mt-3' do %>
      <%= hidden_field_tag :preset, 'import_all_spain' %>
      <div class="form-row align-items-end">
        <div class="form-group col-md-3 mb-2 mb-md-0">
          <%= label_tag :request_delay_seconds_all, 'Delay seg.' %>
          <%= number_field_tag :request_delay_seconds, 10, min: 10, max: 120, step: 1, id: 'request_delay_seconds_all', class: 'form-control' %>
        </div>
        <div class="form-group col-md-9 mb-0">
          <%= submit_tag 'Traer todos los festivales futuros de Espana',
                         class: 'btn btn-success text-white',
                         data: { confirm: 'Se recorreran todas las paginas y se crearan los festivales futuros de Espana, descargando sus imagenes. El proceso corre en segundo plano y puede tardar hasta cerca de una hora. Continuar?' } %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="row">
  <div class="col-lg-7 mb-4">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h4 class="mb-0">Crear nueva importacion</h4>
      </div>
      <div class="card-body">
        <%= form_with url: black_coffee_festival_imports_path, method: :post, local: true do %>
          <div class="form-row">
            <div class="form-group col-md-6">
              <%= label_tag :operation, 'Operacion' %>
              <%= select_tag :operation,
                             options_for_select([
                               ['Descubrir festivales nuevos', 'import'],
                               ['Reprocesar detalles de festivales existentes', 'refresh_details']
                             ], 'import'),
                             class: 'form-control' %>
              <small class="text-muted">El reprocesado completa fuente, coordenadas, entradas y descripcion sin duplicar venues.</small>
            </div>
            <div class="form-group col-md-6">
              <%= label_tag :mode, 'Modo' %>
              <%= select_tag :mode,
                             options_for_select([
                               ['Dry run: solo simular y registrar candidatos', 'dry_run'],
                               ['Aplicar cambios: crear o actualizar festivales', 'import']
                             ], 'dry_run'),
                             class: 'form-control' %>
              <small class="text-muted">Usa dry-run para medir antes de crear venues.</small>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group col-md-3">
              <%= label_tag :max_pages, 'Paginas' %>
              <%= number_field_tag :max_pages, 1, min: 1, max: BlackCoffeeFestivalImportsController::MAX_PAGES, class: 'form-control' %>
              <small class="text-muted">Solo para descubrir. Maximo 13.</small>
            </div>
            <div class="form-group col-md-3">
              <%= label_tag :request_delay_seconds, 'Delay seg.' %>
              <%= number_field_tag :request_delay_seconds, 10, min: 10, max: 120, step: 1, class: 'form-control' %>
              <small class="text-muted">robots.txt pide 10.</small>
            </div>
            <div class="form-group col-md-3">
              <%= label_tag :max_details, 'Max. detalles' %>
              <%= number_field_tag :max_details, 100, min: 0, max: BlackCoffeeFestivalImportsController::MAX_DETAILS, class: 'form-control' %>
              <small class="text-muted">Limite de fichas y peticiones de detalle.</small>
            </div>
            <div class="form-group col-md-3">
              <div class="custom-control custom-switch mt-4">
                <%= check_box_tag :import_details, '1', false, class: 'custom-control-input', id: 'fanmusicfest_import_details' %>
                <%= label_tag :fanmusicfest_import_details, 'Consultar fichas de detalle', class: 'custom-control-label' %>
              </div>
              <small class="text-muted">En reprocesado siempre se consulta la ficha.</small>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group col-md-3">
              <%= hidden_field_tag :only_future, '0' %>
              <div class="custom-control custom-switch mt-4">
                <%= check_box_tag :only_future, '1', true, class: 'custom-control-input', id: 'fanmusicfest_only_future' %>
                <%= label_tag :fanmusicfest_only_future, 'Solo futuros', class: 'custom-control-label' %>
              </div>
              <small class="text-muted">Descarta festivales cuya fecha ya paso.</small>
            </div>
            <div class="form-group col-md-3">
              <%= hidden_field_tag :download_images, '0' %>
              <div class="custom-control custom-switch mt-4">
                <%= check_box_tag :download_images, '1', true, class: 'custom-control-input', id: 'fanmusicfest_download_images' %>
                <%= label_tag :fanmusicfest_download_images, 'Descargar imagenes', class: 'custom-control-label' %>
              </div>
              <small class="text-muted">Guarda la imagen como binario, no solo la URL.</small>
            </div>
            <div class="form-group col-md-3">
              <div class="custom-control custom-switch mt-4">
                <%= check_box_tag :auto_publish, '1', false, class: 'custom-control-input', id: 'fanmusicfest_auto_publish' %>
                <%= label_tag :fanmusicfest_auto_publish, 'Autopublicar', class: 'custom-control-label' %>
              </div>
              <small class="text-muted">Por defecto quedan visibles pero pendientes de revision.</small>
            </div>
          </div>

          <%= submit_tag 'Crear importacion en servidor', class: 'btn btn-primary text-white' %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5 mb-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white">
        <h4 class="mb-0">Resumen de seguridad</h4>
      </div>
      <div class="card-body">
        <ul class="mb-0">
          <li>Solo se aceptan festivales con pais normalizado como ES.</li>
          <li>Con "Solo futuros" se descartan los festivales cuya fecha ya paso.</li>
          <li>Las imagenes se descargan y se guardan como binario; si falla la descarga se conserva la URL.</li>
          <li>Los locales importados quedan con categoria festival.</li>
          <li>Los festivales se crean visibles en la app, pero con review pendiente hasta aprobarlos.</li>
          <li>Se salta cualquier duplicado por fuente/fingerprint antes de crear venue.</li>
          <li>El reprocesado conserva datos manuales y nunca publica la descripcion externa sin aprobarla.</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white">
    <h4 class="mb-0">Importaciones recientes</h4>
  </div>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>#</th>
          <th>Estado</th>
          <th>Modo</th>
          <th>Operacion</th>
          <th>Paginas</th>
          <th>Candidatos</th>
          <th>Creados</th>
          <th>Actualizados</th>
          <th>Saltados</th>
          <th>Requests</th>
          <th>Fecha</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if @recent_runs.any? %>
          <% @recent_runs.each do |run| %>
            <tr>
              <td><strong>#<%= run.id %></strong></td>
              <td><span class="badge badge-<%= run.status_badge_class %>"><%= run.status_label %></span></td>
              <td><%= run.mode_label %></td>
              <td><%= run.operation_label %></td>
              <td><%= run.max_pages %></td>
              <td><%= run.candidates_found_count %></td>
              <td class="text-success"><%= run.venues_created_count %></td>
              <td class="text-info"><%= run.venues_updated_count %></td>
              <td><%= run.outside_country_skipped_count.to_i + run.duplicate_skipped_count.to_i + run.invalid_skipped_count.to_i + run.past_skipped_count.to_i %></td>
              <td><%= run.robots_requests_count.to_i + run.listing_requests_count.to_i + run.detail_requests_count.to_i %></td>
              <td><%= l(run.created_at, format: :short) %></td>
              <td class="text-right"><%= link_to 'Ver', black_coffee_festival_import_path(run), class: 'btn btn-sm btn-outline-primary' %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="12" class="text-center text-muted py-4">Todavia no hay importaciones FanMusicFest.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
