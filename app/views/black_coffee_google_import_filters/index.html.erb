                Algunas etiquetas de esta categoria no se pueden aplicar en Places Aggregate API. Se seguiran usando al importar, pero el total Google pasara a ser aproximado.
                <% unsupported_entries = (filter.aggregate_unsupported_primary_types + filter.aggregate_unsupported_types).uniq %>
                <% if unsupported_entries.any? %>
                  <div class="small mt-2">Etiquetas no aplicables al total Google: <strong><%= unsupported_entries.join(', ') %></strong></div>
                <% end %>
              </div>
            <% end %>

            <div class="d-flex flex-wrap justify-content-between align-items-center">
              <div class="small text-muted mb-2 mb-md-0">
                Estos filtros se aplican ademas de los globales.
              </div>
              <%= submit_tag 'Guardar filtros', class: 'btn btn-primary text-white' %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('turbolinks:load', function () {
    document.querySelectorAll('.js-google-filter-form').forEach(function(form) {
      const searchInput = form.querySelector('.js-google-filter-search');
      if (!searchInput) return;

      form.querySelectorAll('.js-google-filter-add').forEach(function(button) {
        button.addEventListener('click', function () {
          const targetRole = button.dataset.targetRole;
          const input = form.querySelector('.js-google-filter-input[data-role="' + targetRole + '"]');
          if (!input) return;

          const value = (searchInput.value || '').trim();
          if (!value) {
            searchInput.focus();
            return;
          }

          const currentValues = input.value
            .split(/\n|,/)
            .map(function(entry) { return entry.trim(); })
            .filter(Boolean);

          if (!currentValues.includes(value)) {
            currentValues.push(value);
            input.value = currentValues.join("\n");
          }

          searchInput.value = '';
          input.focus();
        });
      });
    });
  });
</script>
