<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Subcategorias</p>
    <h2 class="mb-0">Gestion de subcategorias</h2>
  </div>
  <div>
    <%= link_to 'Volver a locales', black_coffee_venues_path, class: 'btn btn-outline-secondary mr-2' %>
  </div>
</div>

<div class="alert alert-info">
  Este catalogo es fijo y esta alineado con los tipos de Google Places. Desde el dashboard se consulta y se usa al editar locales, pero no se crean valores dinamicos.
</div>

<div class="card mb-4">
  <div class="card-body">
    <%= form_with url: black_coffee_subcategories_path, method: :get, local: true do %>
      <div class="row">
        <div class="col-md-5 mb-3">
          <%= text_field_tag :q, params[:q], class: 'form-control', placeholder: 'Buscar por nombre' %>
        </div>
        <div class="col-md-4 mb-3">
          <%= select_tag :category, options_for_select([['Todas las categorias', '']] + @categories.map { |category| [category, category] }, params[:category]), class: 'form-control' %>
        </div>
        <div class="col-md-3 mb-3">
          <%= submit_tag 'Filtrar', class: 'btn btn-primary btn-block text-white' %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<div class="card">
  <div class="card-body table-responsive p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Etiqueta app</th>
          <th>Categoria</th>
          <th>Tipos Google</th>
          <th>Locales asociados</th>
        </tr>
      </thead>
      <tbody>
        <% if @subcategories.any? %>
          <% @subcategories.each do |subcategory| %>
            <tr>
              <td><strong><%= subcategory[:name] %></strong></td>
              <td><%= subcategory[:label] %></td>
              <td><span class="badge badge-secondary"><%= subcategory[:category] %></span></td>
              <td class="small" style="max-width: 420px;">
                <% if Array(subcategory[:google_types]).any? %>
                  <% Array(subcategory[:google_types]).each do |google_type| %>
                    <span class="badge badge-light border mr-1 mb-1"><%= google_type %></span>
                  <% end %>
                <% else %>
                  <span class="text-muted">Solo keywords internas</span>
                <% end %>
              </td>
              <td><%= subcategory[:venues_count].to_i %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="text-center text-muted py-5">
              No hay subcategorias con los filtros actuales.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
