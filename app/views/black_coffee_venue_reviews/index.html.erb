<style>
  .review-metric-card {
    border: 0;
    border-radius: 14px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
  }

  .review-metric-label {
    color: #64748b;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .review-metric-value {
    color: #1f2937;
    font-size: 30px;
    font-weight: 700;
    line-height: 1;
  }

  .review-panel {
    border: 0;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
  }

  .review-delete-warning {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 12px;
    padding: 14px;
  }

  .review-page-header {
    gap: 16px;
  }

  .review-page-actions,
  .review-batch-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .review-page-actions .btn,
  .review-batch-actions .btn {
    margin: 0 !important;
  }

  .review-status-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .review-status-tabs .btn {
    border-radius: 999px;
    font-weight: 800;
    margin: 0 !important;
  }

  .review-venues-table .venue-title {
    color: #1f2937;
    font-weight: 900;
  }

  .review-venue-thumb {
    background: #f1f5f9;
    border-radius: 12px;
    height: 54px;
    object-fit: cover;
    width: 74px;
  }

  .review-venue-thumb-placeholder {
    align-items: center;
    background: #f1f5f9;
    border-radius: 12px;
    color: #94a3b8;
    display: flex;
    height: 54px;
    justify-content: center;
    width: 74px;
  }

  .review-origin-badge,
  .review-origin-badge:focus,
  .review-origin-badge:hover {
    color: #ffffff !important;
  }

  @media (max-width: 767px) {
    .review-page-header {
      align-items: stretch !important;
      flex-direction: column;
    }

    .review-page-header h2 {
      font-size: 26px;
      line-height: 1.15;
    }

    .review-page-actions,
    .review-batch-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .review-page-actions .btn,
    .review-batch-actions .btn {
      min-height: 44px;
      width: 100%;
    }

    .review-panel input[type="submit"] {
      min-height: 44px;
      width: 100%;
    }

    .review-metric-card .card-body {
      padding: 16px;
    }

    .review-metric-value {
      font-size: 26px;
    }

    .review-panel {
      border-radius: 14px;
    }

    .review-status-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .review-status-tabs .btn {
      min-height: 42px;
      width: 100%;
    }

    .review-history-table thead,
    .review-venues-table thead {
      display: none;
    }

    .review-history-table,
    .review-history-table tbody,
    .review-history-table tr,
    .review-history-table td,
    .review-venues-table,
    .review-venues-table tbody,
    .review-venues-table tr,
    .review-venues-table td {
      display: block;
      width: 100%;
    }

    .review-history-table tr,
    .review-venues-table tr {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 16px;
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.07);
      margin: 0 10px 16px;
      overflow: hidden;
    }

    .review-history-table td,
    .review-venues-table td {
      align-items: flex-start;
      border-top: 0;
      display: flex;
      gap: 12px;
      justify-content: space-between;
      padding: 10px 14px;
      text-align: right !important;
      white-space: normal !important;
    }

    .review-history-table td::before,
    .review-venues-table td::before {
      color: #64748b;
      content: attr(data-label);
      flex: 0 0 40%;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.06em;
      text-align: left;
      text-transform: uppercase;
    }

    .review-history-table td[data-label="Acciones"],
    .review-history-table td[colspan],
    .review-venues-table td[data-label="Acciones"],
    .review-venues-table td[colspan] {
      display: block;
      text-align: left !important;
    }

    .review-history-table td[data-label="Acciones"]::before,
    .review-venues-table td[data-label="Acciones"]::before {
      display: block;
      margin-bottom: 8px;
      width: 100%;
    }

    .review-history-table td[colspan],
    .review-venues-table td[colspan] {
      text-align: center !important;
    }

    .review-history-table td[colspan]::before,
    .review-venues-table td[colspan]::before {
      display: none;
    }

    .review-venue-thumb,
    .review-venue-thumb-placeholder {
      height: 88px;
      width: 100%;
    }
  }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 review-page-header">
  <div>
    <p class="text-muted mb-1">Black Coffee / Revisión manual</p>
    <h2 class="mb-0">Revisión de locales importados en Black Coffee</h2>
    <p class="text-muted mb-0">Carga un lote pendiente, rechaza lo que no encaje y aprueba el resto al finalizar.</p>
  </div>
  <div class="review-page-actions mt-3 mt-md-0">
    <%= link_to 'Locales', black_coffee_venues_path, class: 'btn btn-outline-secondary mr-2' %>
    <%= link_to 'Herramientas de imagenes', black_coffee_image_audits_path, class: 'btn btn-outline-info mr-2' %>
    <%= link_to 'Importador Google', black_coffee_google_imports_path, class: 'btn btn-outline-primary' %>
  </div>
</div>

<div class="row mb-4">
  <div class="col-6 col-lg-2 mb-3">
    <div class="card review-metric-card h-100">
      <div class="card-body">
        <div class="review-metric-label">Pendientes</div>
        <div class="review-metric-value text-warning"><%= number_with_delimiter(@metrics[:pending]) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-2 mb-3">
    <div class="card review-metric-card h-100">
      <div class="card-body">
        <div class="review-metric-label">Aprobados</div>
        <div class="review-metric-value text-success"><%= number_with_delimiter(@metrics[:approved]) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-2 mb-3">
    <div class="card review-metric-card h-100">
      <div class="card-body">
        <div class="review-metric-label">Rechazados</div>
        <div class="review-metric-value text-danger"><%= number_with_delimiter(@metrics[:rejected]) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3 mb-3">
    <div class="card review-metric-card h-100">
      <div class="card-body">
        <div class="review-metric-label">Total revisado</div>
        <div class="review-metric-value"><%= number_with_delimiter(@metrics[:reviewed]) %></div>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-3 mb-3">
    <div class="card review-metric-card h-100">
      <div class="card-body">
        <div class="review-metric-label">Porcentaje revisado</div>
        <div class="review-metric-value"><%= @metrics[:reviewed_percentage] %>%</div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-7 mb-4">
    <div class="card review-panel h-100">
      <div class="card-header bg-white">
        <h4 class="mb-0">Crear nuevo lote</h4>
      </div>
      <div class="card-body">
        <%= form_with url: black_coffee_reviews_path, method: :post, local: true do %>
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Categoria</label>
              <%= select_tag :category,
                             options_for_select([['Todas las categorias', '']] + @category_options, params[:category]),
                             class: 'form-control' %>
            </div>
            <div class="col-md-6 mb-3">
              <label class="font-weight-bold">Tamano del lote</label>
              <%= select_tag :batch_size,
                             options_for_select(@batch_sizes.map { |size| [size, size] } + [['Personalizado', 'custom']], params[:batch_size].presence || @default_batch_size),
                             class: 'form-control',
                             id: 'review-batch-size-select' %>
              <small class="text-muted">Por defecto revisamos 20 locales pendientes.</small>
            </div>
            <% custom_batch_selected = params[:batch_size].to_s == 'custom' %>
            <div class="col-md-6 mb-3" id="review-custom-size-wrapper" style="<%= custom_batch_selected ? '' : 'display: none;' %>">
              <label class="font-weight-bold">Tamano personalizado</label>
              <%= number_field_tag :custom_batch_size,
                                   params[:custom_batch_size].presence || @default_batch_size,
                                   min: 1,
                                   max: BlackCoffeeVenueReviewsController::MAX_CUSTOM_BATCH_SIZE,
                                   class: 'form-control',
                                   placeholder: 'Ej: 300' %>
              <small class="text-muted">Maximo <%= BlackCoffeeVenueReviewsController::MAX_CUSTOM_BATCH_SIZE %> para proteger el dashboard.</small>
            </div>
          </div>

          <%= submit_tag 'Cargar lote pendiente', class: 'btn btn-primary text-white' %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-5 mb-4">
    <div class="card review-panel h-100">
      <div class="card-header bg-white">
        <h4 class="mb-0">Motivos de rechazo</h4>
      </div>
      <div class="card-body">
        <% Venue::REJECTION_REASON_LABELS.each do |code, label| %>
          <div class="d-flex justify-content-between align-items-center border-bottom py-2">
            <div>
              <strong><%= label %></strong>
              <div class="text-muted small"><%= code %></div>
            </div>
            <span class="badge badge-light p-2"><%= number_with_delimiter(@reason_breakdown[code].to_i) %></span>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="card review-panel mb-4">
  <div class="card-header bg-white">
    <div class="d-flex flex-wrap justify-content-between align-items-center">
      <div class="review-status-heading">
        <h4 class="mb-1">Locales por estado de revision</h4>
        <p class="text-muted mb-0">Filtra pendientes, aprobados o rechazados y revisa motivo, reviewer y origen.</p>
      </div>
      <div class="review-status-tabs">
        <% status_tab_options = [
          ['Rechazados', Venue::REVIEW_STATUS_REJECTED, @metrics[:rejected], 'danger'],
          ['Aprobados', Venue::REVIEW_STATUS_APPROVED, @metrics[:approved], 'success'],
          ['Pendientes', Venue::REVIEW_STATUS_PENDING, @metrics[:pending], 'warning'],
          ['Todos', 'all', @metrics[:total], 'secondary']
        ] %>
        <% status_tab_options.each do |label, status, count, color| %>
          <% active = @review_filter_status == status %>
          <% tab_params = request.query_parameters.except('review_page').merge(review_status: status) %>
          <% tab_params = tab_params.except('review_reason') unless [Venue::REVIEW_STATUS_REJECTED, 'all'].include?(status) %>
          <%= link_to "#{label} · #{number_with_delimiter(count)}",
                      black_coffee_reviews_path(tab_params),
                      class: "btn btn-sm #{active ? "btn-#{color} text-white" : "btn-outline-#{color}"}" %>
        <% end %>
      </div>
    </div>
  </div>
  <div class="card-body">
    <%= form_with url: black_coffee_reviews_path, method: :get, local: true do %>
      <div class="row align-items-end">
        <div class="col-md-3 mb-3">
          <%= label_tag :review_status_select, 'Estado', class: 'font-weight-bold' %>
          <%= select_tag :review_status,
                         options_for_select(@review_status_options, @review_filter_status),
                         class: 'form-control',
                         id: 'review_status_select' %>
        </div>
        <div class="col-md-3 mb-3">
          <%= label_tag :review_category, 'Categoria', class: 'font-weight-bold' %>
          <%= select_tag :review_category,
                         options_for_select([['Todas las categorias', '']] + @category_options, @review_filter_category),
                         class: 'form-control' %>
        </div>
        <div class="col-md-3 mb-3">
          <%= label_tag :review_reason, 'Motivo rechazo', class: 'font-weight-bold' %>
          <%= select_tag :review_reason,
                         options_for_select([['Todos los motivos', '']] + @review_reason_options, @review_filter_reason),
                         class: 'form-control' %>
        </div>
        <div class="col-md-3 mb-3">
          <%= label_tag :review_q, 'Buscar local', class: 'font-weight-bold' %>
          <%= text_field_tag :review_q,
                             @review_filter_query,
                             class: 'form-control',
                             placeholder: 'Nombre, ciudad, direccion...' %>
        </div>
        <div class="col-md-12 mb-3">
          <%= submit_tag 'Aplicar filtros', class: 'btn btn-primary text-white mr-2' %>
          <%= link_to 'Limpiar filtros', black_coffee_reviews_path, class: 'btn btn-outline-secondary' %>
        </div>
      </div>
    <% end %>
  </div>
  <div class="table-responsive">
    <table class="table table-hover mb-0 review-venues-table">
      <thead>
        <tr>
          <th>Imagen</th>
          <th>Local</th>
          <th>Estado</th>
          <th>Motivo</th>
          <th>Categoria</th>
          <th>Origen</th>
          <th>Reviewer</th>
          <th>Fecha</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if @reviewed_venues.any? %>
          <% @reviewed_venues.each do |venue| %>
            <% cover_url = venue.cover_image_url(base_url: request.base_url) %>
            <% review_source = black_coffee_review_source_for(venue) %>
            <tr>
              <td data-label="Imagen">
                <% if cover_url.present? %>
                  <%= image_tag cover_url, class: 'review-venue-thumb', alt: venue.name %>
                <% else %>
                  <div class="review-venue-thumb-placeholder"><i class="fa fa-image"></i></div>
                <% end %>
              </td>
              <td data-label="Local">
                <div class="venue-title"><%= venue.name %></div>
                <div class="text-muted small"><%= [venue.city, venue.state].map(&:presence).compact.join(' · ') %></div>
                <div class="text-muted small">Favoritos: <%= number_with_delimiter(@favorite_counts_by_venue_id[venue.id].to_i) %></div>
                <% if venue.google_primary_type_for_dashboard.present? %>
                  <div class="text-muted small">Google: <%= venue.google_primary_type_for_dashboard %></div>
                <% end %>
              </td>
              <td data-label="Estado">
                <span class="badge badge-<%= venue.review_status_badge_class %> p-2"><%= venue.review_status_label %></span>
              </td>
              <td data-label="Motivo">
                <% if venue.review_rejection_reason.present? %>
                  <strong><%= venue.review_rejection_reason_label %></strong>
                  <% if venue.review_rejection_note.present? %>
                    <div class="text-muted small"><%= truncate(venue.review_rejection_note, length: 90) %></div>
                  <% end %>
                <% else %>
                  <span class="text-muted">Sin motivo</span>
                <% end %>
              </td>
              <td data-label="Categoria">
                <span class="badge badge-dark"><%= Venue.category_label_for(venue.category) %></span>
                <% if venue.subcategory_name.present? %>
                  <div class="text-muted small"><%= BlackCoffeeTaxonomy.label_for(venue.category, venue.subcategory_name) || venue.subcategory_name.humanize %></div>
                <% end %>
              </td>
              <td data-label="Origen">
                <% if review_source[:kind] == :batch %>
                  <%= link_to review_source[:label],
                              black_coffee_review_path(review_source[:batch]),
                              class: 'badge badge-info p-2 review-origin-badge' %>
                <% elsif review_source[:kind] == :manual %>
                  <span class="badge badge-info p-2 review-origin-badge"><%= review_source[:label] %></span>
                <% else %>
                  <span class="text-muted"><%= review_source[:label] %></span>
                <% end %>
              </td>
              <td data-label="Reviewer">
                <%= venue.reviewed_by&.name.presence || venue.reviewed_by&.email.presence || 'Sin reviewer' %>
              </td>
              <td data-label="Fecha">
                <%= venue.reviewed_at&.strftime('%d/%m/%Y %H:%M') || 'Sin fecha' %>
              </td>
              <td data-label="Acciones" class="text-right text-nowrap">
                <%= link_to 'Ver local', black_coffee_venue_path(venue), class: 'btn btn-sm btn-outline-primary mr-2' %>
                <% if venue.google_connected? %>
                  <%= link_to 'Google',
                              venue.google_maps_url,
                              class: 'btn btn-sm btn-outline-dark',
                              target: '_blank',
                              rel: 'noopener' %>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="text-center text-muted py-5">No hay locales que coincidan con estos filtros.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if @reviewed_venues.respond_to?(:total_pages) && @reviewed_venues.total_pages > 1 %>
    <div class="card-footer bg-white text-center">
      <%= will_paginate @reviewed_venues,
                        param_name: 'review_page',
                        previous_label: '← Anterior',
                        next_label: 'Siguiente →',
                        params: request.query_parameters.except('review_page') %>
    </div>
  <% end %>
</div>

<% if @open_batches.any? %>
  <div class="card review-panel mb-4">
    <div class="card-header bg-white">
      <h4 class="mb-0">Lotes abiertos</h4>
    </div>
    <div class="card-body">
      <% @open_batches.each do |batch| %>
        <div class="d-flex flex-wrap justify-content-between align-items-center border-bottom py-2">
          <div>
            <strong>Lote #<%= batch.id %></strong>
            <span class="text-muted ml-2"><%= batch.filters_summary %></span>
            <div class="text-muted small"><%= batch.total_places %> locales · creado <%= batch.created_at.strftime('%d/%m/%Y %H:%M') %></div>
          </div>
          <div class="review-batch-actions mt-2 mt-md-0">
            <%= link_to 'Continuar revision', black_coffee_review_path(batch), class: 'btn btn-sm btn-outline-primary mr-2' %>
            <button type="button"
                    class="btn btn-sm btn-outline-danger"
                    data-toggle="modal"
                    data-target="#deleteReviewBatch<%= batch.id %>">
              Borrar lote
            </button>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="card review-panel">
  <div class="card-header bg-white">
    <h4 class="mb-0">Historial de lotes</h4>
  </div>
  <div class="card-body table-responsive p-0">
    <table class="table table-hover mb-0 review-history-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Estado</th>
          <th>Filtros</th>
          <th>Locales</th>
          <th>Aprobados</th>
          <th>Rechazados</th>
          <th>Reviewer</th>
          <th>Fecha</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if @recent_batches.any? %>
          <% @recent_batches.each do |batch| %>
            <tr>
              <td data-label="#"><strong>#<%= batch.id %></strong></td>
              <td data-label="Estado"><span class="badge badge-<%= batch.status_badge_class %>"><%= batch.status_label %></span></td>
              <td data-label="Filtros"><%= batch.filters_summary %></td>
              <td data-label="Locales"><%= number_with_delimiter(batch.total_places) %></td>
              <td data-label="Aprobados" class="text-success"><%= number_with_delimiter(batch.approved_count) %></td>
              <td data-label="Rechazados" class="text-danger"><%= number_with_delimiter(batch.rejected_count) %></td>
              <td data-label="Reviewer"><%= batch.reviewed_by&.name.presence || batch.reviewed_by&.email.presence || 'Sin reviewer' %></td>
              <td data-label="Fecha"><%= (batch.reviewed_at || batch.created_at).strftime('%d/%m/%Y %H:%M') %></td>
              <td data-label="Acciones" class="text-right text-nowrap">
                <div class="review-batch-actions">
                  <%= link_to 'Ver lote', black_coffee_review_path(batch), class: 'btn btn-sm btn-outline-primary mr-2' %>
                  <button type="button"
                          class="btn btn-sm btn-outline-danger"
                          data-toggle="modal"
                          data-target="#deleteReviewBatch<%= batch.id %>">
                    Borrar
                  </button>
                </div>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="text-center text-muted py-5">Todavia no hay lotes de revision.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<% (@open_batches.to_a + @recent_batches.to_a).uniq.each do |batch| %>
  <div class="modal fade" id="deleteReviewBatch<%= batch.id %>" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header bg-danger text-white">
          <h5 class="modal-title">Borrar lote #<%= batch.id %> y deshacer revision</h5>
          <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
            <span aria-hidden="true">&times;</span>
          </button>
        </div>
        <div class="modal-body">
          <div class="review-delete-warning mb-3">
            <strong>Atencion:</strong> esta accion elimina el historial del lote y devuelve sus locales a
            <span class="badge badge-warning">pending</span>.
          </div>
          <p class="mb-2">Resumen de impacto:</p>
          <ul class="mb-0">
            <li><strong><%= number_with_delimiter(batch.total_places) %></strong> locales volveran a pendiente de revision.</li>
            <li><strong><%= number_with_delimiter(batch.approved_count) %></strong> aprobaciones se desharan.</li>
            <li><strong><%= number_with_delimiter(batch.rejected_count) %></strong> rechazos se desharan, incluyendo motivo y nota interna.</li>
            <li>Las categorias corregidas dentro del lote volveran a su valor anterior.</li>
            <li>Se borrara el lote #<%= batch.id %> del historial de revisiones.</li>
          </ul>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancelar</button>
          <%= link_to 'Si, borrar lote y deshacer',
                      black_coffee_review_path(batch),
                      method: :delete,
                      class: 'btn btn-danger text-white',
                      data: { confirm: 'Confirmacion final: se eliminara el lote y todos sus locales volveran a pendiente. Continuar?' } %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<script>
  (function() {
    function initializeReviewBatchSizeInput() {
    var select = document.getElementById('review-batch-size-select');
    var wrapper = document.getElementById('review-custom-size-wrapper');
    var input = wrapper ? wrapper.querySelector('input[name="custom_batch_size"]') : null;

    function toggleCustomSize() {
      if (!select || !wrapper) return;
      var customSelected = select.value === 'custom';
      wrapper.style.display = customSelected ? 'block' : 'none';
      if (input) input.disabled = !customSelected;
    }

    if (select) {
      if (select.getAttribute('data-custom-size-bound') === 'true') {
        toggleCustomSize();
        return;
      }
      select.setAttribute('data-custom-size-bound', 'true');
      select.addEventListener('change', toggleCustomSize);
      toggleCustomSize();
    }
    }

    document.addEventListener('DOMContentLoaded', initializeReviewBatchSizeInput);
    document.addEventListener('turbolinks:load', initializeReviewBatchSizeInput);
  })();
</script>
