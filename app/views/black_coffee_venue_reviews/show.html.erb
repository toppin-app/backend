<style>
  .review-summary-card {
    border: 0;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
  }

  .review-summary-card .card-body {
    padding: 28px 30px;
  }

  .review-summary-value {
    font-size: 42px;
    font-weight: 850;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .venue-review-card {
    border: 2px solid #e5e7eb;
    border-radius: 18px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .venue-review-card:hover {
    border-color: #cbd5e1;
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.1);
  }

  .venue-review-card.is-rejected {
    border-color: #ef4444;
    background: #fff7f7;
  }

  .venue-review-title {
    color: #1f2937;
    font-size: 22px;
    font-weight: 700;
  }

  .venue-review-label {
    color: #64748b;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .venue-review-pill {
    border-radius: 999px;
    display: inline-flex;
    font-size: 12px;
    font-weight: 700;
    margin: 0 6px 6px 0;
    padding: 6px 9px;
  }

  .venue-review-photos {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .venue-review-photo {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    cursor: zoom-in;
    height: 180px;
    object-fit: cover;
    width: 240px;
  }

  .venue-review-empty-photo {
    align-items: center;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 12px;
    color: #64748b;
    display: flex;
    height: 180px;
    justify-content: center;
    width: 240px;
  }

  .rejection-button {
    font-weight: 700;
    margin: 0 8px 8px 0;
  }

  .review-status-chip {
    border-radius: 999px;
    font-weight: 800;
    padding: 8px 12px;
  }

  .review-finalize-panel {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-left: 6px solid #343a40;
    border-radius: 22px;
    box-shadow: 0 14px 32px rgba(33, 37, 41, 0.12);
    color: #212529;
    margin-bottom: 32px;
    padding: 38px 32px;
  }

  .review-finalize-title {
    font-size: 28px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .review-finalize-panel .btn {
    border-radius: 14px;
    font-size: 18px;
    font-weight: 800;
    padding: 18px 28px;
  }

  .review-finalize-counter {
    background: white;
    border: 1px solid #ced4da;
    border-radius: 14px;
    color: #343a40;
    display: inline-flex;
    font-size: 17px;
    font-weight: 800;
    margin: 12px 8px 0 0;
    padding: 12px 15px;
  }

  .review-finalize-panel .small {
    color: #6c757d;
  }

  @media (max-width: 767px) {
    .venue-review-photo,
    .venue-review-empty-photo {
      height: 150px;
      width: 100%;
    }
  }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Revision de locales</p>
    <h2 class="mb-0">Lote #<%= @batch.id %></h2>
    <p class="text-muted mb-0"><%= @batch.filters_summary %> · <%= @batch.total_places %> locales cargados</p>
  </div>
  <div class="mt-3 mt-md-0">
    <%= link_to 'Volver a revision', black_coffee_reviews_path, class: 'btn btn-outline-secondary mr-2' %>
    <button type="button"
            class="btn btn-outline-danger mr-2"
            data-toggle="modal"
            data-target="#deleteReviewBatch<%= @batch.id %>">
      Borrar lote
    </button>
    <%= link_to 'Locales', black_coffee_venues_path, class: 'btn btn-outline-dark' %>
  </div>
</div>

<div class="card review-summary-card mb-4">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col-md-3 mb-3 mb-md-0">
        <div class="venue-review-label">Estado del lote</div>
        <span class="badge badge-<%= @batch.status_badge_class %> p-2"><%= @batch.status_label %></span>
      </div>
      <div class="col-md-3 mb-3 mb-md-0">
        <div class="venue-review-label">Locales del lote</div>
        <div class="review-summary-value mb-0"><%= number_with_delimiter(@items.size) %></div>
      </div>
      <div class="col-md-3 mb-3 mb-md-0">
        <div class="venue-review-label">Aprobados</div>
        <div class="review-summary-value mb-0 text-success" id="review-approved-count"><%= @batch.completed? ? @batch.approved_count : @items.size %></div>
      </div>
      <div class="col-md-3 mb-3 mb-md-0">
        <div class="venue-review-label">Rechazados</div>
        <div class="review-summary-value mb-0 text-danger" id="review-rejected-count"><%= @batch.completed? ? @batch.rejected_count : 0 %></div>
      </div>
    </div>
  </div>
</div>

<% if @batch.completed? %>
  <div class="alert alert-success">
    Este lote ya fue finalizado el <%= @batch.reviewed_at&.strftime('%d/%m/%Y %H:%M') || 'sin fecha guardada' %>.
    Los estados de cada local se muestran solo como consulta historica.
  </div>
<% else %>
  <div class="alert alert-info">
    Marca como rechazados solo los locales que no deben salir en Black Coffee. Al finalizar, todos los demas locales de este lote se aprobaran automaticamente.
  </div>
<% end %>

<%= form_with url: complete_black_coffee_review_path(@batch), method: :post, local: true, id: 'black-coffee-review-form' do %>
  <% @items.each do |item| %>
    <% venue = item.venue %>
    <% next unless venue %>
    <% image_urls = venue.image_urls(base_url: request.base_url) %>
    <% already_rejected = item.rejected? %>

    <div class="card venue-review-card mb-4 <%= 'is-rejected' if already_rejected %>"
         data-review-card
         data-venue-id="<%= venue.id %>">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start mb-3">
          <div class="pr-md-4">
            <div class="venue-review-title"><%= venue.name %></div>
            <div class="text-muted"><%= venue.address.presence || 'Sin direccion' %></div>
            <div class="text-muted small">
              <%= venue.city.presence || 'Sin ciudad' %>
              · <%= venue.state.presence || 'Sin region' %>
              · <%= venue.country.presence || 'Sin pais' %>
            </div>
          </div>
          <div class="mt-3 mt-md-0 text-md-right">
            <% status_label = already_rejected ? "Rechazado: #{item.rejection_reason_label}" : 'Pendiente en este lote' %>
            <span class="badge <%= already_rejected ? 'badge-danger' : 'badge-warning' %> review-status-chip" data-review-status>
              <%= status_label %>
            </span>
            <div class="small text-muted mt-2">ID: <%= venue.id %></div>
          </div>
        </div>

        <div class="row">
          <div class="col-lg-7">
            <div class="mb-3">
              <div class="venue-review-label">Descripcion</div>
              <p class="mb-0"><%= venue.description.presence || 'Sin descripcion guardada.' %></p>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <div class="venue-review-label">Categoria interna</div>
                <span class="badge badge-secondary p-2"><%= venue.category %></span>
              </div>
              <div class="col-md-6 mb-3">
                <div class="venue-review-label">Subcategoria</div>
                <strong><%= BlackCoffeeTaxonomy.label_for(venue.category, venue.subcategory_name).presence || 'Sin subcategoria' %></strong>
                <% if venue.subcategory_name.present? %>
                  <div class="text-muted small"><%= venue.subcategory_name %></div>
                <% end %>
              </div>
              <div class="col-md-6 mb-3">
                <div class="venue-review-label">Google primary type</div>
                <% if venue.google_primary_type_for_dashboard.present? %>
                  <span class="badge badge-primary p-2"><%= venue.google_primary_type_for_dashboard %></span>
                <% else %>
                  <span class="text-muted">Sin primary type</span>
                <% end %>
              </div>
              <div class="col-md-6 mb-3">
                <div class="venue-review-label">Ubicacion</div>
                <strong><%= venue.city.presence || 'Sin ciudad' %></strong>
                <div class="text-muted small"><%= venue.state.presence || 'Sin region' %> · <%= venue.country.presence || 'Sin pais' %></div>
              </div>
            </div>

            <div class="mb-3">
              <div class="venue-review-label">Tipos secundarios / etiquetas Google</div>
              <% secondary_types = venue.google_secondary_type_list %>
              <% if secondary_types.any? %>
                <% secondary_types.each do |tag| %>
                  <span class="badge badge-dark venue-review-pill"><%= tag %></span>
                <% end %>
              <% elsif Array(venue.tags).any? %>
                <% Array(venue.tags).each do |tag| %>
                  <span class="badge badge-dark venue-review-pill"><%= tag %></span>
                <% end %>
              <% else %>
                <span class="text-muted">Sin etiquetas Google guardadas.</span>
              <% end %>
            </div>
          </div>

          <div class="col-lg-5">
            <div class="venue-review-label mb-2">Imagenes disponibles</div>
            <div class="venue-review-photos">
              <% if image_urls.any? %>
                <% image_urls.each do |image_url| %>
                  <%= image_tag image_url,
                                class: 'venue-review-photo',
                                data: { review_image: true, full_src: image_url },
                                alt: venue.name %>
                <% end %>
              <% else %>
                <div class="venue-review-empty-photo">
                  <i class="fas fa-image mr-2"></i> Sin imagenes
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <hr>

        <% if @batch.completed? %>
          <div class="d-flex flex-wrap align-items-center">
            <strong class="mr-2">Resultado:</strong>
            <span class="badge badge-<%= item.rejected? ? 'danger' : 'success' %> p-2">
              <%= item.review_status_label %>
            </span>
            <% if item.rejected? %>
              <span class="text-muted ml-2"><%= item.rejection_reason_label %></span>
              <% if item.review_rejection_note.present? %>
                <span class="text-muted ml-2">Nota: <%= item.review_rejection_note %></span>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <input type="hidden"
                 name="rejections[<%= venue.id %>][reason]"
                 value="<%= item.review_rejection_reason %>"
                 data-reason-input>

          <div class="mb-3">
            <div class="venue-review-label mb-2">Rechazar este local</div>
            <% @reason_labels.each do |code, label| %>
              <button type="button"
                      class="btn btn-outline-danger rejection-button <%= 'active' if item.review_rejection_reason == code %>"
                      data-rejection-reason="<%= code %>"
                      data-rejection-label="<%= label %>">
                <%= label %>
              </button>
            <% end %>
            <button type="button" class="btn btn-outline-secondary rejection-button" data-review-undo>
              Deshacer rechazo
            </button>
          </div>

          <div class="form-group mb-0" data-note-wrapper style="<%= item.review_rejection_reason == 'other' ? '' : 'display: none;' %>">
            <label class="font-weight-bold">Nota interna opcional</label>
            <textarea name="rejections[<%= venue.id %>][note]"
                      class="form-control"
                      rows="2"
                      data-note-input
                      placeholder="Solo visible en dashboard/admin"><%= item.review_rejection_note %></textarea>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% unless @batch.completed? %>
    <div class="sticky-bottom review-finalize-panel">
      <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div>
          <div class="review-finalize-title">Finalizar revision del lote</div>
          <div>Al pulsar aqui, todo lo no rechazado quedara aprobado para Black Coffee.</div>
          <span class="review-finalize-counter">
            <span id="review-live-rejected">0</span>&nbsp;rechazados
          </span>
          <span class="review-finalize-counter">
            <span id="review-live-approved"><%= @items.size %></span>&nbsp;aprobados automaticamente
          </span>
          <div class="small mt-2" style="opacity: 0.85;">Solo se actualizaran los <%= @items.size %> locales cargados en este lote.</div>
        </div>
        <%= submit_tag 'Finalizar revision y aprobar el resto',
                       class: 'btn btn-dark mt-4 mt-md-0',
                       data: { confirm: 'Se aprobaran automaticamente todos los locales no rechazados de este lote. Continuar?' } %>
      </div>
    </div>
  <% end %>
<% end %>

<div class="modal fade" id="deleteReviewBatch<%= @batch.id %>" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">Borrar lote #<%= @batch.id %> y deshacer revision</h5>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="alert alert-warning">
          Esta accion elimina el historial del lote y devuelve sus locales a <strong>pending</strong>.
        </div>
        <p class="mb-2">Resumen de impacto:</p>
        <ul class="mb-0">
          <li><strong><%= number_with_delimiter(@batch.total_places) %></strong> locales volveran a pendiente de revision.</li>
          <li><strong><%= number_with_delimiter(@batch.approved_count) %></strong> aprobaciones se desharan.</li>
          <li><strong><%= number_with_delimiter(@batch.rejected_count) %></strong> rechazos se desharan, incluyendo motivo y nota interna.</li>
          <li>Se borrara el lote #<%= @batch.id %> del historial de revisiones.</li>
        </ul>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancelar</button>
        <%= link_to 'Si, borrar lote y deshacer',
                    black_coffee_review_path(@batch),
                    method: :delete,
                    class: 'btn btn-danger text-white',
                    data: { confirm: 'Confirmacion final: se eliminara el lote y todos sus locales volveran a pendiente. Continuar?' } %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="reviewImageModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Imagen del local</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body text-center">
        <img id="reviewImageModalImg" src="" alt="Imagen del local" class="img-fluid rounded">
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var cards = Array.prototype.slice.call(document.querySelectorAll('[data-review-card]'));
    var rejectedCounter = document.getElementById('review-live-rejected');
    var approvedCounter = document.getElementById('review-live-approved');
    var rejectedSummary = document.getElementById('review-rejected-count');
    var approvedSummary = document.getElementById('review-approved-count');

    function updateCounters() {
      if (!rejectedCounter || !approvedCounter) return;

      var rejectedCount = cards.filter(function(card) {
        var input = card.querySelector('[data-reason-input]');
        return input && input.value;
      }).length;
      var approvedCount = cards.length - rejectedCount;

      if (rejectedCounter) rejectedCounter.textContent = rejectedCount;
      if (approvedCounter) approvedCounter.textContent = approvedCount;
      if (rejectedSummary) rejectedSummary.textContent = rejectedCount;
      if (approvedSummary) approvedSummary.textContent = approvedCount;
    }

    cards.forEach(function(card) {
      var reasonInput = card.querySelector('[data-reason-input]');
      var noteInput = card.querySelector('[data-note-input]');
      var noteWrapper = card.querySelector('[data-note-wrapper]');
      var status = card.querySelector('[data-review-status]');
      var buttons = Array.prototype.slice.call(card.querySelectorAll('[data-rejection-reason]'));
      var undoButton = card.querySelector('[data-review-undo]');

      function setReason(reason, label) {
        if (!reasonInput) return;

        reasonInput.value = reason;
        card.classList.add('is-rejected');
        if (status) {
          status.classList.remove('badge-warning');
          status.classList.add('badge-danger');
          status.textContent = 'Rechazado: ' + label;
        }
        buttons.forEach(function(button) {
          button.classList.toggle('active', button.getAttribute('data-rejection-reason') === reason);
        });
        if (noteWrapper) {
          noteWrapper.style.display = reason === 'other' ? 'block' : 'none';
        }
        if (reason !== 'other' && noteInput) {
          noteInput.value = '';
        }
        updateCounters();
      }

      function clearReason() {
        if (!reasonInput) return;

        reasonInput.value = '';
        card.classList.remove('is-rejected');
        if (status) {
          status.classList.remove('badge-danger');
          status.classList.add('badge-warning');
          status.textContent = 'Pendiente en este lote';
        }
        buttons.forEach(function(button) {
          button.classList.remove('active');
        });
        if (noteWrapper) {
          noteWrapper.style.display = 'none';
        }
        if (noteInput) {
          noteInput.value = '';
        }
        updateCounters();
      }

      buttons.forEach(function(button) {
        button.addEventListener('click', function() {
          setReason(button.getAttribute('data-rejection-reason'), button.getAttribute('data-rejection-label'));
        });
      });

      if (undoButton) {
        undoButton.addEventListener('click', clearReason);
      }
    });

    Array.prototype.slice.call(document.querySelectorAll('[data-review-image]')).forEach(function(image) {
      image.addEventListener('click', function() {
        var modalImage = document.getElementById('reviewImageModalImg');
        if (modalImage) {
          modalImage.src = image.getAttribute('data-full-src') || image.src;
        }

        if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
          window.jQuery('#reviewImageModal').modal('show');
        }
      });
    });

    updateCounters();
  });
</script>
