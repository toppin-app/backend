<style>
  .review-summary-card {
    border: 0;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
  }

  .review-summary-card .card-body {
    padding: 28px 30px;
  }

  .review-summary-value {
    font-size: 42px;
    font-weight: 850;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .venue-review-card {
    border: 2px solid #e5e7eb;
    border-radius: 18px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.06);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .venue-review-card:hover {
    border-color: #cbd5e1;
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.1);
  }

  .venue-review-card.is-rejected {
    border-color: #ef4444;
    background: #fff7f7;
  }

  .venue-review-card.is-corrected {
    border-color: #198754;
    background: #f3fff7;
  }

  .venue-review-title {
    color: #1f2937;
    font-size: 22px;
    font-weight: 700;
  }

  .venue-review-label {
    color: #64748b;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .venue-review-pill {
    border-radius: 999px;
    display: inline-flex;
    font-size: 12px;
    font-weight: 700;
    margin: 0 6px 6px 0;
    max-width: 100%;
    overflow: hidden;
    padding: 6px 9px;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .venue-review-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .venue-review-photos {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .venue-review-photo {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    cursor: zoom-in;
    height: 180px;
    object-fit: cover;
    width: 240px;
  }

  .venue-review-empty-photo {
    align-items: center;
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 12px;
    color: #64748b;
    display: flex;
    height: 180px;
    justify-content: center;
    width: 240px;
  }

  .rejection-button {
    align-items: center;
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    line-height: 1.15;
    margin: 0 8px 8px 0;
    text-align: center;
    white-space: normal;
  }

  .review-rejection-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .review-status-chip {
    border-radius: 999px;
    font-weight: 800;
    padding: 8px 12px;
  }

  .review-finalize-panel {
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    border-left: 6px solid #343a40;
    border-radius: 22px;
    box-shadow: 0 14px 32px rgba(33, 37, 41, 0.12);
    color: #212529;
    margin-bottom: 32px;
    padding: 38px 32px;
  }

  .review-finalize-title {
    font-size: 28px;
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 8px;
  }

  .review-finalize-panel .btn {
    align-items: center;
    border-radius: 14px;
    display: inline-flex;
    font-size: 18px;
    font-weight: 800;
    justify-content: center;
    line-height: 1.15;
    padding: 18px 28px;
    text-align: center;
  }

  .review-finalize-counter {
    background: white;
    border: 1px solid #ced4da;
    border-radius: 14px;
    color: #343a40;
    display: inline-flex;
    font-size: 17px;
    font-weight: 800;
    margin: 12px 8px 0 0;
    padding: 12px 15px;
  }

  .review-finalize-panel .small {
    color: #6c757d;
  }

  .review-lot-header {
    gap: 16px;
  }

  .review-lot-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  .review-lot-actions .btn {
    align-items: center;
    display: inline-flex;
    justify-content: center;
    line-height: 1.15;
    margin: 0 !important;
    text-align: center;
  }

  .review-google-link {
    align-items: center;
    display: inline-flex;
    font-weight: 800;
    gap: 6px;
    justify-content: center;
    line-height: 1.15;
    text-align: center;
  }

  .review-image-tools {
    border: 1px solid #f1c2c7;
    border-left: 6px solid #dc3545;
    border-radius: 16px;
  }

  .category-correction-panel {
    background: #f8fafc;
    border: 1px solid #dbe3ef;
    border-radius: 14px;
    padding: 14px;
  }

  .venue-review-description {
    margin-bottom: 0;
  }

  .review-modal-image-stage {
    align-items: center;
    background: #111827;
    border-radius: 14px;
    display: flex;
    justify-content: center;
    min-height: 280px;
    overflow: hidden;
    position: relative;
  }

  .review-modal-image-stage img {
    max-height: 72vh;
    object-fit: contain;
    width: auto;
  }

  .review-modal-nav {
    align-items: center;
    border-radius: 999px;
    display: inline-flex;
    height: 44px;
    justify-content: center;
    opacity: 0.92;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    z-index: 2;
  }

  .review-modal-prev {
    left: 16px;
  }

  .review-modal-next {
    right: 16px;
  }

  .review-modal-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .review-modal-thumb {
    border: 2px solid transparent;
    border-radius: 10px;
    cursor: pointer;
    flex: 0 0 76px;
    height: 58px;
    object-fit: cover;
    opacity: 0.72;
    width: 76px;
  }

  .review-modal-thumb.is-active {
    border-color: #007bff;
    opacity: 1;
  }

  @media (max-width: 767px) {
    .review-lot-header {
      align-items: stretch !important;
      flex-direction: column;
    }

    .review-lot-header h2 {
      font-size: 26px;
      line-height: 1.15;
    }

    .review-lot-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .review-lot-actions .btn {
      min-height: 44px;
      width: 100%;
    }

    .review-summary-card .card-body {
      padding: 12px 14px;
    }

    .review-summary-value {
      font-size: 26px;
    }

    .venue-review-card {
      border-radius: 16px;
      margin-bottom: 14px !important;
    }

    .venue-review-card .card-body {
      padding: 12px;
    }

    .venue-review-title {
      font-size: 18px;
      line-height: 1.2;
    }

    .venue-review-card .mb-3 {
      margin-bottom: 0.6rem !important;
    }

    .venue-review-card hr {
      margin-bottom: 0.75rem;
      margin-top: 0.75rem;
    }

    .venue-review-label {
      font-size: 10px;
    }

    .venue-review-description {
      display: -webkit-box;
      font-size: 13px;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .venue-review-photos-column {
      order: -1;
      margin-bottom: 10px;
    }

    .venue-review-photos {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .venue-review-photo,
    .venue-review-empty-photo {
      height: 88px;
      width: 100%;
    }

    .venue-review-empty-photo {
      grid-column: 1 / -1;
    }

    .venue-review-pill {
      font-size: 10px;
      margin: 0;
      padding: 4px 7px;
    }

    .venue-review-tag-list {
      max-height: 46px;
      overflow: hidden;
    }

    .review-google-link {
      font-size: 12px;
      min-height: 36px;
      padding: 8px 10px;
      width: 100%;
    }

    .review-rejection-actions {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .rejection-button {
      font-size: 12px;
      margin: 0;
      min-height: 40px;
      padding: 8px 6px;
      width: 100%;
    }

    .rejection-button[data-review-undo] {
      grid-column: 1 / -1;
    }

    .review-finalize-panel {
      border-left-width: 0;
      border-top: 6px solid #343a40;
      margin-left: -5px;
      margin-right: -5px;
      padding: 24px 18px;
      position: static !important;
    }

    .review-finalize-title {
      font-size: 24px;
    }

    .review-finalize-counter {
      display: flex;
      justify-content: center;
      margin-right: 0;
      width: 100%;
    }

    .review-finalize-panel .btn {
      font-size: 16px;
      min-height: 54px;
      width: 100%;
    }

    .review-modal-image-stage {
      min-height: 220px;
    }

    .review-modal-nav {
      height: 38px;
      width: 38px;
    }

    .review-modal-prev {
      left: 8px;
    }

    .review-modal-next {
      right: 8px;
    }
  }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4 review-lot-header">
  <div>
    <p class="text-muted mb-1">Black Coffee / Revision de locales</p>
    <h2 class="mb-0">Lote #<%= @batch.id %></h2>
    <p class="text-muted mb-0"><%= @batch.filters_summary %> · <%= @batch.total_places %> locales cargados</p>
  </div>
  <div class="review-lot-actions mt-3 mt-md-0">
    <%= link_to 'Volver a revision', black_coffee_reviews_path, class: 'btn btn-outline-secondary mr-2' %>
    <button type="button"
            class="btn btn-outline-danger mr-2"
            data-toggle="modal"
            data-target="#deleteReviewBatch<%= @batch.id %>">
      Borrar lote
    </button>
    <%= link_to 'Locales', black_coffee_venues_path, class: 'btn btn-outline-dark' %>
  </div>
</div>

<div class="card review-summary-card mb-4">
  <div class="card-body">
    <div class="row align-items-center">
      <div class="col-6 col-md-3 mb-3 mb-md-0">
        <div class="venue-review-label">Estado del lote</div>
        <span class="badge badge-<%= @batch.status_badge_class %> p-2"><%= @batch.status_label %></span>
      </div>
      <div class="col-6 col-md-3 mb-3 mb-md-0">
        <div class="venue-review-label">Locales del lote</div>
        <div class="review-summary-value mb-0"><%= number_with_delimiter(@items.size) %></div>
      </div>
      <div class="col-6 col-md-3 mb-3 mb-md-0">
        <div class="venue-review-label">Aprobados</div>
        <div class="review-summary-value mb-0 text-success" id="review-approved-count"><%= @batch.completed? ? @batch.approved_count : @items.size %></div>
      </div>
      <div class="col-6 col-md-3 mb-3 mb-md-0">
        <div class="venue-review-label">Rechazados</div>
        <div class="review-summary-value mb-0 text-danger" id="review-rejected-count"><%= @batch.completed? ? @batch.rejected_count : 0 %></div>
      </div>
    </div>
  </div>
</div>

<% if @batch.completed? %>
  <div class="alert alert-success">
    Este lote ya fue finalizado el <%= @batch.reviewed_at&.strftime('%d/%m/%Y %H:%M') || 'sin fecha guardada' %>.
    Los estados de cada local se muestran solo como consulta historica.
  </div>
<% else %>
  <div class="alert alert-info">
    Marca como rechazados solo los locales que no deben salir en Black Coffee. Al finalizar, todos los demas locales de este lote se aprobaran automaticamente.
  </div>

  <div class="card review-image-tools mb-4">
    <div class="card-body d-flex flex-wrap justify-content-between align-items-center">
      <div class="mr-md-3 mb-3 mb-md-0">
        <strong>Revision rapida de imagenes con problemas</strong>
        <div class="text-muted small">
          Si alguna miniatura falla al cargar, puedes marcar esos locales como
          <strong>Fotos incorrectas o muy malas</strong> en un solo paso.
        </div>
        <div class="small mt-1" data-broken-images-summary>Buscando imagenes con error...</div>
      </div>
      <button type="button"
              class="btn btn-outline-danger font-weight-bold"
              data-mark-broken-images>
        Marcar imagenes con problemas como rechazo por fotos
      </button>
    </div>
  </div>
<% end %>

<%= form_with url: complete_black_coffee_review_path(@batch), method: :post, local: true, id: 'black-coffee-review-form' do %>
  <% @items.each do |item| %>
    <% venue = item.venue %>
    <% next unless venue %>
    <% image_urls = venue.image_urls(base_url: request.base_url) %>
    <% already_rejected = item.rejected? %>

    <div class="card venue-review-card mb-4 <%= 'is-rejected' if already_rejected %>"
         data-review-card
         data-venue-id="<%= venue.id %>">
      <div class="card-body">
        <div class="d-flex flex-wrap justify-content-between align-items-start mb-3">
          <div class="pr-md-4">
            <div class="venue-review-title"><%= venue.name %></div>
            <div class="text-muted"><%= venue.address.presence || 'Sin direccion' %></div>
            <div class="text-muted small">
              <%= venue.city.presence || 'Sin ciudad' %>
              · <%= venue.state.presence || 'Sin region' %>
              · <%= venue.country.presence || 'Sin pais' %>
            </div>
          </div>
          <div class="mt-3 mt-md-0 text-md-right">
            <% status_label = already_rejected ? "Rechazado: #{item.rejection_reason_label}" : 'Pendiente en este lote' %>
            <span class="badge <%= already_rejected ? 'badge-danger' : 'badge-warning' %> review-status-chip" data-review-status>
              <%= status_label %>
            </span>
            <div class="small text-muted mt-2">ID: <%= venue.id %></div>
            <% if venue.google_connected? %>
              <%= link_to venue.google_maps_url,
                          class: 'btn btn-sm btn-outline-dark review-google-link mt-2',
                          target: '_blank',
                          rel: 'noopener' do %>
                <i class="fas fa-map-marked-alt"></i>
                <span>Ver en Google</span>
              <% end %>
            <% end %>
          </div>
        </div>

        <div class="row">
          <div class="col-lg-7 venue-review-details-column">
            <div class="mb-3">
              <div class="venue-review-label">Descripcion</div>
              <p class="venue-review-description"><%= venue.description.presence || 'Sin descripcion guardada.' %></p>
            </div>

            <div class="row">
              <div class="col-6 col-md-6 mb-3">
                <div class="venue-review-label">Categoria interna</div>
                <span class="badge badge-secondary p-2"><%= venue.category %></span>
              </div>
              <div class="col-6 col-md-6 mb-3">
                <div class="venue-review-label">Subcategoria</div>
                <strong><%= BlackCoffeeTaxonomy.label_for(venue.category, venue.subcategory_name).presence || 'Sin subcategoria' %></strong>
                <% if venue.subcategory_name.present? %>
                  <div class="text-muted small"><%= venue.subcategory_name %></div>
                <% end %>
              </div>
              <div class="col-6 col-md-6 mb-3">
                <div class="venue-review-label">Google primary type</div>
                <% if venue.google_primary_type_for_dashboard.present? %>
                  <span class="badge badge-primary p-2"><%= venue.google_primary_type_for_dashboard %></span>
                <% else %>
                  <span class="text-muted">Sin primary type</span>
                <% end %>
              </div>
              <div class="col-6 col-md-6 mb-3">
                <div class="venue-review-label">Ubicacion</div>
                <strong><%= venue.city.presence || 'Sin ciudad' %></strong>
                <div class="text-muted small"><%= venue.state.presence || 'Sin region' %> · <%= venue.country.presence || 'Sin pais' %></div>
              </div>
            </div>

            <div class="mb-3">
              <div class="venue-review-label">Tipos secundarios / etiquetas Google</div>
              <% secondary_types = venue.google_secondary_type_list %>
              <div class="venue-review-tag-list">
                <% if secondary_types.any? %>
                  <% secondary_types.each do |tag| %>
                    <span class="badge badge-dark venue-review-pill"><%= tag %></span>
                  <% end %>
                <% elsif Array(venue.tags).any? %>
                  <% Array(venue.tags).each do |tag| %>
                    <span class="badge badge-dark venue-review-pill"><%= tag %></span>
                  <% end %>
                <% else %>
                  <span class="text-muted">Sin etiquetas Google guardadas.</span>
                <% end %>
              </div>
            </div>
          </div>

          <div class="col-lg-5 venue-review-photos-column">
            <div class="venue-review-label mb-2">Imagenes disponibles</div>
            <div class="venue-review-photos">
              <% if image_urls.any? %>
                <% image_urls.each do |image_url| %>
                  <%= image_tag image_url,
                                class: 'venue-review-photo',
                                data: { review_image: true, full_src: image_url, image_title: venue.name },
                                alt: venue.name %>
                <% end %>
              <% else %>
                <div class="venue-review-empty-photo">
                  <i class="fas fa-image mr-2"></i> Sin imagenes
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <hr>

        <% if @batch.completed? %>
          <div class="d-flex flex-wrap align-items-center">
            <strong class="mr-2">Resultado:</strong>
            <span class="badge badge-<%= item.rejected? ? 'danger' : 'success' %> p-2">
              <%= item.review_status_label %>
            </span>
            <% if item.rejected? %>
              <span class="text-muted ml-2"><%= item.rejection_reason_label %></span>
              <% if item.review_rejection_note.present? %>
                <span class="text-muted ml-2">Nota: <%= item.review_rejection_note %></span>
              <% end %>
            <% elsif item.category_corrected? %>
              <span class="text-muted ml-2">
                Categoria corregida:
                <strong><%= item.category_correction_from %></strong>
                a
                <strong><%= item.category_correction_to %></strong>
              </span>
            <% end %>
          </div>
        <% else %>
          <input type="hidden"
                 name="rejections[<%= venue.id %>][reason]"
                 value="<%= item.review_rejection_reason %>"
                 data-reason-input>
          <input type="hidden"
                 name="rejections[<%= venue.id %>][correct_category]"
                 value="0"
                 data-correct-category-hidden>

          <div class="mb-3">
            <div class="venue-review-label mb-2">Rechazar este local</div>
            <div class="review-rejection-actions">
              <% @reason_labels.each do |code, label| %>
                <button type="button"
                        class="btn btn-outline-danger rejection-button <%= 'active' if item.review_rejection_reason == code %>"
                        data-rejection-reason="<%= code %>"
                        data-rejection-label="<%= label %>">
                  <%= label %>
                </button>
              <% end %>
              <button type="button" class="btn btn-outline-secondary rejection-button" data-review-undo>
                Deshacer rechazo
              </button>
            </div>
          </div>

          <div class="category-correction-panel mb-3"
               data-category-correction-wrapper
               style="<%= item.review_rejection_reason == 'wrong_category' ? '' : 'display: none;' %>">
            <div class="custom-control custom-checkbox mb-3">
              <input type="checkbox"
                     class="custom-control-input"
                     id="correctCategory<%= venue.id %>"
                     data-correct-category-toggle>
              <label class="custom-control-label font-weight-bold" for="correctCategory<%= venue.id %>">
                Corregir categoria y aprobar este local en lugar de rechazarlo
              </label>
            </div>
            <label class="font-weight-bold">Nueva categoria correcta</label>
            <%= select_tag "rejections[#{venue.id}][corrected_category]",
                           options_for_select([['Selecciona categoria correcta', '']] + @category_options.select { |_label, value| Venue::CATEGORIES.include?(value) }.reject { |_label, value| value == venue.category }),
                           class: 'form-control',
                           disabled: true,
                           data: { corrected_category_select: true } %>
            <small class="text-muted">
              Si activas esta opcion, el local quedara aprobado y cambiaremos su categoria interna.
            </small>
          </div>

          <div class="form-group mb-0" data-note-wrapper style="<%= item.review_rejection_reason == 'other' ? '' : 'display: none;' %>">
            <label class="font-weight-bold">Nota interna opcional</label>
            <textarea name="rejections[<%= venue.id %>][note]"
                      class="form-control"
                      rows="2"
                      data-note-input
                      placeholder="Solo visible en dashboard/admin"><%= item.review_rejection_note %></textarea>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% unless @batch.completed? %>
    <div class="sticky-bottom review-finalize-panel">
      <div class="d-flex flex-wrap justify-content-between align-items-center">
        <div>
          <div class="review-finalize-title">Finalizar revision del lote</div>
          <div>Al pulsar aqui, todo lo no rechazado quedara aprobado para Black Coffee.</div>
          <span class="review-finalize-counter">
            <span id="review-live-rejected">0</span>&nbsp;rechazados
          </span>
          <span class="review-finalize-counter">
            <span id="review-live-approved"><%= @items.size %></span>&nbsp;aprobados automaticamente
          </span>
          <div class="small mt-2" style="opacity: 0.85;">Solo se actualizaran los <%= @items.size %> locales cargados en este lote.</div>
        </div>
        <%= submit_tag 'Finalizar revision y aprobar el resto',
                       class: 'btn btn-dark mt-4 mt-md-0',
                       data: { confirm: 'Se aprobaran automaticamente todos los locales no rechazados de este lote. Continuar?' } %>
      </div>
    </div>
  <% end %>
<% end %>

<div class="modal fade" id="deleteReviewBatch<%= @batch.id %>" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title">Borrar lote #<%= @batch.id %> y deshacer revision</h5>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Cerrar">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="alert alert-warning">
          Esta accion elimina el historial del lote y devuelve sus locales a <strong>pending</strong>.
        </div>
        <p class="mb-2">Resumen de impacto:</p>
        <ul class="mb-0">
          <li><strong><%= number_with_delimiter(@batch.total_places) %></strong> locales volveran a pendiente de revision.</li>
          <li><strong><%= number_with_delimiter(@batch.approved_count) %></strong> aprobaciones se desharan.</li>
          <li><strong><%= number_with_delimiter(@batch.rejected_count) %></strong> rechazos se desharan, incluyendo motivo y nota interna.</li>
          <li>Las categorias corregidas dentro de este lote volveran a su valor anterior.</li>
          <li>Se borrara el lote #<%= @batch.id %> del historial de revisiones.</li>
        </ul>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancelar</button>
        <%= link_to 'Si, borrar lote y deshacer',
                    black_coffee_review_path(@batch),
                    method: :delete,
                    class: 'btn btn-danger text-white',
                    data: { confirm: 'Confirmacion final: se eliminara el lote y todos sus locales volveran a pendiente. Continuar?' } %>
      </div>
    </div>
  </div>
</div>

<div class="modal fade review-image-modal" id="reviewImageModal" tabindex="-1" role="dialog" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <div>
          <h5 class="modal-title mb-0" id="reviewImageModalTitle">Imagen del local</h5>
          <div class="text-muted small" id="reviewImageModalCounter"></div>
        </div>
        <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="review-modal-image-stage">
          <button type="button" class="btn btn-light review-modal-nav review-modal-prev" data-review-modal-prev aria-label="Imagen anterior">
            <i class="fas fa-chevron-left"></i>
          </button>
          <img id="reviewImageModalImg" src="" alt="Imagen del local" class="img-fluid">
          <button type="button" class="btn btn-light review-modal-nav review-modal-next" data-review-modal-next aria-label="Imagen siguiente">
            <i class="fas fa-chevron-right"></i>
          </button>
        </div>
        <div class="review-modal-thumbs" id="reviewImageModalThumbs"></div>
      </div>
    </div>
  </div>
</div>

<script>
  (function() {
    function initializeBlackCoffeeReviewPage() {
    var cards = Array.prototype.slice.call(document.querySelectorAll('[data-review-card]'));
    var rejectedCounter = document.getElementById('review-live-rejected');
    var approvedCounter = document.getElementById('review-live-approved');
    var rejectedSummary = document.getElementById('review-rejected-count');
    var approvedSummary = document.getElementById('review-approved-count');
    var modal = document.getElementById('reviewImageModal');
    var modalImage = document.getElementById('reviewImageModalImg');
    var modalTitle = document.getElementById('reviewImageModalTitle');
    var modalCounter = document.getElementById('reviewImageModalCounter');
    var modalThumbs = document.getElementById('reviewImageModalThumbs');
    var prevButton = document.querySelector('[data-review-modal-prev]');
    var nextButton = document.querySelector('[data-review-modal-next]');
    var brokenImagesButton = document.querySelector('[data-mark-broken-images]');
    var brokenImagesSummary = document.querySelector('[data-broken-images-summary]');
    var galleryImages = [];
    var galleryIndex = 0;
    var galleryTitle = 'Imagen del local';

    function cardIsCategoryCorrection(card) {
      var reasonInput = card.querySelector('[data-reason-input]');
      var toggle = card.querySelector('[data-correct-category-toggle]');
      var select = card.querySelector('[data-corrected-category-select]');

      return !!(
        reasonInput &&
        reasonInput.value === 'wrong_category' &&
        toggle &&
        toggle.checked &&
        select &&
        select.value
      );
    }

    function cardIsRejected(card) {
      var input = card.querySelector('[data-reason-input]');
      return !!(input && input.value && !cardIsCategoryCorrection(card));
    }

    function updateCounters() {
      if (!rejectedCounter || !approvedCounter) return;

      var rejectedCount = cards.filter(function(card) {
        return cardIsRejected(card);
      }).length;
      var approvedCount = cards.length - rejectedCount;

      if (rejectedCounter) rejectedCounter.textContent = rejectedCount;
      if (approvedCounter) approvedCounter.textContent = approvedCount;
      if (rejectedSummary) rejectedSummary.textContent = rejectedCount;
      if (approvedSummary) approvedSummary.textContent = approvedCount;
    }

    function updateBrokenImagesSummary() {
      if (!brokenImagesSummary && !brokenImagesButton) return;

      var affectedCards = cards.filter(function(card) {
        return !!card.querySelector('[data-review-image][data-image-broken="true"]');
      });
      var count = affectedCards.length;

      if (brokenImagesSummary) {
        brokenImagesSummary.textContent = count > 0 ?
          count + ' locales del lote tienen al menos una imagen que no carga.' :
          'No se han detectado imagenes rotas en este lote.';
      }
      if (brokenImagesButton) {
        brokenImagesButton.disabled = count === 0;
      }
    }

    function renderGallery() {
      if (!modalImage || galleryImages.length === 0) return;

      var currentImage = galleryImages[galleryIndex];
      modalImage.src = currentImage.src;
      modalImage.alt = galleryTitle;

      if (modalTitle) modalTitle.textContent = galleryTitle;
      if (modalCounter) modalCounter.textContent = (galleryIndex + 1) + ' de ' + galleryImages.length;
      if (prevButton) prevButton.style.display = galleryImages.length > 1 ? 'inline-flex' : 'none';
      if (nextButton) nextButton.style.display = galleryImages.length > 1 ? 'inline-flex' : 'none';

      if (modalThumbs) {
        modalThumbs.innerHTML = '';
        galleryImages.forEach(function(image, index) {
          var thumb = document.createElement('img');
          thumb.src = image.src;
          thumb.alt = galleryTitle;
          thumb.className = 'review-modal-thumb' + (index === galleryIndex ? ' is-active' : '');
          thumb.addEventListener('click', function() {
            galleryIndex = index;
            renderGallery();
          });
          modalThumbs.appendChild(thumb);
        });
      }
    }

    function moveGallery(delta) {
      if (galleryImages.length < 2) return;

      galleryIndex = (galleryIndex + delta + galleryImages.length) % galleryImages.length;
      renderGallery();
    }

    function openGallery(clickedImage) {
      var card = clickedImage.closest('[data-review-card]');
      var images = card ? Array.prototype.slice.call(card.querySelectorAll('[data-review-image]')) : [clickedImage];
      galleryImages = images.map(function(image) {
        return {
          src: image.getAttribute('data-full-src') || image.src
        };
      }).filter(function(image) {
        return image.src;
      });
      galleryIndex = Math.max(0, images.indexOf(clickedImage));
      galleryTitle = clickedImage.getAttribute('data-image-title') || clickedImage.alt || 'Imagen del local';
      renderGallery();

      if (window.jQuery && window.jQuery.fn && window.jQuery.fn.modal) {
        window.jQuery(modal).modal('show');
      }
    }

    cards.forEach(function(card) {
      if (card.getAttribute('data-review-card-bound') === 'true') return;
      card.setAttribute('data-review-card-bound', 'true');

      var reasonInput = card.querySelector('[data-reason-input]');
      var noteInput = card.querySelector('[data-note-input]');
      var noteWrapper = card.querySelector('[data-note-wrapper]');
      var status = card.querySelector('[data-review-status]');
      var buttons = Array.prototype.slice.call(card.querySelectorAll('[data-rejection-reason]'));
      var undoButton = card.querySelector('[data-review-undo]');
      var categoryCorrectionWrapper = card.querySelector('[data-category-correction-wrapper]');
      var correctCategoryHidden = card.querySelector('[data-correct-category-hidden]');
      var correctCategoryToggle = card.querySelector('[data-correct-category-toggle]');
      var correctedCategorySelect = card.querySelector('[data-corrected-category-select]');

      function selectedCategoryLabel() {
        if (!correctedCategorySelect || !correctedCategorySelect.value) return '';

        var option = correctedCategorySelect.options[correctedCategorySelect.selectedIndex];
        return option ? option.text : correctedCategorySelect.value;
      }

      function syncCategoryCorrectionState() {
        if (!reasonInput) return;

        var isWrongCategory = reasonInput.value === 'wrong_category';
        var correctionRequested = !!(isWrongCategory && correctCategoryToggle && correctCategoryToggle.checked);
        var correctionReady = correctionRequested && correctedCategorySelect && correctedCategorySelect.value;

        if (categoryCorrectionWrapper) {
          categoryCorrectionWrapper.style.display = isWrongCategory ? 'block' : 'none';
        }

        if (!isWrongCategory) {
          if (correctCategoryToggle) correctCategoryToggle.checked = false;
          if (correctCategoryHidden) correctCategoryHidden.value = '0';
          if (correctedCategorySelect) correctedCategorySelect.value = '';
        }

        if (correctCategoryHidden) {
          correctCategoryHidden.value = correctionRequested ? '1' : '0';
        }

        if (correctedCategorySelect) {
          correctedCategorySelect.disabled = !correctionRequested;
          correctedCategorySelect.required = correctionRequested;
        }

        card.classList.toggle('is-corrected', !!correctionReady);
        card.classList.toggle('is-rejected', !!(reasonInput.value && !correctionReady));

        if (status && correctionRequested) {
          status.classList.remove('badge-warning', 'badge-danger');
          status.classList.add(correctionReady ? 'badge-success' : 'badge-warning');
          status.textContent = correctionReady ?
            'Se aprobara corrigiendo a: ' + selectedCategoryLabel() :
            'Selecciona la categoria correcta';
        }

        updateCounters();
      }

      function setReason(reason, label) {
        if (!reasonInput) return;

        reasonInput.value = reason;
        card.classList.add('is-rejected');
        if (status) {
          status.classList.remove('badge-warning', 'badge-success');
          status.classList.add('badge-danger');
          status.textContent = 'Rechazado: ' + label;
        }
        buttons.forEach(function(button) {
          button.classList.toggle('active', button.getAttribute('data-rejection-reason') === reason);
        });
        if (noteWrapper) {
          noteWrapper.style.display = reason === 'other' ? 'block' : 'none';
        }
        if (reason !== 'other' && noteInput) {
          noteInput.value = '';
        }
        syncCategoryCorrectionState();
        updateCounters();
      }

      function clearReason() {
        if (!reasonInput) return;

        reasonInput.value = '';
        card.classList.remove('is-rejected');
        card.classList.remove('is-corrected');
        if (status) {
          status.classList.remove('badge-danger', 'badge-success');
          status.classList.add('badge-warning');
          status.textContent = 'Pendiente en este lote';
        }
        buttons.forEach(function(button) {
          button.classList.remove('active');
        });
        if (noteWrapper) {
          noteWrapper.style.display = 'none';
        }
        if (noteInput) {
          noteInput.value = '';
        }
        syncCategoryCorrectionState();
        updateCounters();
      }

      card.blackCoffeeSetReviewReason = setReason;

      buttons.forEach(function(button) {
        button.addEventListener('click', function() {
          setReason(button.getAttribute('data-rejection-reason'), button.getAttribute('data-rejection-label'));
        });
      });

      if (correctCategoryToggle) {
        correctCategoryToggle.addEventListener('change', syncCategoryCorrectionState);
      }

      if (correctedCategorySelect) {
        correctedCategorySelect.addEventListener('change', syncCategoryCorrectionState);
      }

      if (undoButton) {
        undoButton.addEventListener('click', clearReason);
      }

      syncCategoryCorrectionState();
    });

    Array.prototype.slice.call(document.querySelectorAll('[data-review-image]')).forEach(function(image) {
      if (image.getAttribute('data-review-image-bound') === 'true') return;
      image.setAttribute('data-review-image-bound', 'true');

      function markImageAsBroken() {
        image.setAttribute('data-image-broken', 'true');
        updateBrokenImagesSummary();
      }

      function markImageAsLoaded() {
        if (image.naturalWidth > 0) {
          image.removeAttribute('data-image-broken');
          updateBrokenImagesSummary();
        }
      }

      image.addEventListener('error', markImageAsBroken);
      image.addEventListener('load', markImageAsLoaded);
      if (image.complete && image.naturalWidth === 0) {
        markImageAsBroken();
      }

      image.addEventListener('click', function(event) {
        event.preventDefault();
        openGallery(image);
      });
    });

    if (brokenImagesButton && brokenImagesButton.getAttribute('data-broken-images-bound') !== 'true') {
      brokenImagesButton.setAttribute('data-broken-images-bound', 'true');
      brokenImagesButton.addEventListener('click', function() {
        var affectedCards = cards.filter(function(card) {
          return !!card.querySelector('[data-review-image][data-image-broken="true"]');
        });

        affectedCards.forEach(function(card) {
          if (typeof card.blackCoffeeSetReviewReason === 'function') {
            card.blackCoffeeSetReviewReason('bad_photos', 'Fotos incorrectas o muy malas');
          }
        });
      });
    }

    if (prevButton && prevButton.getAttribute('data-review-gallery-bound') !== 'true') {
      prevButton.setAttribute('data-review-gallery-bound', 'true');
      prevButton.addEventListener('click', function() {
        moveGallery(-1);
      });
    }

    if (nextButton && nextButton.getAttribute('data-review-gallery-bound') !== 'true') {
      nextButton.setAttribute('data-review-gallery-bound', 'true');
      nextButton.addEventListener('click', function() {
        moveGallery(1);
      });
    }

    updateCounters();
    updateBrokenImagesSummary();
    }

    document.addEventListener('DOMContentLoaded', initializeBlackCoffeeReviewPage);
    document.addEventListener('turbolinks:load', initializeBlackCoffeeReviewPage);
  })();
</script>
