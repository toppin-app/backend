  // ===== COMPLAINTS DATA =====

  function formatWeekLabel(isoDate) {
    try {
      const d = new Date(isoDate + 'T00:00:00');
      const end = new Date(d.getTime() + 6 * 24 * 60 * 60 * 1000);
      const opts = { day: 'numeric', month: 'short' };
      return d.toLocaleDateString('es-ES', opts) + ' – ' + end.toLocaleDateString('es-ES', opts);
    } catch (_) { return isoDate; }
  }

  async function loadComplaintsData() {
    // Reset HTML-based containers so stale data disappears when filters change
    const _matrixEl = document.getElementById('chart-complaints-gender-matrix');
    if (_matrixEl) _matrixEl.innerHTML = '';
    const _typeMatrixEl = document.getElementById('chart-complaints-type-matrix');
    if (_typeMatrixEl) _typeMatrixEl.innerHTML = '<p class="text-muted text-center mt-3">Cargando datos...</p>';

    try {
      const data = await fetchData('complaints');
      if (!data) {
        console.warn('[Analytics] No data returned for complaints section');
        return;
      }

      const genderLabels = { 0: 'Mujer', 1: 'Hombre', 2: 'No binario', 3: 'Pareja' };
      const genderColors = [colors.pink, colors.primary, colors.purple, colors.teal];

      // Total metric card
      const totalEl = document.getElementById('metric-complaints-total');
      if (totalEl) totalEl.textContent = formatNumber(data.total || 0);

      // Over time
      renderLineChart('chart-complaints-over-time', {
        labels: Object.keys(data.over_time || {}).map(formatWeekLabel),
        datasets: [{
          label: 'Denuncias',
          data: Object.values(data.over_time || {}),
          borderColor: colors.danger,
          backgroundColor: colors.danger + '20',
          fill: true,
          tension: 0.4
        }]
      });

      // By reporter gender
      const repGender = data.by_reporter_gender || {};
      renderPieChart('chart-complaints-reporter-gender', {
        labels: Object.keys(repGender).map(k => genderLabels[parseInt(k)] || k),
        datasets: [{ data: Object.values(repGender), backgroundColor: genderColors }]
      });

      // By reported gender
      const repdGender = data.by_reported_gender || {};
      renderPieChart('chart-complaints-reported-gender', {
        labels: Object.keys(repdGender).map(k => genderLabels[parseInt(k)] || k),
        datasets: [{ data: Object.values(repdGender), backgroundColor: genderColors }]
      });

      // Gender matrix as HTML table
      const matrix = data.gender_matrix || {};
      const reporters = Object.keys(matrix);
      const allReported = [...new Set(reporters.flatMap(r => Object.keys(matrix[r] || {})))];
      const genderMatrixEl = document.getElementById('chart-complaints-gender-matrix');
      if (genderMatrixEl) {
        if (reporters.length > 0) {
          let html = '<table class="table table-bordered table-sm text-center w-100" style="font-size:13px; margin:12px auto;">';
          html += '<thead class="thead-light"><tr><th>Denunciante \ Denunciado</th>' + allReported.map(c => `<th>${c}</th>`).join('') + '</tr></thead><tbody>';
          reporters.forEach(r => {
            html += `<tr><td class="font-weight-bold">${r}</td>` + allReported.map(c => {
              const val = (matrix[r] || {})[c] || 0;
              const intensity = val > 0 ? Math.min(0.15 + (val / 200), 0.85) : 0;
              return `<td style="background:rgba(220,53,69,${intensity}); color:${intensity > 0.4 ? '#fff' : '#333'}">${val}</td>`;
            }).join('') + '</tr>';
          });
          html += '</tbody></table>';
          genderMatrixEl.innerHTML = html;
        } else {
          genderMatrixEl.innerHTML = '<p class="text-muted text-center p-3">No hay datos de denuncias para mostrar con los filtros actuales.</p>';
        }
      }

      // Made distribution
      const madeDist = data.made_distribution || {};
      const madeLabels = [...Array(11).keys()].map(String).concat(['>10']);
      renderBarChart('chart-complaints-made-dist', {
        labels: madeLabels,
        datasets: [{ label: 'Usuarios', data: madeLabels.map(k => madeDist[k] || 0), backgroundColor: colors.warning }]
      }, { plugins: { legend: { display: false } }, scales: { x: { title: { display: true, text: 'Denuncias realizadas' } }, y: { beginAtZero: true } } });

      // Received distribution
      const recvDist = data.received_distribution || {};
      renderBarChart('chart-complaints-received-dist', {
        labels: madeLabels,
        datasets: [{ label: 'Usuarios', data: madeLabels.map(k => recvDist[k] || 0), backgroundColor: colors.danger }]
      }, { plugins: { legend: { display: false } }, scales: { x: { title: { display: true, text: 'Denuncias recibidas' } }, y: { beginAtZero: true } } });

      // Avg received by gender
      const avgByGender = data.avg_received_by_gender || {};
      renderBarChart('chart-complaints-avg-by-gender', {
        labels: Object.keys(avgByGender),
        datasets: [{ label: 'Promedio', data: Object.values(avgByGender), backgroundColor: genderColors.slice(0, Object.keys(avgByGender).length) }]
      }, { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, title: { display: true, text: 'Promedio denuncias recibidas' } } } });

      // ===== TYPE × GENDER =====
      const ttg = data.by_type_and_gender || {};
      const typeColorPalette = [colors.primary, colors.danger, colors.warning, colors.success, colors.purple, colors.teal];

      // 1. Total by type — HTML bar chart (long labels, no tooltip issues)
      const byType = ttg.by_type || {};
      const sortedTypeEntries = Object.entries(byType).sort((a, b) => b[1] - a[1]);
      renderHTMLBarChart(
        'chart-complaints-by-type',
        sortedTypeEntries.map(([k]) => k),
        sortedTypeEntries.map(([, v]) => v),
        colors.danger
      );

      // 2. By type × reporter gender — horizontal grouped bar
      const byTypeReporter = ttg.by_type_reporter_gender || {};
      const reporterGenders = Object.keys(byTypeReporter);
      const allTypeLabelsR = [...new Set(reporterGenders.flatMap(g => Object.keys(byTypeReporter[g] || {})))];
      if (allTypeLabelsR.length > 0) {
        const repDatasets = reporterGenders.map((g, i) => ({
          label: g,
          data: allTypeLabelsR.map(t => (byTypeReporter[g] || {})[t] || 0),
          backgroundColor: genderColors[i % genderColors.length]
        }));
        renderGroupedBarChart('chart-complaints-type-reporter-gender', allTypeLabelsR, repDatasets, true);
      }

      // 3. By type × reported gender — horizontal grouped bar
      const byTypeReported = ttg.by_type_reported_gender || {};
      const reportedGenders = Object.keys(byTypeReported);
      const allTypeLabelsD = [...new Set(reportedGenders.flatMap(g => Object.keys(byTypeReported[g] || {})))];
      if (allTypeLabelsD.length > 0) {
        const repdDatasets = reportedGenders.map((g, i) => ({
          label: g,
          data: allTypeLabelsD.map(t => (byTypeReported[g] || {})[t] || 0),
          backgroundColor: genderColors[i % genderColors.length]
        }));
        renderGroupedBarChart('chart-complaints-type-reported-gender', allTypeLabelsD, repdDatasets, true);
      }

      // 4. Full matrix: reporter gender × reported gender × type — nested HTML tables
      const fullMatrix = ttg.full_matrix || {};
      const matrixEl = document.getElementById('chart-complaints-type-matrix');
      if (matrixEl) {
        const rptGenders = Object.keys(fullMatrix);
        if (rptGenders.length === 0) {
          matrixEl.innerHTML = '<p class="text-muted text-center">Sin datos</p>';
        } else {
          const allRepdG = [...new Set(rptGenders.flatMap(r => Object.keys(fullMatrix[r] || {})))];
          const allTypes = [...new Set(rptGenders.flatMap(r => allRepdG.flatMap(d => Object.keys((fullMatrix[r] || {})[d] || {}))))];
          let html = '';
          rptGenders.forEach(reporter => {
            html += `<h6 class="mt-3 mb-1 font-weight-bold" style="font-size:13px">Denunciante: ${reporter}</h6>`;
            html += '<table class="table table-bordered table-sm text-center mb-2" style="font-size:12px">';
            html += '<thead><tr><th style="font-size:11px">Denunciado →</th>' + allRepdG.map(d => `<th>${d}</th>`).join('') + '</tr></thead><tbody>';
            allTypes.forEach(type => {
              html += `<tr><td class="text-left font-weight-bold" style="font-size:11px; white-space:nowrap">${type}</td>`;
              allRepdG.forEach(reported => {
                const val = ((fullMatrix[reporter] || {})[reported] || {})[type] || 0;
                const intensity = val > 0 ? Math.min(0.12 + (val / 150), 0.85) : 0;
                html += `<td style="background:rgba(220,53,69,${intensity}); color:${intensity > 0.4 ? '#fff' : '#333'}">${val || ''}</td>`;
              });
              html += '</tr>';
            });
            html += '</tbody></table>';
          });
          matrixEl.innerHTML = html;
        }
      }

    } catch (e) {
      console.error('[Analytics] Error loading complaints data:', e);
    }
  }

  // ===== CHART RENDERING FUNCTIONS =====

  function renderLineChart(canvasId, data, options = {}) {
    destroyChart(canvasId);
    
    const ctx = document.getElementById(canvasId);
    if (!ctx) return;
    
    const defaultOptions = {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: true,
          position: 'top'
        },
        tooltip: {
          mode: 'index',
          intersect: false
        }
      },
      scales: {
        x: {
          display: true,
          grid: {
            display: false
          }
        },
        y: {
          display: true,
          beginAtZero: true,
          grid: {
            color: 'rgba(0,0,0,0.05)'
          }
        }
      }
    };
    
    charts[canvasId] = new Chart(ctx, {
      type: 'line',
      data: data,
      options: Object.assign({}, defaultOptions, options)
    });
  }

  // Pure HTML/CSS horizontal bar chart — no Chart.js, no sizing issues.
  // Each row is a flex div: label on the left, proportional colored bar on the right.
  function renderHTMLBarChart(containerId, labels, values, color) {
    const container = document.getElementById(containerId);
    if (!container) return;

    const maxVal    = Math.max(...values, 1);
    const VISIBLE   = 15;
    const hasMore   = labels.length > VISIBLE;

    function buildRow(label, val) {
      const pct = (val / maxVal * 100).toFixed(1);
      return `
        <div style="display:flex; align-items:center; margin-bottom:6px; min-height:28px;">
          <div style="width:200px; min-width:200px; text-align:right; padding-right:12px;
                      font-size:13px; color:#333; overflow:hidden; text-overflow:ellipsis;
                      white-space:nowrap;" title="${label}">${label}</div>
          <div style="flex:1; background:#f0f0f0; border-radius:3px; height:20px; position:relative;">
            <div style="width:${pct}%; background:${color}; height:100%; border-radius:3px;
                        min-width:${val > 0 ? 2 : 0}px;"></div>
          </div>
          <div style="width:36px; min-width:36px; text-align:right; padding-left:8px;
                      font-size:12px; font-weight:600; color:#555;">${val}</div>
        </div>`;
    }

    let html = '<div style="font-family: inherit; padding: 12px 16px;">';

    // First 15 rows always visible
    labels.slice(0, VISIBLE).forEach((label, i) => {
      html += buildRow(label, values[i] || 0);
    });

    // Remaining rows, hidden by default
    if (hasMore) {
      const remaining = labels.length - VISIBLE;
      html += `<div id="${containerId}-extra" style="display:none;">`;
      labels.slice(VISIBLE).forEach((label, i) => {
        html += buildRow(label, values[VISIBLE + i] || 0);
      });
      html += `</div>`;
      html += `
        <div style="text-align:center; margin-top:12px;">
          <button onclick="toggleHTMLBarChartExtra('${containerId}', this, ${remaining})"
                  style="background:none; border:1px solid #aaa; border-radius:4px;
                         padding:6px 18px; font-size:13px; cursor:pointer; color:#555;">
            Ver ${remaining} más ▼
          </button>
        </div>`;
    }

    html += '</div>';
    container.innerHTML = html;
  }

  function toggleHTMLBarChartExtra(containerId, btn, remaining) {
    const extra = document.getElementById(containerId + '-extra');
    if (!extra) return;
    const expanded = extra.style.display !== 'none';
    extra.style.display = expanded ? 'none' : 'block';
    btn.textContent = expanded ? `Ver ${remaining} más ▼` : 'Ver menos ▲';
  }
  window.toggleHTMLBarChartExtra = toggleHTMLBarChartExtra;

  function renderGroupedBarChart(canvasId, labels, datasets, horizontal = false) {
    destroyChart(canvasId);
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    charts[canvasId] = new Chart(ctx, {
      type: 'bar',
      data: { labels, datasets },
      options: {
        indexAxis: horizontal ? 'y' : 'x',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: true, position: 'top' },
          tooltip: { mode: 'index', intersect: false }
        },
        scales: horizontal ? {
          x: { beginAtZero: true },
          y: { grid: { display: false }, ticks: { autoSkip: false } }
        } : {
          x: { grid: { display: false } },
          y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' } }
        }
      }
    });
  }

  function renderBarChart(canvasId, data, options = {}) {
    destroyChart(canvasId);
    
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    
    // Extract custom height if provided
    const customHeight = options.customHeight;
    delete options.customHeight; // Remove from options to avoid passing to Chart.js
    
    // When customHeight is set, use the Chart.js recommended pattern:
    // set height on the WRAPPER div (position:relative), and use
    // responsive:true + maintainAspectRatio:false so Chart.js fills it.
    const hasCustomHeight = !!customHeight;
    
    if (hasCustomHeight) {
      // Check if there's a dedicated wrapper (e.g. chart-main-interests-wrapper)
      const wrapperId = canvasId + '-wrapper';
      const wrapper = document.getElementById(wrapperId);
      const targetContainer = wrapper || canvas.parentElement;
      
      // Set height on the container — Chart.js (responsive) will fill this
      targetContainer.style.height = customHeight + 'px';
      targetContainer.style.minHeight = customHeight + 'px';
      
      // Ensure position:relative so Chart.js can measure it
      if (!wrapper) {
        targetContainer.style.position = 'relative';
      }
    }
    
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    
    const defaultOptions = {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          display: false
        },
        tooltip: {
          mode: 'index',
          intersect: false
        }
      },
      scales: {
        x: {
          grid: {
            display: false
          }
        },
        y: {
          beginAtZero: true,
          grid: {
            color: 'rgba(0,0,0,0.05)'
          }
        }
      }
    };
    
    // Deep merge options to preserve nested properties
    const mergedOptions = {
      ...defaultOptions,
      ...options,
      // Always keep responsive + maintainAspectRatio
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        ...defaultOptions.plugins,
        ...(options.plugins || {})
      },
      scales: {
        x: {
          ...defaultOptions.scales.x,
          ...(options.scales?.x || {})
        },
        y: {
          ...defaultOptions.scales.y,
          ...(options.scales?.y || {}),
          ticks: {
            ...(defaultOptions.scales.y.ticks || {}),
            ...(options.scales?.y?.ticks || {})
          }
        }
      }
    };
    
    // Registrar plugin personalizado si está habilitado
    const plugins = [];
    if (options.plugins && options.plugins.dataLabelsPlugin) {
      plugins.push(dataLabelsPlugin);
      delete mergedOptions.plugins.dataLabelsPlugin; // Remover para no conflictuar
    }
    
    charts[canvasId] = new Chart(ctx, {
      type: 'bar',
      data: data,
      options: mergedOptions,
      plugins: plugins
    });
  }

  function renderPieChart(canvasId, data, options = {}) {
    destroyChart(canvasId);
    
    const ctx = document.getElementById(canvasId);
    if (!ctx) return;
    
    const defaultOptions = {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: true,
          position: 'bottom'
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const label = context.label || '';
              const value = context.parsed || 0;
              const total = context.dataset.data.reduce((a, b) => a + b, 0);
              const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
              return `${label}: ${formatNumber(value)} (${percentage}%)`;
            }
          }
        }
      }
    };
    
    charts[canvasId] = new Chart(ctx, {
      type: 'doughnut',
      data: data,
      options: Object.assign({}, defaultOptions, options)
    });
  }

  function destroyChart(canvasId) {
    if (charts[canvasId]) {
      charts[canvasId].destroy();
      delete charts[canvasId];
    }
  }

  // Load data on page load
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize date range toggle
    const dateRangeSelect = document.getElementById('date-range');
    if (dateRangeSelect) {
      dateRangeSelect.addEventListener('change', function() {
        const customStartDiv = document.getElementById('custom-date-start');
        const customEndDiv = document.getElementById('custom-date-end');
        
        if (this.value === 'custom') {
          customStartDiv.style.display = 'block';
          customEndDiv.style.display = 'block';
        } else {
          customStartDiv.style.display = 'none';
          customEndDiv.style.display = 'none';
        }
      });
    }

    // Apply filters button
    const applyButton = document.getElementById('apply-filters');
    if (applyButton) {
      applyButton.addEventListener('click', function() {
        loadAllData();
      });
    }

    // Load initial data
    loadAllData();
  });

