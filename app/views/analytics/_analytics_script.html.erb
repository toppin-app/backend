// Analytics Dashboard JavaScript
(function() {
  'use strict';

  // Global chart instances
  const charts = {};

  // Chart.js default config
  Chart.defaults.font.family = "'Source Sans Pro', sans-serif";
  Chart.defaults.color = '#666';
  
  // Color palette
  const colors = {
    primary: '#007bff',
    success: '#28a745',
    danger: '#dc3545',
    warning: '#ffc107',
    info: '#17a2b8',
    purple: '#6f42c1',
    pink: '#e83e8c',
    teal: '#20c997',
    orange: '#fd7e14',
    gray: '#6c757d'
  };

  // Helper function to format numbers
  function formatNumber(num) {
    if (num === null || num === undefined) return '-';
    return num.toLocaleString('es-ES');
  }

  // Helper function to create gradient
  function createGradient(ctx, color1, color2) {
    const gradient = ctx.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, color1);
    gradient.addColorStop(1, color2);
    return gradient;
  }

  // Get filter parameters
  function getFilters() {
    const form = document.getElementById('analytics-filters-form');
    const formData = new FormData(form);
    const params = new URLSearchParams();
    
    // Log form data for debugging
    console.log('=== ANALYTICS FILTERS - Form Data ===');
    for (let [key, value] of formData.entries()) {
      console.log(`  ${key}: ${value}`);
    }
    
    // Always send all filter values to backend, even "all" values
    // This ensures the backend knows the user's explicit choice
    for (let [key, value] of formData.entries()) {
      if (value) {
        params.append(key, value);
      }
    }
    
    const queryString = params.toString();
    console.log('Query string:', queryString);
    console.log('=====================================');
    
    return queryString;
  }

  // Fetch data from API with timeout
  async function fetchData(section) {
    const filters = getFilters();
    const url = `/analytics/data?section=${section}&${filters}`;
    
    // Create abort controller for timeout
    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), 30000); // 30 second timeout
    
    try {
      console.log(`[Analytics] Fetching data for section: ${section}`);
      const response = await fetch(url, { signal: controller.signal });
      clearTimeout(timeoutId);
      
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      
      const data = await response.json();
      console.log(`[Analytics] Successfully loaded data for section: ${section}`);
      return data;
    } catch (error) {
      clearTimeout(timeoutId);
      
      if (error.name === 'AbortError') {
        console.error(`[Analytics] Timeout loading ${section} data`);
      } else {
        console.error(`[Analytics] Error fetching ${section} data:`, error);
      }
      return null;
    }
  }

  // Track if a load is in progress to prevent race conditions
  let isLoading = false;

  // Load all sections
  async function loadAllData() {
    // Prevent multiple simultaneous loads
    if (isLoading) {
      console.log('[Analytics] Load already in progress, skipping...');
      return;
    }
    
    isLoading = true;
    const applyButton = document.getElementById('apply-filters');
    
    try {
      console.log('[Analytics] Starting data load...');
      
      // Show loading state
      showLoading();
      if (applyButton) {
        applyButton.disabled = true;
        applyButton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Cargando...';
      }
      
      // Load only the sections that exist now (growth, demographics, insights, media, interests)
      const results = await Promise.allSettled([
        loadGrowthData(),
        loadDemographicsData(),
        loadInsightsData(),
        loadMediaData(),
        loadInterestsData()
      ]);
      
      // Log any failures
      results.forEach((result, index) => {
        const sections = ['growth', 'demographics', 'insights', 'media', 'interests'];
        if (result.status === 'rejected') {
          console.error(`[Analytics] Failed to load ${sections[index]}:`, result.reason);
        }
      });
      
      console.log('[Analytics] Data load completed');
    } catch (error) {
      console.error('[Analytics] Unexpected error during data load:', error);
    } finally {
      // Always hide loading state and re-enable button, even if there were errors
      hideLoading();
      if (applyButton) {
        applyButton.disabled = false;
        applyButton.innerHTML = '<i class="fas fa-sync"></i> Aplicar Filtros';
      }
      isLoading = false;
    }
  }

  function showLoading() {
    const loadingIndicator = document.getElementById('loading-indicator');
    if (loadingIndicator) {
      loadingIndicator.style.display = 'block';
    }
  }

  function hideLoading() {
    const loadingIndicator = document.getElementById('loading-indicator');
    if (loadingIndicator) {
      loadingIndicator.style.display = 'none';
    }
  }

  // ===== GROWTH SECTION =====
  async function loadGrowthData() {
    try {
      const data = await fetchData('growth');
      if (!data) {
        console.warn('[Analytics] No data returned for growth section');
        return;
      }

    // Update KEY METRICS cards at the top
    const userMetrics = data.user_metrics || {};
    if (userMetrics.total_users !== undefined) {
      document.getElementById('metric-total-users').textContent = formatNumber(userMetrics.total_users);
    }

    // New Users Over Time
    renderLineChart('chart-new-users', {
      labels: Object.keys(data.new_users_daily || {}),
      datasets: [{
        label: 'Nuevos Usuarios',
        data: Object.values(data.new_users_daily || {}),
        borderColor: colors.primary,
        backgroundColor: colors.primary + '20',
        fill: true,
        tension: 0.4
      }]
    });

    // Cumulative Users
    renderLineChart('chart-cumulative-users', {
      labels: Object.keys(data.cumulative_users || {}),
      datasets: [{
        label: 'Total de Usuarios',
        data: Object.values(data.cumulative_users || {}),
        borderColor: colors.success,
        backgroundColor: colors.success + '20',
        fill: true,
        tension: 0.4
      }]
    });

    // Users by Type
    const usersByType = data.users_by_type || {};
    renderPieChart('chart-users-by-type', {
      labels: ['Usuarios Reales', 'Bots', 'Eliminados'],
      datasets: [{
        data: [usersByType.real || 0, usersByType.bots || 0, usersByType.deleted || 0],
        backgroundColor: [colors.success, colors.warning, colors.danger]
      }]
    });

    // Verified Distribution
    const verified = data.verified_distribution || {};
    renderPieChart('chart-verified', {
      labels: ['Verificado', 'No Verificado'],
      datasets: [{
        data: [verified.verified || 0, verified.non_verified || 0],
        backgroundColor: [colors.info, colors.gray]
      }]
    });

    // Deletions Over Time
    renderLineChart('chart-deletions', {
      labels: Object.keys(data.deletions || {}),
      datasets: [{
        label: 'Eliminaciones',
        data: Object.values(data.deletions || {}),
        borderColor: colors.danger,
        backgroundColor: colors.danger + '20',
        fill: true,
        tension: 0.4
      }]
    }, { scales: { y: { beginAtZero: true } } });
    } catch (error) {
      console.error('[Analytics] Error rendering growth charts:', error);
    }
  }

  // ===== DEMOGRAPHICS SECTION =====
  async function loadDemographicsData() {
    try {
      const data = await fetchData('demographics');
      if (!data) {
        console.warn('[Analytics] No data returned for demographics section');
        return;
      }

    // Gender Distribution
    const genderData = data.gender_distribution || {};
    const genderLabels = {0: 'Mujer', 1: 'Hombre', 2: 'No binario', 3: 'Pareja'};
    renderPieChart('chart-gender', {
      labels: Object.keys(genderData).map(k => genderLabels[k] || k),
      datasets: [{
        data: Object.values(genderData),
        backgroundColor: [colors.pink, colors.primary, colors.purple, colors.teal]
      }]
    });

    // Age Distribution
    const ageData = data.age_distribution || {};
    renderBarChart('chart-age', {
      labels: Object.keys(ageData),
      datasets: [{
        label: 'Usuarios por Edad',
        data: Object.values(ageData),
        backgroundColor: colors.info
      }]
    });

    // Top Countries
    const countriesData = data.top_countries || {};
    renderBarChart('chart-countries', {
      labels: Object.keys(countriesData),
      datasets: [{
        label: 'Usuarios',
        data: Object.values(countriesData),
        backgroundColor: colors.success
      }]
    }, { indexAxis: 'y' });

    // Top Cities
    const citiesData = data.top_cities || {};
    renderBarChart('chart-cities', {
      labels: Object.keys(citiesData),
      datasets: [{
        label: 'Usuarios',
        data: Object.values(citiesData),
        backgroundColor: colors.orange
      }]
    }, { indexAxis: 'y' });
    } catch (error) {
      console.error('[Analytics] Error rendering demographics charts:', error);
    }
  }

  // ===== INSIGHTS SECTION =====
  async function loadInsightsData() {
    try {
      const data = await fetchData('insights');
      if (!data) {
        console.warn('[Analytics] No data returned for insights section');
        return;
      }

    const topUsers = data.top_users || {};
    
    // Top Matches
    let html = '<ol class="pl-3">';
    (topUsers.most_matches || []).forEach(user => {
      html += `<li>Usuario #${user[0]} (${user[1]}) - ${formatNumber(user[2])} matches</li>`;
    });
    html += '</ol>';
    document.getElementById('top-matches-list').innerHTML = html;

    // Most Liked
    html = '<ol class="pl-3">';
    (topUsers.most_liked || []).forEach(user => {
      html += `<li>User #${user[0]} (${user[1]}) - ${formatNumber(user[2])} likes</li>`;
    });
    html += '</ol>';
    document.getElementById('top-liked-list').innerHTML = html;

    // Top Cities
    const topCities = data.top_cities || [];
    html = '<ol class="pl-3">';
    topCities.forEach(city => {
      html += `<li>${city.city} - ${formatNumber(city.users)} usuarios, promedio ${city.avg_matches} matches</li>`;
    });
    html += '</ol>';
    document.getElementById('top-cities-list').innerHTML = html;
    } catch (error) {
      console.error('[Analytics] Error rendering insights:', error);
    }
  }

  // Plugin para mostrar valores directamente en las barras
  const dataLabelsPlugin = {
    id: 'dataLabelsPlugin',
    afterDatasetsDraw(chart, args, options) {
      const { ctx, chartArea: { left, right, top, bottom }, scales: { x, y } } = chart;
      
      chart.data.datasets.forEach((dataset, datasetIndex) => {
        const meta = chart.getDatasetMeta(datasetIndex);
        
        meta.data.forEach((bar, index) => {
          const value = dataset.data[index];
          if (value === 0 || value === null || value === undefined) return;
          
          ctx.save();
          ctx.font = 'bold 12px Arial';
          ctx.fillStyle = '#333';
          ctx.textAlign = 'left';
          ctx.textBaseline = 'middle';
          
          // For horizontal bars, display value to the right of the bar
          const xPos = bar.x + 5;
          const yPos = bar.y;
          
          ctx.fillText(value, xPos, yPos);
          ctx.restore();
        });
      });
    }
  };

  // ===== MEDIA SECTION (Movies, Series, Photos) =====
  async function loadMediaData() {
    try {
      const data = await fetchData('media');
      if (!data) {
        console.warn('[Analytics] No data returned for media section');
        return;
      }

      // Top 20 Series - Horizontal Bar Chart (primero, para coincidir con el orden del HTML)
      const seriesData = data.top_series || {};
      const seriesLabels = Object.keys(seriesData);
      const seriesCounts = Object.values(seriesData);
      
      renderBarChart('chart-top-series', {
        labels: seriesLabels,
        datasets: [{
          label: 'Usuarios',
          data: seriesCounts,
          backgroundColor: colors.purple
        }]
      }, {
        indexAxis: 'y',
        plugins: {
          tooltip: {
            enabled: true
          },
          dataLabelsPlugin: true
        },
        scales: {
          x: {
            beginAtZero: true,
            grid: {
              color: 'rgba(0,0,0,0.05)'
            }
          },
          y: {
            grid: {
              display: false
            }
          }
        }
      });

      // Top 20 Movies - Horizontal Bar Chart
      const moviesData = data.top_movies || {};
      const movieLabels = Object.keys(moviesData);
      const movieCounts = Object.values(moviesData);
      
      renderBarChart('chart-top-movies', {
        labels: movieLabels,
        datasets: [{
          label: 'Usuarios',
          data: movieCounts,
          backgroundColor: colors.pink
        }]
      }, {
        indexAxis: 'y',
        plugins: {
          tooltip: {
            enabled: true
          },
          dataLabelsPlugin: true
        },
        scales: {
          x: {
            beginAtZero: true,
            grid: {
              color: 'rgba(0,0,0,0.05)'
            }
          },
          y: {
            grid: {
              display: false
            }
          }
        }
      });

      // Photos Distribution - Dividida en dos gráficas: válida (1-9) e inválida (0, >9)
      const photosData = data.photos_distribution || {};
      const validData = photosData.valid || {};
      const invalidData = photosData.invalid || {};
      const invalidUsers = photosData.invalid_users || { '0': [], '>9': [] };
      
      // Store invalid users globally for modal access
      window.invalidPhotosUsers = invalidUsers;
      
      // === Gráfica Principal: Valores Válidos (1-9) ===
      const validLabels = [];
      const validCounts = [];
      
      for (let i = 1; i <= 9; i++) {
        const key = i.toString();
        const count = validData[key] || 0;
        validLabels.push(i === 1 ? '1 foto' : `${i} fotos`);
        validCounts.push(count);
      }
      
      renderBarChart('chart-photos-valid', {
        labels: validLabels,
        datasets: [{
          label: 'Usuarios',
          data: validCounts,
          backgroundColor: colors.teal
        }]
      }, {
        plugins: {
          legend: {
            display: false
          }
        }
      });
      
      // === Gráfica Secundaria: Casos Inválidos (0 y >9) ===
      const invalidLabels = ['0 fotos', '>9 fotos'];
      const invalidCounts = [
        invalidData['0'] || 0,
        invalidData['>9'] || 0
      ];
      
      renderBarChart('chart-photos-invalid', {
        labels: invalidLabels,
        datasets: [{
          label: 'Usuarios',
          data: invalidCounts,
          backgroundColor: colors.warning
        }]
      }, {
        plugins: {
          legend: {
            display: false
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              stepSize: 1
            }
          }
        }
      });
      
      // Update counts in buttons and show actions if there are invalid users
      const count0 = invalidData['0'] || 0;
      const countMore = invalidData['>9'] || 0;
      
      document.getElementById('count-0-photos').textContent = count0;
      document.getElementById('count-more-photos').textContent = countMore;
      
      if (count0 > 0 || countMore > 0) {
        document.getElementById('invalid-photos-actions').classList.remove('d-none');
      }
      
    } catch (error) {
      console.error('[Analytics] Error rendering media charts:', error);
    }
  }

  // ===== INVALID USERS MODAL =====
  
  function viewInvalidUsers(bucket) {
    const users = window.invalidPhotosUsers?.[bucket] || [];
    const bucketName = bucket === '0' ? '0 fotos' : '>9 fotos';
    
    document.getElementById('modal-bucket-name').textContent = bucketName;
    
    if (users.length === 0) {
      document.getElementById('invalid-users-list').innerHTML = '<p class="text-muted">No hay usuarios en esta categoría.</p>';
    } else {
      let html = '<div class="table-responsive"><table class="table table-striped table-hover">';
      html += '<thead><tr>';
      html += '<th>ID</th><th>Nombre</th><th>Email</th>';
      if (bucket === '>9') {
        html += '<th>Fotos</th>';
      }
      html += '<th>Acciones</th></tr></thead><tbody>';
      
      users.forEach(user => {
        html += '<tr>';
        html += `<td>${user.id}</td>`;
        html += `<td>${user.name || 'N/A'}</td>`;
        html += `<td>${user.email || 'N/A'}</td>`;
        if (bucket === '>9') {
          html += `<td><span class="badge bg-warning text-dark">${user.photo_count}</span></td>`;
        }
        html += '<td>';
        html += `<a href="/users/${user.id}" class="btn btn-sm btn-primary text-white" target="_blank" style="color: white !important;"><i class="fas fa-user-cog"></i> Gestionar perfil</a> `;
        html += `<a href="/edit_user?id=${user.id}" class="btn btn-sm btn-outline-secondary" target="_blank"><i class="fas fa-edit"></i> Editar</a>`;
        html += '</td>';
        html += '</tr>';
      });
      
      html += '</tbody></table></div>';
      document.getElementById('invalid-users-list').innerHTML = html;
    }
    
    // Show modal using Bootstrap 4
    $('#invalidUsersModal').modal('show');
  }

  // Make function globally available
  window.viewInvalidUsers = viewInvalidUsers;

  // ===== INTERESTS SECTION =====
  
  async function loadInterestsData() {
    try {
      const data = await fetchData('interests');
      if (!data) {
        console.warn('[Analytics] No data returned for interests section');
        return;
      }

      // Main Interests Distribution - Horizontal Bar Chart
      const mainInterestsData = data.main_interests || {};
      const mainInterestsLabels = Object.keys(mainInterestsData);
      const mainInterestsCounts = Object.values(mainInterestsData);
      
      renderBarChart('chart-main-interests', {
        labels: mainInterestsLabels,
        datasets: [{
          label: 'Usuarios',
          data: mainInterestsCounts,
          backgroundColor: colors.blue
        }]
      }, {
        indexAxis: 'y',
        plugins: {
          tooltip: {
            enabled: true
          },
          dataLabelsPlugin: true
        },
        scales: {
          x: {
            beginAtZero: true,
            grid: {
              color: 'rgba(0,0,0,0.05)'
            }
          },
          y: {
            grid: {
              display: false
            }
          }
        }
      });

      // Main Interests Count - Valid and Invalid
      const mainInterestsCountData = data.main_interests_count || {};
      const invalidMainData = mainInterestsCountData.invalid || {};
      const invalidMainUsers = mainInterestsCountData.invalid_users || { '<4': [], '>4': [] };
      
      // Store invalid users globally for modal access
      window.invalidMainInterestsUsers = invalidMainUsers;
      
      // Invalid Main Interests Chart
      const invalidMainLabels = ['<4 intereses', '>4 intereses'];
      const invalidMainCounts = [
        invalidMainData['<4'] || 0,
        invalidMainData['>4'] || 0
      ];
      
      renderBarChart('chart-main-interests-invalid', {
        labels: invalidMainLabels,
        datasets: [{
          label: 'Usuarios',
          data: invalidMainCounts,
          backgroundColor: colors.warning
        }]
      }, {
        plugins: {
          legend: {
            display: false
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              stepSize: 1
            }
          }
        }
      });
      
      // Update counts in buttons and show actions if there are invalid users
      const countLessMain = invalidMainData['<4'] || 0;
      const countMoreMain = invalidMainData['>4'] || 0;
      
      document.getElementById('count-less-main-interests').textContent = countLessMain;
      document.getElementById('count-more-main-interests').textContent = countMoreMain;
      
      if (countLessMain > 0 || countMoreMain > 0) {
        document.getElementById('invalid-main-interests-actions').classList.remove('d-none');
      }

      // Secondary Interests Distribution - Horizontal Bar Chart
      const secondaryInterestsData = data.secondary_interests || {};
      const secondaryInterestsLabels = Object.keys(secondaryInterestsData);
      const secondaryInterestsCounts = Object.values(secondaryInterestsData);
      
      renderBarChart('chart-secondary-interests', {
        labels: secondaryInterestsLabels,
        datasets: [{
          label: 'Usuarios',
          data: secondaryInterestsCounts,
          backgroundColor: colors.green
        }]
      }, {
        indexAxis: 'y',
        plugins: {
          tooltip: {
            enabled: true
          },
          dataLabelsPlugin: true
        },
        scales: {
          x: {
            beginAtZero: true,
            grid: {
              color: 'rgba(0,0,0,0.05)'
            }
          },
          y: {
            grid: {
              display: false
            }
          }
        }
      });

      // Secondary Interests Count Per User - Bar Chart
      const secondaryCountData = data.secondary_interests_count || {};
      const secondaryCountLabels = [];
      const secondaryCountValues = [];
      
      // Process buckets 0-10, >10
      for (let i = 0; i <= 10; i++) {
        const key = i.toString();
        const count = secondaryCountData[key] || 0;
        secondaryCountLabels.push(i === 0 ? '0' : i === 1 ? '1' : i.toString());
        secondaryCountValues.push(count);
      }
      
      const countMore10 = secondaryCountData['>10'] || 0;
      secondaryCountLabels.push('>10');
      secondaryCountValues.push(countMore10);
      
      renderBarChart('chart-secondary-interests-count', {
        labels: secondaryCountLabels,
        datasets: [{
          label: 'Usuarios',
          data: secondaryCountValues,
          backgroundColor: colors.purple
        }]
      }, {
        plugins: {
          legend: {
            display: false
          }
        }
      });
      
    } catch (error) {
      console.error('[Analytics] Error rendering interests charts:', error);
    }
  }

