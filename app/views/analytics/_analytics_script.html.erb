      html += '<th>ID</th><th>Nombre</th><th>Email</th>';
      html += '<th>Intereses</th>';
      html += '<th>Acciones</th></tr></thead><tbody>';
      
      users.forEach(user => {
        html += '<tr>';
        html += `<td>${user.id}</td>`;
        html += `<td>${user.name || 'N/A'}</td>`;
        html += `<td>${user.email || 'N/A'}</td>`;
        html += `<td><span class="badge bg-warning text-dark">${user.main_interests_count}</span></td>`;
        html += '<td>';
        html += `<a href="/users/${user.id}" class="btn btn-sm btn-primary text-white" target="_blank" style="color: white !important;"><i class="fas fa-user-cog"></i> Gestionar perfil</a> `;
        html += `<a href="/edit_user?id=${user.id}" class="btn btn-sm btn-outline-secondary" target="_blank"><i class="fas fa-edit"></i> Editar</a>`;
        html += '</td>';
        html += '</tr>';
      });
      
      html += '</tbody></table></div>';
      document.getElementById('invalid-main-interests-list').innerHTML = html;
    }
    
    // Show modal using Bootstrap 4
    $('#invalidMainInterestsModal').modal('show');
  }

  // Make function globally available
  window.viewInvalidMainInterestsUsers = viewInvalidMainInterestsUsers;

  // ===== SPOTIFY DATA =====

  async function loadSpotifyData() {
    try {
      const data = await fetchData('spotify');
      if (!data) {
        console.warn('[Analytics] No data returned for spotify section');
        return;
      }

      // --- Artist count distribution (0-10, >10) ---
      const distData = data.artists_count_distribution || {};
      const distLabels = [];
      const distValues = [];
      for (let i = 0; i <= 10; i++) {
        distLabels.push(i.toString());
        distValues.push(distData[i.toString()] || 0);
      }
      distLabels.push('>10');
      distValues.push(distData['>10'] || 0);

      renderBarChart('chart-spotify-artists-count', {
        labels: distLabels,
        datasets: [{
          label: 'Usuarios',
          data: distValues,
          backgroundColor: '#1DB954'
        }]
      }, {
        plugins: { legend: { display: false } },
        scales: {
          x: { title: { display: true, text: 'Nº de artistas' } },
          y: { beginAtZero: true, ticks: { stepSize: 1 }, title: { display: true, text: 'Usuarios' } }
        }
      });

      // --- Warning for >10 artists ---
      const over10Count = distData['>10'] || 0;
      const alertWrapper = document.getElementById('spotify-over10-alert-wrapper');
      const over10CountEl = document.getElementById('spotify-over10-count');
      if (alertWrapper) alertWrapper.style.display = over10Count > 0 ? '' : 'none';
      if (over10CountEl) over10CountEl.textContent = formatNumber(over10Count);

      // --- Top 10 artists ---
      const topArtists = data.top_artists || {};
      const artistLabels = Object.keys(topArtists);
      const artistCounts = Object.values(topArtists);
      renderHTMLBarChart('chart-top-spotify-artists', artistLabels, artistCounts, '#1DB954');

    } catch (e) {
      console.error('[Analytics] Error loading Spotify data:', e);
    }
  }

