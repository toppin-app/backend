    // Show modal using Bootstrap 4
    $('#invalidMainInterestsModal').modal('show');
  }

  // Make function globally available
  window.viewInvalidMainInterestsUsers = viewInvalidMainInterestsUsers;

  // ===== CHART RENDERING FUNCTIONS =====

  function renderLineChart(canvasId, data, options = {}) {
    destroyChart(canvasId);
    
    const ctx = document.getElementById(canvasId);
    if (!ctx) return;
    
    const defaultOptions = {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: true,
          position: 'top'
        },
        tooltip: {
          mode: 'index',
          intersect: false
        }
      },
      scales: {
        x: {
          display: true,
          grid: {
            display: false
          }
        },
        y: {
          display: true,
          beginAtZero: true,
          grid: {
            color: 'rgba(0,0,0,0.05)'
          }
        }
      }
    };
    
    charts[canvasId] = new Chart(ctx, {
      type: 'line',
      data: data,
      options: Object.assign({}, defaultOptions, options)
    });
  }

  function renderBarChart(canvasId, data, options = {}) {
    destroyChart(canvasId);
    
    const ctx = document.getElementById(canvasId);
    if (!ctx) return;
    
    const defaultOptions = {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: false
        },
        tooltip: {
          mode: 'index',
          intersect: false
        }
      },
      scales: {
        x: {
          grid: {
            display: false
          }
        },
        y: {
          beginAtZero: true,
          grid: {
            color: 'rgba(0,0,0,0.05)'
          }
        }
      }
    };
    
    // Registrar plugin personalizado si está habilitado
    const plugins = [];
    if (options.plugins && options.plugins.dataLabelsPlugin) {
      plugins.push(dataLabelsPlugin);
      delete options.plugins.dataLabelsPlugin; // Remover para no conflictuar
    }
    
    charts[canvasId] = new Chart(ctx, {
      type: 'bar',
      data: data,
      options: Object.assign({}, defaultOptions, options),
      plugins: plugins
    });
  }

  function renderPieChart(canvasId, data, options = {}) {
    destroyChart(canvasId);
    
    const ctx = document.getElementById(canvasId);
    if (!ctx) return;
    
    const defaultOptions = {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: {
          display: true,
          position: 'bottom'
        },
        tooltip: {
          callbacks: {
            label: function(context) {
              const label = context.label || '';
              const value = context.parsed || 0;
              const total = context.dataset.data.reduce((a, b) => a + b, 0);
              const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
              return `${label}: ${formatNumber(value)} (${percentage}%)`;
            }
          }
        }
      }
    };
    
    charts[canvasId] = new Chart(ctx, {
      type: 'doughnut',
      data: data,
      options: Object.assign({}, defaultOptions, options)
    });
  }

  function destroyChart(canvasId) {
    if (charts[canvasId]) {
      charts[canvasId].destroy();
      delete charts[canvasId];
    }
  }

  // Load data on page load
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize date range toggle
    const dateRangeSelect = document.getElementById('date-range');
    if (dateRangeSelect) {
      dateRangeSelect.addEventListener('change', function() {
        const customStartDiv = document.getElementById('custom-date-start');
        const customEndDiv = document.getElementById('custom-date-end');
        
        if (this.value === 'custom') {
          customStartDiv.style.display = 'block';
          customEndDiv.style.display = 'block';
        } else {
          customStartDiv.style.display = 'none';
          customEndDiv.style.display = 'none';
        }
      });
    }

    // Apply filters button
    const applyButton = document.getElementById('apply-filters');
    if (applyButton) {
      applyButton.addEventListener('click', function() {
        loadAllData();
      });
    }

    // Load initial data
    loadAllData();
  });

})();
