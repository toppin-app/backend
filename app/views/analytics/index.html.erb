    <div class="col-6 col-md-3 mb-3">
      <div class="card border-primary shadow-sm h-100">
        <div class="card-body text-center">
          <h6 class="text-muted">Matches Generados</h6>
          <h2 class="text-primary mb-0" id="metric-interactions-matches">-</h2>
        </div>
      </div>
