          <h6 class="mb-0">Distribución de Likes Recibidos por Usuario</h6>
          <small class="text-muted">Agrupación de usuarios según cuántos likes han recibido</small>
        </div>
        <div class="card-body">
          <canvas id="chart-likes-received-dist" height="80"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ===== SECCIÓN 11: MODO INVISIBLE ===== -->
<div class="analytics-section mb-5" id="section-invisible-mode">
  <div class="section-header mb-4">
    <h4 class="text-dark font-weight-bold"><i class="fas fa-eye-slash mr-2"></i>Modo Invisible</h4>
    <p class="text-muted">Distribución del uso del modo invisible entre los usuarios del conjunto analizado.</p>
  </div>

  <!-- Métricas principales -->
  <div class="row mb-4">
    <div class="col-md-4 mb-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6 class="text-muted">Modo Invisible Activado</h6>
          <h2 class="text-dark mb-0" id="metric-invisible-on">-</h2>
        </div>
      </div>
    </div>
    <div class="col-md-4 mb-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6 class="text-muted">Modo Invisible Desactivado</h6>
          <h2 class="text-success mb-0" id="metric-invisible-off">-</h2>
        </div>
      </div>
    </div>
    <div class="col-md-4 mb-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6 class="text-muted">% Usan Modo Invisible</h6>
          <h2 class="text-warning mb-0" id="metric-invisible-pct">-</h2>
        </div>
      </div>
    </div>
  </div>

  <!-- Gráficas -->
  <div class="row mb-4">
    <div class="col-md-5 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Distribución: Invisible vs. Visible</h6>
          <small class="text-muted">Proporción de usuarios con modo invisible activado</small>
        </div>
        <div class="card-body">
          <div style="position:relative; height:260px;">
            <canvas id="chart-invisible-donut"></canvas>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-7 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Uso del Modo Invisible por Género</h6>
          <small class="text-muted">Comparativa de activado vs. desactivado por género</small>
        </div>
        <div class="card-body">
          <div style="position:relative; height:260px;">
            <canvas id="chart-invisible-by-gender"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ===== SECCIÓN 12: BLOQUEOS ENTRE USUARIOS ===== -->
<div class="analytics-section mb-5" id="section-blocks">
  <div class="section-header mb-4">
    <h4 class="text-dark font-weight-bold"><i class="fas fa-ban mr-2"></i>Bloqueos entre Usuarios</h4>
    <p class="text-muted">Análisis de los bloqueos realizados entre usuarios de la plataforma.</p>
  </div>

  <!-- Métricas principales -->
  <div class="row mb-4">
    <div class="col-md-6 mb-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6 class="text-muted">Total Bloqueos</h6>
          <h2 class="text-danger mb-0" id="metric-blocks-total">-</h2>
