<!-- User Analytics Dashboard -->
<%= stylesheet_link_tag 'analytics' %>

<div class="container-fluid mt-4">
  
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <h1 class="h2 mb-3">
        <i class="fas fa-chart-area"></i> <%= @title %>
      </h1>
      <p class="text-muted">
        Análisis completo de usuarios e información de la plataforma
        <span class="badge badge-info">Última actualización: <%= Time.current.strftime("%d/%m/%Y %H:%M") %></span>
      </p>
    </div>
  </div>

  <!-- Filtros Globales -->
  <div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white">
      <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros Globales</h5>
    </div>
    <div class="card-body">
      <form id="analytics-filters-form">
        <div class="row">
          
          <!-- Rango de Fechas -->
          <div class="col-md-3 mb-3">
            <label class="font-weight-bold">Rango de Fechas</label>
            <select class="form-control" id="date-range" name="date_range">
              <option value="today">Hoy</option>
              <option value="yesterday">Ayer</option>
              <option value="last_7_days">Últimos 7 días</option>
              <option value="last_30_days">Últimos 30 días</option>
              <option value="last_90_days">Últimos 90 días</option>
              <option value="last_12_months">Últimos 12 meses</option>
              <option value="all_time" selected>Todo el tiempo</option>
              <option value="custom">Rango personalizado</option>
            </select>
          </div>

          <!-- Rango Personalizado -->
          <div class="col-md-2 mb-3" id="custom-date-start" style="display: none;">
            <label class="font-weight-bold">Fecha Inicio</label>
            <input type="date" class="form-control" name="start_date" id="start-date">
          </div>
          <div class="col-md-2 mb-3" id="custom-date-end" style="display: none;">
            <label class="font-weight-bold">Fecha Fin</label>
            <input type="date" class="form-control" name="end_date" id="end-date">
          </div>

          <!-- Filtro de Bots -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Filtro de Bots</label>
            <select class="form-control" name="bot_filter">
              <option value="exclude_bots" selected>Excluir bots</option>
              <option value="only_bots">Solo bots</option>
              <option value="include_bots">Incluir bots</option>
            </select>
          </div>

          <!-- Estado de Cuenta -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Estado de Cuenta</label>
            <select class="form-control" name="account_status">
              <option value="active" selected>Usuarios activos</option>
              <option value="deleted">Cuentas eliminadas</option>
              <option value="all">Todos los usuarios</option>
            </select>
          </div>

          <!-- Género -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Género</label>
            <select class="form-control" name="gender">
              <option value="all" selected>Todos los géneros</option>
              <option value="0">Mujer</option>
              <option value="1">Hombre</option>
              <option value="2">No binario</option>
              <option value="3">Pareja</option>
            </select>
          </div>

        </div>

        <div class="row">
          
          <!-- Plataforma -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Plataforma</label>
            <select class="form-control" name="device_platform">
              <option value="all" selected>Todas las plataformas</option>
              <option value="ios">iOS</option>
              <option value="android">Android</option>
            </select>
          </div>

          <!-- Tipo de Suscripción -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Suscripción</label>
            <select class="form-control" name="subscription_type">
              <option value="all" selected>Todos los tipos</option>
              <option value="free">Gratis</option>
              <option value="premium">Premium</option>
              <option value="supreme">Supreme</option>
            </select>
          </div>

          <!-- País -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">País</label>
            <select class="form-control" name="country">
              <option value="all" selected>Todos los países</option>
              <% @countries.each do |country| %>
                <option value="<%= country %>"><%= country %></option>
              <% end %>
            </select>
          </div>

          <!-- Ciudad -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Ciudad</label>
            <select class="form-control" name="city">
              <option value="all" selected>Todas las ciudades</option>
              <% @cities.first(100).each do |city| %>
                <option value="<%= city %>"><%= city %></option>
              <% end %>
            </select>
          </div>

          <!-- Estado de Verificación -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Verificación</label>
            <select class="form-control" name="verified">
              <option value="all" selected>Todos los usuarios</option>
              <option value="verified">Solo verificados</option>
              <option value="non_verified">No verificados</option>
            </select>
          </div>

          <!-- Botón Aplicar -->
          <div class="col-md-2 mb-3 d-flex align-items-end">
            <button type="button" id="apply-filters" class="btn btn-primary btn-block">
              <i class="fas fa-sync"></i> Aplicar Filtros
            </button>
          </div>

        </div>
      </form>
    </div>
  </div>

  <!-- Métricas Clave -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card border-primary shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Usuarios Totales</h6>
          <h2 class="text-primary mb-0" id="metric-total-users"><%= number_with_delimiter(@key_metrics[:total_users]) %></h2>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-success shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Matches Totales</h6>
          <h2 class="text-success mb-0" id="metric-total-matches"><%= number_with_delimiter(@key_metrics[:total_matches]) %></h2>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-warning shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Activos Hoy</h6>
          <h2 class="text-warning mb-0" id="metric-active-today"><%= number_with_delimiter(@key_metrics[:active_users_today]) %></h2>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-info shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Ingresos Totales</h6>
          <h2 class="text-info mb-0" id="metric-total-revenue">€<%= number_with_delimiter(@key_metrics[:total_revenue].to_f.round(2)) %></h2>
        </div>
      </div>
    </div>
  </div>

  <!-- Indicador de Carga -->
  <div id="loading-indicator" class="text-center py-5" style="display: none;">
    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
      <span class="sr-only">Cargando...</span>
    </div>
    <p class="mt-3 text-muted">Cargando datos de análisis...</p>
  </div>

  <!-- Sección 1: Crecimiento -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-chart-line text-success"></i> Crecimiento de Usuarios</h3>
    <div class="row">
      
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Nuevos Usuarios en el Tiempo</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-new-users" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Crecimiento Acumulado de Usuarios</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-cumulative-users" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución de Tipos de Usuario</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-users-by-type" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Verificados vs No Verificados</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-verified" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Eliminación de Cuentas</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-deletions" height="120"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Sección 2: Engagement -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-heart text-danger"></i> Engagement de Usuarios</h3>
    
    <!-- Tarjetas de Métricas de Engagement -->
    <div class="row mb-3">
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">DAU</small>
            <h4 id="metric-dau">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">WAU</small>
            <h4 id="metric-wau">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">MAU</small>
            <h4 id="metric-mau">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Ratio DAU/MAU</small>
            <h4 id="metric-stickiness">-</h4>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Usuarios Activos Diarios</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-dau" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Likes Enviados en el Tiempo</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-likes-sent" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Matches Creados en el Tiempo</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-matches-created" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Métricas Promedio de Engagement</h6>
          </div>
          <div class="card-body">
            <div id="engagement-stats">
              <p><strong>Promedio de Matches por Usuario:</strong> <span id="avg-matches">-</span></p>
              <p><strong>Promedio de Likes Recibidos:</strong> <span id="avg-likes">-</span></p>
              <p><strong>Ratio Promedio de Likes:</strong> <span id="avg-ratio">-</span></p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Sección 3: Demografía -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-users text-info"></i> Demografía</h3>
    <div class="row">
      
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución por Género</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-gender" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-8 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución por Edad</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-age" height="100"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Principales Países</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-countries" height="100"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Principales Ciudades</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-cities" height="100"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Sección 4: Sistema de Matching -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-star text-warning"></i> Sistema de Matching</h3>
    
    <!-- Métricas de Match -->
    <div class="row mb-3">
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Likes Totales</small>
            <h4 id="metric-total-likes">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Superlikes Totales</small>
            <h4 id="metric-total-superlikes">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Conversión de Match</small>
            <h4 id="metric-match-conversion">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Conversión de Superlike</small>
            <h4 id="metric-superlike-conversion">-</h4>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución de Matches por Usuario</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-matches-distribution" height="60"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sección 5: Retención -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-sync text-primary"></i> Retención y Churn</h3>
    
    <!-- Métricas de Churn -->
    <div class="row mb-3">
      <div class="col-md-4">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Tasa de Churn</small>
            <h4 id="metric-churn-rate">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Usuarios con Churn</small>
            <h4 id="metric-churned-users">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Usuarios Activos</small>
            <h4 id="metric-retention-active">-</h4>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Cohortes de Retención (Últimos 6 Meses)</h6>
          </div>
          <div class="card-body">
            <div id="retention-cohorts-table" class="table-responsive">
              <!-- Será llenado por JavaScript -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sección 6: Principales Insights -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-trophy text-warning"></i> Principales Insights</h3>
    <div class="row">
      
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top Usuarios por Matches</h6>
          </div>
          <div class="card-body">
            <div id="top-matches-list" class="small">
              <!-- Será llenado por JavaScript -->
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Usuarios Más Gustados</h6>
          </div>
          <div class="card-body">
            <div id="top-liked-list" class="small">
              <!-- Será llenado por JavaScript -->
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top Ciudades por Engagement</h6>
          </div>
          <div class="card-body">
            <div id="top-cities-list" class="small">
              <!-- Será llenado por JavaScript -->
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

<%= javascript_tag do %>
  <%= render 'analytics_script' %>
<% end %>
