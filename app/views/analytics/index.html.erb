    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Distribución de Bloqueos Dados por Usuario</h6>
          <small class="text-muted">Agrupación de usuarios según cuántos bloqueos han realizado</small>
        </div>
        <div class="card-body">
          <canvas id="chart-blocks-given-dist" height="80"></canvas>
        </div>
      </div>
    </div>
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Distribución de Bloqueos Recibidos por Usuario</h6>
          <small class="text-muted">Agrupación de usuarios según cuántos bloqueos han recibido</small>
        </div>
        <div class="card-body">
          <canvas id="chart-blocks-received-dist" height="80"></canvas>
        </div>
      </div>
