  </div>

  <!-- Evolución temporal -->
  <div class="row">
    <div class="col-12 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Evolución de Interacciones en el Tiempo (por semana)</h6>
          <small class="text-muted">Likes, superlikes y dislikes enviados por los usuarios filtrados</small>
        </div>
        <div class="card-body">
          <canvas id="chart-interactions-over-time" height="60"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Interacciones por género + tasa de match -->
  <div class="row">
    <div class="col-md-7 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Interacciones Dadas por Género</h6>
          <small class="text-muted">Likes, superlikes y dislikes enviados según género del remitente</small>
        </div>
        <div class="card-body p-2">
          <div style="position:relative; height:240px;">
            <canvas id="chart-interactions-by-gender"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-5 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Tasa de Match por Género</h6>
          <small class="text-muted">% de likes que se convierten en match, por género del emisor</small>
        </div>
        <div class="card-body">
          <canvas id="chart-interactions-match-rate" height="140"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Distribuciones -->
  <div class="row">
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
