<!-- User Analytics Dashboard -->
<%= stylesheet_link_tag 'analytics' %>

<div class="container-fluid mt-4">
  
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <h1 class="h2 mb-3">
        <i class="fas fa-chart-area"></i> <%= @title %>
      </h1>
      <p class="text-muted">
        Análisis completo de usuarios e información de la plataforma
        <span class="badge badge-info">Última actualización: <%= Time.current.strftime("%d/%m/%Y %H:%M") %></span>
      </p>
    </div>
  </div>

  <!-- Filtros Globales -->
  <div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white">
      <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros Globales</h5>
    </div>
    <div class="card-body">
      <form id="analytics-filters-form">
        <div class="row">
          
          <!-- Rango de Fechas -->
          <div class="col-md-3 mb-3">
            <label class="font-weight-bold">Rango de Fechas</label>
            <select class="form-control" id="date-range" name="date_range">
              <option value="today">Hoy</option>
              <option value="yesterday">Ayer</option>
              <option value="last_7_days">Últimos 7 días</option>
              <option value="last_30_days">Últimos 30 días</option>
              <option value="last_90_days">Últimos 90 días</option>
              <option value="last_12_months">Últimos 12 meses</option>
              <option value="all_time" selected>Todo el tiempo</option>
              <option value="custom">Rango personalizado</option>
            </select>
          </div>

          <!-- Rango Personalizado -->
          <div class="col-md-2 mb-3" id="custom-date-start" style="display: none;">
            <label class="font-weight-bold">Fecha Inicio</label>
            <input type="date" class="form-control" name="start_date" id="start-date">
          </div>
          <div class="col-md-2 mb-3" id="custom-date-end" style="display: none;">
            <label class="font-weight-bold">Fecha Fin</label>
            <input type="date" class="form-control" name="end_date" id="end-date">
          </div>

          <!-- Filtro de Bots -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Filtro de Bots</label>
            <select class="form-control" name="bot_filter">
              <option value="exclude_bots" selected>Excluir bots</option>
              <option value="only_bots">Solo bots</option>
              <option value="include_bots">Incluir bots</option>
            </select>
          </div>

          <!-- Estado de Cuenta -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Estado de Cuenta</label>
            <select class="form-control" name="account_status">
              <option value="active" selected>Usuarios activos</option>
              <option value="deleted">Cuentas eliminadas</option>
              <option value="all">Todos los usuarios</option>
            </select>
          </div>

          <!-- Género -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Género</label>
            <select class="form-control" name="gender">
              <option value="all" selected>Todos los géneros</option>
              <option value="0">Mujer</option>
              <option value="1">Hombre</option>
              <option value="2">No binario</option>
              <option value="3">Pareja</option>
            </select>
          </div>

        </div>

        <div class="row">
          
          <!-- Plataforma -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Plataforma</label>
            <select class="form-control" name="device_platform">
              <option value="all" selected>Todas las plataformas</option>
              <option value="ios">iOS</option>
              <option value="android">Android</option>
            </select>
          </div>

          <!-- Tipo de Suscripción -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Suscripción</label>
            <select class="form-control" name="subscription_type">
              <option value="all" selected>Todos los tipos</option>
              <option value="free">Gratis</option>
              <option value="premium">Premium</option>
              <option value="supreme">Supreme</option>
            </select>
          </div>

          <!-- País -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">País</label>
            <select class="form-control" name="country">
              <option value="all" selected>Todos los países</option>
              <% @countries.each do |country| %>
                <option value="<%= country %>"><%= country %></option>
              <% end %>
            </select>
          </div>

          <!-- Ciudad -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Ciudad</label>
            <select class="form-control" name="city">
              <option value="all" selected>Todas las ciudades</option>
              <% @cities.first(100).each do |city| %>
                <option value="<%= city %>"><%= city %></option>
              <% end %>
            </select>
          </div>

          <!-- Estado de Verificación -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Verificación</label>
            <select class="form-control" name="verified">
              <option value="all" selected>Todos los usuarios</option>
              <option value="verified">Solo verificados</option>
              <option value="non_verified">No verificados</option>
            </select>
          </div>

          <!-- Botón Aplicar -->
          <div class="col-md-2 mb-3 d-flex align-items-end">
            <button type="button" id="apply-filters" class="btn btn-primary btn-block">
              <i class="fas fa-sync"></i> Aplicar Filtros
            </button>
          </div>

        </div>
      </form>
    </div>
  </div>

  <!-- Métricas Clave -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card border-primary shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Usuarios Totales</h6>
          <h2 class="text-primary mb-0" id="metric-total-users"><%= number_with_delimiter(@key_metrics[:total_users]) %></h2>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-success shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Matches Totales</h6>
          <h2 class="text-success mb-0" id="metric-total-matches"><%= number_with_delimiter(@key_metrics[:total_matches]) %></h2>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-warning shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Activos Hoy</h6>
          <h2 class="text-warning mb-0" id="metric-active-today"><%= number_with_delimiter(@key_metrics[:active_users_today]) %></h2>
        </div>
      </div>
    </div>
  </div>

  <!-- Indicador de Carga -->
  <div id="loading-indicator" class="text-center py-5" style="display: none;">
    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
      <span class="sr-only">Cargando...</span>
    </div>
    <p class="mt-3 text-muted">Cargando datos de análisis...</p>
  </div>

  <!-- Sección 1: Crecimiento -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-chart-line text-success"></i> Crecimiento de Usuarios</h3>
    <div class="row">
      
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Nuevos Usuarios en el Tiempo</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-new-users" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Crecimiento Acumulado de Usuarios</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-cumulative-users" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución de Tipos de Usuario</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-users-by-type" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Verificados vs No Verificados</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-verified" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Eliminación de Cuentas</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-deletions" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución de Niveles de Suscripción</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-subscription" height="120"></canvas>
          </div>
        </div>
      </div>

    </div>

    <!-- Correlaciones de suscripción y verificación -->
    <div class="row">

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Suscripción × Género</h6>
            <small class="text-muted">Distribución de géneros dentro de cada nivel de suscripción</small>
          </div>
          <div class="card-body">
            <canvas id="chart-subscription-by-gender" height="140"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Suscripción × Verificación</h6>
            <small class="text-muted">Usuarios verificados y no verificados por nivel de suscripción</small>
          </div>
          <div class="card-body">
            <canvas id="chart-subscription-by-verified" height="140"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Verificación × Género</h6>
            <small class="text-muted">Géneros dentro de usuarios verificados y no verificados</small>
          </div>
          <div class="card-body">
            <canvas id="chart-verified-by-gender" height="140"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Sección 2: Demografía -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-users text-info"></i> Demografía</h3>
    <div class="row">
      
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución por Género</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-gender" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-8 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución por Edad</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-age" height="100"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Principales Países</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-countries" height="100"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Principales Ciudades</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-cities" height="100"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Sección 3: Principales Insights -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-trophy text-warning"></i> Principales Insights</h3>
    <div class="row">
      
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top Usuarios por Matches</h6>
          </div>
          <div class="card-body">
            <div id="top-matches-list" class="small">
              <!-- Será llenado por JavaScript -->
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Usuarios Más Gustados</h6>
          </div>
          <div class="card-body">
            <div id="top-liked-list" class="small">
              <!-- Será llenado por JavaScript -->
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top Ciudades por Engagement</h6>
          </div>
          <div class="card-body">
            <div id="top-cities-list" class="small">
              <!-- Será llenado por JavaScript -->
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Sección 4: Series y Películas -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-film text-danger"></i> Series y Películas</h3>
    
    <div class="row">
      <!-- Top 20 Series -->
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top 20 Series Más Comunes</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-top-series" height="400"></canvas>
          </div>
        </div>
      </div>

      <!-- Top 20 Películas -->
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top 20 Películas Más Comunes</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-top-movies" height="400"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sección 5: Distribución de Fotos por Usuario -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-camera text-info"></i> Distribución de Fotos por Usuario</h3>
    
    <!-- Gráfica Principal: Valores Válidos (1-9 fotos) -->
    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Rango Válido: 1-9 Fotos</h6>
            <small class="text-muted">Distribución esperada del sistema</small>
          </div>
          <div class="card-body">
            <canvas id="chart-photos-valid" height="80"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Gráfica Secundaria: Casos Problemáticos (0 y >9 fotos) -->
    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm border-warning">
          <div class="card-header" style="background-color: #fff3cd;">
            <h6 class="mb-0 text-dark">
              <i class="fas fa-exclamation-triangle text-warning"></i> Usuarios que requieren revisión (número de fotos inválido)
            </h6>
            <small class="text-muted">Usuarios con 0 fotos o más de 9 fotos</small>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-8">
                <canvas id="chart-photos-invalid" height="60"></canvas>
              </div>
              <div class="col-md-4" id="invalid-photos-actions-container">
                <div id="invalid-photos-actions" class="d-none h-100 d-flex flex-column justify-content-center">
                  <button class="btn btn-sm btn-warning text-dark mb-2" onclick="viewInvalidUsers('0')">
                    <i class="fas fa-users"></i> Ver usuarios con 0 fotos (<span id="count-0-photos">0</span>)
                  </button>
                  <button class="btn btn-sm btn-warning text-dark" onclick="viewInvalidUsers('>9')">
                    <i class="fas fa-users"></i> Ver usuarios con >9 fotos (<span id="count-more-photos">0</span>)
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Sección 6: Intereses de Usuarios -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-heart text-danger"></i> Intereses de Usuarios</h3>
    
    <!-- Gráfica: Distribución de Intereses Principales -->
    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución de Intereses Principales</h6>
            <small class="text-muted">Intereses principales más comunes entre usuarios</small>
          </div>
          <div class="card-body p-0" style="overflow-x: auto;">
            <div id="chart-main-interests-wrapper" style="position: relative; width: 100%;">
              <div id="chart-main-interests"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Gráfica de Alerta: Usuarios con Número Inválido de Intereses Principales -->
    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm border-warning">
          <div class="card-header" style="background-color: #fff3cd;">
            <h6 class="mb-0 text-dark">
              <i class="fas fa-exclamation-triangle text-warning"></i> Usuarios con número inválido de intereses principales
            </h6>
            <small class="text-muted">Los usuarios deben tener exactamente 4 intereses principales</small>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-8">
                <canvas id="chart-main-interests-invalid" height="60"></canvas>
              </div>
              <div class="col-md-4" id="invalid-main-interests-actions-container">
                <div id="invalid-main-interests-actions" class="d-none h-100 d-flex flex-column justify-content-center">
                  <button class="btn btn-sm btn-warning text-dark mb-2" onclick="viewInvalidMainInterestsUsers('<4')">
                    <i class="fas fa-users"></i> Ver usuarios con <4 intereses (<span id="count-less-main-interests">0</span>)
                  </button>
                  <button class="btn btn-sm btn-warning text-dark" onclick="viewInvalidMainInterestsUsers('>4')">
                    <i class="fas fa-users"></i> Ver usuarios con >4 intereses (<span id="count-more-main-interests">0</span>)
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Gráfica: Distribución de Intereses Secundarios -->
    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución de Intereses Secundarios</h6>
            <small class="text-muted">Intereses secundarios más comunes entre usuarios</small>
          </div>
          <div class="card-body p-0" style="overflow-x: auto;">
            <div id="chart-secondary-interests-wrapper" style="position: relative; width: 100%;">
              <div id="chart-secondary-interests"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Gráfica: Número de Intereses Secundarios por Usuario -->
    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Distribución del Número de Intereses Secundarios por Usuario</h6>
            <small class="text-muted">Cuántos usuarios tienen X número de intereses secundarios</small>
          </div>
          <div class="card-body">
            <canvas id="chart-secondary-interests-count" height="80"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Modal para inspeccionar usuarios con intereses principales inválidos -->
<div class="modal fade" id="invalidMainInterestsModal" tabindex="-1" role="dialog" aria-labelledby="invalidMainInterestsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header" style="background-color: #fff3cd;">
        <h5 class="modal-title text-dark" id="invalidMainInterestsModalLabel">
          <i class="fas fa-exclamation-triangle text-warning"></i> 
          Usuarios con <span id="modal-main-interests-bucket-name"></span>
        </h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div id="invalid-main-interests-list">
          <!-- Contenido dinámico -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<!-- Sección 7: Spotify -->
<div class="analytics-section mb-5">
  <h3 class="mb-3"><i class="fab fa-spotify text-success"></i> Spotify</h3>

  <div class="row">
    <!-- Distribución de artistas por usuario -->
    <div class="col-12 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Distribución de Artistas de Spotify por Usuario</h6>
          <small class="text-muted">Cuántos artistas tiene guardados cada usuario (0–10, &gt;10)</small>
        </div>
        <div class="card-body">
          <canvas id="chart-spotify-artists-count" height="100"></canvas>
        </div>
      </div>
    </div>

    <!-- Alerta usuarios con >10 artistas -->
    <div class="col-12 mb-4" id="spotify-over10-alert-wrapper" style="display:none;">
      <div class="card shadow-sm border-warning">
        <div class="card-header" style="background-color: #fff3cd;">
          <h6 class="mb-0 text-dark">
            <i class="fas fa-exclamation-triangle text-warning"></i>
            Usuarios con más de 10 artistas de Spotify
          </h6>
        </div>
        <div class="card-body">
          <p class="mb-0">
            Hay <strong id="spotify-over10-count">0</strong> usuario(s) con más de 10 artistas de Spotify guardados.
          </p>
        </div>
      </div>
    </div>

    <!-- Top 10 artistas más comunes -->
    <div class="col-12 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Top 10 Artistas de Spotify más Guardados</h6>
          <small class="text-muted">Artistas más populares entre los usuarios</small>
        </div>
        <div class="card-body">
          <div id="chart-top-spotify-artists"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal para inspeccionar usuarios con fotos inválidas -->
<div class="modal fade" id="invalidUsersModal" tabindex="-1" role="dialog" aria-labelledby="invalidUsersModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header" style="background-color: #fff3cd;">
        <h5 class="modal-title text-dark" id="invalidUsersModalLabel">
          <i class="fas fa-exclamation-triangle text-warning"></i> 
          Usuarios con <span id="modal-bucket-name"></span>
        </h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div id="invalid-users-list">
          <!-- Contenido dinámico -->
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<!-- Sección 8: Idiomas -->
<div class="analytics-section mb-5">
  <h3 class="mb-3"><i class="fas fa-language text-primary"></i> Idiomas</h3>

  <div class="row">
    <!-- Distribución de idioma configurado en la app -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Idioma Configurado en la App por los Usuarios</h6>
          <small class="text-muted">Idioma que el usuario tiene seleccionado como idioma principal de la aplicación (también usado para push notifications)</small>
        </div>
        <div class="card-body">
          <canvas id="chart-app-language" height="120"></canvas>
        </div>
      </div>
    </div>

    <!-- Distribución de idiomas del perfil -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Idiomas Guardados en el Perfil de los Usuarios</h6>
          <small class="text-muted">Idiomas que los usuarios declaran hablar y muestran a otros usuarios en su perfil</small>
        </div>
        <div class="card-body p-0" style="overflow-x: auto;">
          <div id="chart-profile-languages"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Distribución de cantidad de idiomas en el perfil -->
    <div class="col-md-12 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Distribución de Cantidad de Idiomas Guardados por Usuario</h6>
          <small class="text-muted">Cuántos idiomas tiene guardados cada usuario en su perfil</small>
        </div>
        <div class="card-body">
          <canvas id="chart-profile-languages-count" height="80"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sección 9: Denuncias -->
<div class="analytics-section mb-5">
  <h3 class="mb-3"><i class="fas fa-flag text-danger"></i> Denuncias</h3>

  <!-- Métricas rápidas -->
  <div class="row mb-3">
    <div class="col-md-3">
      <div class="card border-danger shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Total de Denuncias</h6>
          <h2 class="text-danger mb-0" id="metric-complaints-total">-</h2>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Evolución temporal -->
    <div class="col-md-8 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Evolución de Denuncias en el Tiempo (por semana)</h6>
        </div>
        <div class="card-body">
          <canvas id="chart-complaints-over-time" height="80"></canvas>
        </div>
      </div>
    </div>

    <!-- Promedio denuncias recibidas por género -->
    <div class="col-md-4 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Promedio de Denuncias Recibidas por Género</h6>
          <small class="text-muted">Media de denuncias recibidas por usuario según su género</small>
        </div>
        <div class="card-body">
          <canvas id="chart-complaints-avg-by-gender" height="120"></canvas>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Género del denunciante -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Denuncias por Género del Denunciante</h6>
          <small class="text-muted">¿Qué géneros denuncian más?</small>
        </div>
        <div class="card-body">
          <canvas id="chart-complaints-reporter-gender" height="120"></canvas>
        </div>
      </div>
    </div>

    <!-- Género del denunciado -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Denuncias por Género del Denunciado</h6>
          <small class="text-muted">¿Qué géneros reciben más denuncias?</small>
        </div>
        <div class="card-body">
          <canvas id="chart-complaints-reported-gender" height="120"></canvas>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Matriz género × género -->
    <div class="col-12 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Correlación Género Denunciante × Denunciado</h6>
          <small class="text-muted">Combinaciones de género que más generan denuncias</small>
        </div>
        <div class="card-body p-2">
          <div id="chart-complaints-gender-matrix"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <!-- Distribución denuncias realizadas -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Distribución de Denuncias Realizadas por Usuario</h6>
          <small class="text-muted">Cuántas denuncias ha enviado cada usuario</small>
        </div>
        <div class="card-body">
          <canvas id="chart-complaints-made-dist" height="80"></canvas>
        </div>
      </div>
    </div>

    <!-- Distribución denuncias recibidas -->
    <div class="col-md-6 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Distribución de Denuncias Recibidas por Usuario</h6>
          <small class="text-muted">Cuántas denuncias ha recibido cada usuario</small>
        </div>
        <div class="card-body">
          <canvas id="chart-complaints-received-dist" height="80"></canvas>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Sección 9b: Tipo de Denuncia × Géneros -->
<div class="analytics-section mb-5" id="section-complaints-type">
  <div class="section-header mb-4">
    <h4 class="font-weight-bold">Correlación Tipo de Denuncia × Género</h4>
    <p class="text-muted">Distribución de tipos de denuncia cruzada con el género del denunciante y del denunciado</p>
  </div>

  <!-- Row 1: by type total + by type × reporter gender -->
  <div class="row">
    <div class="col-md-5 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Total por Tipo de Denuncia</h6>
          <small class="text-muted">Frecuencia de cada motivo de denuncia</small>
        </div>
        <div class="card-body">
          <div id="chart-complaints-by-type"></div>
        </div>
      </div>
    </div>

    <div class="col-md-7 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Tipos de Denuncia por Género del Denunciante</h6>
          <small class="text-muted">Comparativa de motivos según quién denuncia</small>
        </div>
        <div class="card-body p-2">
          <div style="position:relative; height:260px;">
            <canvas id="chart-complaints-type-reporter-gender"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Row 2: by type × reported gender + full matrix tables -->
  <div class="row">
    <div class="col-md-7 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Tipos de Denuncia por Género del Denunciado</h6>
          <small class="text-muted">Comparativa de motivos según quién recibe la denuncia</small>
        </div>
        <div class="card-body p-2">
          <div style="position:relative; height:260px;">
            <canvas id="chart-complaints-type-reported-gender"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-5 mb-4">
      <div class="card shadow-sm">
        <div class="card-header bg-light">
          <h6 class="mb-0">Matriz: Denunciante × Denunciado × Tipo</h6>
          <small class="text-muted">Distribución de motivos por cada combinación de géneros</small>
        </div>
        <div class="card-body" style="overflow-x:auto; max-height:340px; overflow-y:auto;">
          <div id="chart-complaints-type-matrix">
            <p class="text-muted text-center mt-3">Cargando datos...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

<!-- Sección 10: Interacciones (Likes / Superlikes / Dislikes) -->
<div class="analytics-section mb-5" id="section-interactions">
  <div class="section-header mb-4">
    <h4 class="font-weight-bold"><i class="fas fa-heart text-danger mr-2"></i>Interacciones — Likes, Superlikes y Dislikes</h4>
    <p class="text-muted">Análisis de las interacciones enviadas por los usuarios filtrados</p>
  </div>

  <!-- Metric cards -->
  <div class="row mb-3">
    <div class="col-6 col-md-3 mb-3">
      <div class="card border-success shadow-sm h-100">
        <div class="card-body text-center">
          <h6 class="text-muted">Likes Dados</h6>
          <h2 class="text-success mb-0" id="metric-likes-total">-</h2>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3 mb-3">
      <div class="card border-warning shadow-sm h-100">
        <div class="card-body text-center">
          <h6 class="text-muted">Superlikes Dados</h6>
          <h2 class="text-warning mb-0" id="metric-superlikes-total">-</h2>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-3 mb-3">
      <div class="card border-danger shadow-sm h-100">
        <div class="card-body text-center">
          <h6 class="text-muted">Dislikes Dados</h6>
          <h2 class="text-danger mb-0" id="metric-dislikes-total">-</h2>
        </div>
