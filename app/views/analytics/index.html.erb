<!-- User Analytics Dashboard -->
<%= stylesheet_link_tag 'analytics' %>

<div class="container-fluid mt-4">
  
  <!-- Header -->
  <div class="row mb-4">
    <div class="col-12">
      <h1 class="h2 mb-3">
        <i class="fas fa-chart-area"></i> <%= @title %>
      </h1>
      <p class="text-muted">
        Comprehensive user analytics and platform insights
        <span class="badge badge-info">Last updated: <%= Time.current.strftime("%d/%m/%Y %H:%M") %></span>
      </p>
    </div>
  </div>

  <!-- Global Filters -->
  <div class="card mb-4 shadow-sm">
    <div class="card-header bg-primary text-white">
      <h5 class="mb-0"><i class="fas fa-filter"></i> Global Filters</h5>
    </div>
    <div class="card-body">
      <form id="analytics-filters-form">
        <div class="row">
          
          <!-- Date Range -->
          <div class="col-md-3 mb-3">
            <label class="font-weight-bold">Date Range</label>
            <select class="form-control" id="date-range" name="date_range">
              <option value="today">Today</option>
              <option value="yesterday">Yesterday</option>
              <option value="last_7_days">Last 7 days</option>
              <option value="last_30_days">Last 30 days</option>
              <option value="last_90_days">Last 90 days</option>
              <option value="last_12_months">Last 12 months</option>
              <option value="all_time" selected>All time</option>
              <option value="custom">Custom range</option>
            </select>
          </div>

          <!-- Custom Date Range -->
          <div class="col-md-2 mb-3" id="custom-date-start" style="display: none;">
            <label class="font-weight-bold">Start Date</label>
            <input type="date" class="form-control" name="start_date" id="start-date">
          </div>
          <div class="col-md-2 mb-3" id="custom-date-end" style="display: none;">
            <label class="font-weight-bold">End Date</label>
            <input type="date" class="form-control" name="end_date" id="end-date">
          </div>

          <!-- Bot Filter -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Bot Filter</label>
            <select class="form-control" name="bot_filter">
              <option value="exclude_bots" selected>Exclude bots</option>
              <option value="only_bots">Only bots</option>
              <option value="include_bots">Include bots</option>
            </select>
          </div>

          <!-- Account Status -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Account Status</label>
            <select class="form-control" name="account_status">
              <option value="active" selected>Active users</option>
              <option value="deleted">Deleted accounts</option>
              <option value="all">All users</option>
            </select>
          </div>

          <!-- Gender -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Gender</label>
            <select class="form-control" name="gender">
              <option value="all" selected>All genders</option>
              <option value="0">Female</option>
              <option value="1">Male</option>
              <option value="2">Non binary</option>
              <option value="3">Couple</option>
            </select>
          </div>

        </div>

        <div class="row">
          
          <!-- Device Platform -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Device Platform</label>
            <select class="form-control" name="device_platform">
              <option value="all" selected>All platforms</option>
              <option value="ios">iOS</option>
              <option value="android">Android</option>
            </select>
          </div>

          <!-- Subscription Type -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Subscription</label>
            <select class="form-control" name="subscription_type">
              <option value="all" selected>All types</option>
              <option value="free">Free</option>
              <option value="premium">Premium</option>
              <option value="supreme">Supreme</option>
            </select>
          </div>

          <!-- Country -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Country</label>
            <select class="form-control" name="country">
              <option value="all" selected>All countries</option>
              <% @countries.each do |country| %>
                <option value="<%= country %>"><%= country %></option>
              <% end %>
            </select>
          </div>

          <!-- City -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">City</label>
            <select class="form-control" name="city">
              <option value="all" selected>All cities</option>
              <% @cities.first(100).each do |city| %>
                <option value="<%= city %>"><%= city %></option>
              <% end %>
            </select>
          </div>

          <!-- Verification Status -->
          <div class="col-md-2 mb-3">
            <label class="font-weight-bold">Verification</label>
            <select class="form-control" name="verified">
              <option value="all" selected>All users</option>
              <option value="verified">Verified only</option>
              <option value="non_verified">Non-verified</option>
            </select>
          </div>

          <!-- Apply Button -->
          <div class="col-md-2 mb-3 d-flex align-items-end">
            <button type="button" id="apply-filters" class="btn btn-primary btn-block">
              <i class="fas fa-sync"></i> Apply Filters
            </button>
          </div>

        </div>
      </form>
    </div>
  </div>

  <!-- Key Metrics Row -->
  <div class="row mb-4">
    <div class="col-md-3">
      <div class="card border-primary shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Total Users</h6>
          <h2 class="text-primary mb-0" id="metric-total-users"><%= number_with_delimiter(@key_metrics[:total_users]) %></h2>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-success shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Total Matches</h6>
          <h2 class="text-success mb-0" id="metric-total-matches"><%= number_with_delimiter(@key_metrics[:total_matches]) %></h2>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-warning shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Active Today</h6>
          <h2 class="text-warning mb-0" id="metric-active-today"><%= number_with_delimiter(@key_metrics[:active_users_today]) %></h2>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-info shadow-sm">
        <div class="card-body text-center">
          <h6 class="text-muted">Total Revenue</h6>
          <h2 class="text-info mb-0" id="metric-total-revenue">€<%= number_with_delimiter(@key_metrics[:total_revenue].to_f.round(2)) %></h2>
        </div>
      </div>
    </div>
  </div>

  <!-- Loading Indicator -->
  <div id="loading-indicator" class="text-center py-5" style="display: none;">
    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
      <span class="sr-only">Loading...</span>
    </div>
    <p class="mt-3 text-muted">Loading analytics data...</p>
  </div>

  <!-- Section 1: Growth -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-chart-line text-success"></i> User Growth</h3>
    <div class="row">
      
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">New Users Over Time</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-new-users" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Cumulative User Growth</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-cumulative-users" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">User Types Distribution</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-users-by-type" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Verified vs Non-Verified</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-verified" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Account Deletions</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-deletions" height="120"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Section 2: Engagement -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-heart text-danger"></i> User Engagement</h3>
    
    <!-- Engagement Metrics Cards -->
    <div class="row mb-3">
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">DAU</small>
            <h4 id="metric-dau">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">WAU</small>
            <h4 id="metric-wau">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">MAU</small>
            <h4 id="metric-mau">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">DAU/MAU Ratio</small>
            <h4 id="metric-stickiness">-</h4>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Daily Active Users</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-dau" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Likes Sent Over Time</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-likes-sent" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Matches Created Over Time</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-matches-created" height="80"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Average Engagement Metrics</h6>
          </div>
          <div class="card-body">
            <div id="engagement-stats">
              <p><strong>Avg Matches per User:</strong> <span id="avg-matches">-</span></p>
              <p><strong>Avg Likes Received:</strong> <span id="avg-likes">-</span></p>
              <p><strong>Avg Like Ratio:</strong> <span id="avg-ratio">-</span></p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Section 3: Demographics -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-users text-info"></i> Demographics</h3>
    <div class="row">
      
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Gender Distribution</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-gender" height="120"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-8 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Age Distribution</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-age" height="100"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top Countries</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-countries" height="100"></canvas>
          </div>
        </div>
      </div>

      <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top Cities</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-cities" height="100"></canvas>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Section 4: Matching System -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-star text-warning"></i> Matching System</h3>
    
    <!-- Match Metrics -->
    <div class="row mb-3">
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Total Likes</small>
            <h4 id="metric-total-likes">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Total Superlikes</small>
            <h4 id="metric-total-superlikes">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Match Conversion</small>
            <h4 id="metric-match-conversion">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Superlike Conversion</small>
            <h4 id="metric-superlike-conversion">-</h4>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Matches per User Distribution</h6>
          </div>
          <div class="card-body">
            <canvas id="chart-matches-distribution" height="60"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 5: Retention -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-sync text-primary"></i> Retention & Churn</h3>
    
    <!-- Churn Metrics -->
    <div class="row mb-3">
      <div class="col-md-4">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Churn Rate</small>
            <h4 id="metric-churn-rate">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Churned Users</small>
            <h4 id="metric-churned-users">-</h4>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-light">
          <div class="card-body text-center">
            <small class="text-muted">Active Users</small>
            <h4 id="metric-retention-active">-</h4>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-12 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Retention Cohorts (Last 6 Months)</h6>
          </div>
          <div class="card-body">
            <div id="retention-cohorts-table" class="table-responsive">
              <!-- Will be populated by JavaScript -->
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Section 6: Top Insights -->
  <div class="analytics-section mb-5">
    <h3 class="mb-3"><i class="fas fa-trophy text-warning"></i> Top Insights</h3>
    <div class="row">
      
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top Users by Matches</h6>
          </div>
          <div class="card-body">
            <div id="top-matches-list" class="small">
              <!-- Will be populated by JavaScript -->
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Most Liked Users</h6>
          </div>
          <div class="card-body">
            <div id="top-liked-list" class="small">
              <!-- Will be populated by JavaScript -->
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card shadow-sm">
          <div class="card-header bg-light">
            <h6 class="mb-0">Top Cities by Engagement</h6>
          </div>
          <div class="card-body">
            <div id="top-cities-list" class="small">
              <!-- Will be populated by JavaScript -->
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

</div>

<!-- Include Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>

<%= javascript_tag do %>
  <%= render 'analytics_script' %>
<% end %>
