<style>
  /* Estilos modernos y responsivos para la gestión de usuarios fake */
  .fake-user-card {
    background: white;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    padding: 20px;
    margin-bottom: 20px;
    transition: all 0.3s ease;
    border-left: 4px solid #667eea;
    position: relative;
    cursor: pointer;
  }
  
  .fake-user-card:hover {
    box-shadow: 0 6px 20px rgba(102, 126, 234, 0.3);
    transform: translateY(-3px);
  }
  
  .fake-user-card.selected {
    background: linear-gradient(135deg, rgba(102, 126, 234, 0.05) 0%, rgba(118, 75, 162, 0.05) 100%);
    border-left-width: 6px;
  }
  
  .user-selection-checkbox {
    position: absolute;
    top: 65px;
    right: 50%;
    transform: translateX(50%);
    width: 32px;
    height: 32px;
    cursor: pointer;
    z-index: 10;
  }
  
  .user-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
    margin-top: 15px;
  }
  
  .info-item {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  
  .info-label {
    font-size: 11px;
    text-transform: uppercase;
    color: #667eea;
    font-weight: 600;
    letter-spacing: 0.5px;
  }
  
  .info-value {
    font-size: 14px;
    color: #333;
    font-weight: 500;
  }
  
  .user-header {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 10px;
  }
  
  .user-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #667eea;
  }
  
  .user-avatar-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 24px;
    font-weight: bold;
  }
  
  .user-name-email {
    flex: 1;
  }
  
  .user-name {
    font-size: 18px;
    font-weight: 700;
    color: #333;
    margin: 0;
  }
  
  .user-email {
    font-size: 13px;
    color: #666;
    margin: 2px 0 0 0;
  }
  
  .user-id-badge {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 4px 10px;
    border-radius: 15px;
    font-size: 11px;
    font-weight: 600;
  }
  
  .bulk-actions-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 15px 20px;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.3);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: space-between;
  }
  
  .bulk-actions-bar.show {
    display: flex;
  }
  
  .selected-count {
    font-size: 16px;
    font-weight: 600;
  }
  
  .form-check-input:hover {
    cursor: pointer !important;
    border-color: #667eea !important;
    box-shadow: 0 0 8px rgba(102, 126, 234, 0.4) !important;
  }
  
  .form-check-label:hover {
    cursor: pointer !important;
    color: #667eea !important;
  }
  
  select.form-select {
    cursor: pointer !important;
    border: 2px solid #dee2e6;
    border-radius: 8px;
    transition: all 0.3s ease;
  }
  
  select.form-select:hover {
    border-color: #667eea !important;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.25) !important;
  }
  
  @media (max-width: 768px) {
    .user-info-grid {
      grid-template-columns: 1fr;
    }
    
    .bulk-actions-bar {
      flex-direction: column;
      gap: 10px;
      align-items: stretch;
    }
    
    .bulk-actions-bar .btn {
      width: 100%;
    }
  }
</style>

<div style="margin-bottom: 20px;">
  <h2 style="color: #667eea; margin-bottom: 10px;">
    <i class="fas fa-robot"></i> Gestión de Usuarios Fake (BOT)
  </h2>
  <p style="color: #666;">
    Administra y configura los usuarios bot del sistema. Puedes seleccionar múltiples usuarios para realizar cambios masivos.
  </p>
</div>

<!-- Filtros de búsqueda -->
<div class="card shadow-sm" style="margin-bottom: 25px;">
  <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
    <h5 class="mb-0"><i class="fa fa-filter"></i> Filtros de búsqueda</h5>
  </div>
  <div class="card-body">
    <%= search_form_for @q, url: fake_users_path do |f| %>
      <%= hidden_field_tag :per_page, params[:per_page] if params[:per_page].present? %>
      <%= hidden_field_tag :custom_per_page, params[:custom_per_page] if params[:custom_per_page].present? %>

      <!-- Búsqueda principal -->
      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label"><i class="fa fa-search"></i> <strong>Buscar usuario</strong></label>
          <div class="input-group">
            <%= f.search_field :email_or_name_cont, value: @search, class: 'form-control', placeholder: "Email o nombre del usuario" %>
            <button type="submit" class="btn btn-primary">
              <i class="fa fa-search"></i> Buscar
            </button>
          </div>
        </div>

        <div class="col-md-6">
          <label class="form-label"><i class="fa fa-calendar"></i> <strong>Fecha de registro</strong></label>
          <div class="row">
            <div class="col-6">
              <label class="form-label" style="font-size: 12px;">Desde</label>
              <%= f.date_field :created_at_gteq, class: 'form-control' %>
            </div>
            <div class="col-6">
              <label class="form-label" style="font-size: 12px;">Hasta</label>
              <%= f.date_field :created_at_lteq, class: 'form-control' %>
            </div>
          </div>
        </div>
      </div>

      <!-- Filtros de ubicación -->
      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label"><i class="fa fa-map-marker-alt"></i> <strong>Ubicación</strong></label>
          <div class="row">
            <div class="col-6">
              <%= f.select :location_country_eq, 
                  options_for_select([['Todos los países', '']] + @countries.map { |c| [c, c] }, params.dig(:q, :location_country_eq)), 
                  {}, 
                  { class: 'form-select', onchange: 'this.form.submit();' } %>
            </div>
            <div class="col-6">
              <%= f.select :location_city_eq, 
                  options_for_select([['Todas las ciudades', '']] + @cities.map { |c| [c, c] }, params.dig(:q, :location_city_eq)), 
                  {}, 
                  { class: 'form-select', onchange: 'this.form.submit();' } %>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <label class="form-label"><i class="fa fa-venus-mars"></i> <strong>Género</strong></label>
          <%= f.select :gender_eq, 
              options_for_select([
                ['Todos los géneros', ''],
                ['👩 Mujer', 0],
                ['👨 Hombre', 1],
                ['⚧ No binario', 2],
                ['👫 Pareja', 3]
              ], params.dig(:q, :gender_eq)), 
              {}, 
              { class: 'form-select', onchange: 'this.form.submit();' } %>
        </div>
      </div>

      <!-- Ordenar por -->
      <div class="row mb-3">
        <div class="col-md-12">
          <label class="form-label"><i class="fa fa-sort"></i> <strong>Ordenar por</strong></label>
          <div class="d-flex flex-wrap" style="gap: 8px;">
            <%= sort_link(@q, :created_at, '<i class="fa fa-calendar"></i> Fecha de registro'.html_safe, 
                { per_page: params[:per_page], custom_per_page: params[:custom_per_page], show_blocked_users: params[:show_blocked_users] }, 
                { class: 'btn btn-outline-secondary btn-sm' }) %>
            <%= sort_link(@q, :name, '<i class="fa fa-font"></i> Nombre'.html_safe, 
                { per_page: params[:per_page], custom_per_page: params[:custom_per_page], show_blocked_users: params[:show_blocked_users] }, 
                { class: 'btn btn-outline-secondary btn-sm' }) %>
            <%= sort_link(@q, :email, '<i class="fa fa-envelope"></i> Email'.html_safe, 
                { per_page: params[:per_page], custom_per_page: params[:custom_per_page], show_blocked_users: params[:show_blocked_users] }, 
                { class: 'btn btn-outline-secondary btn-sm' }) %>
            <%= sort_link(@q, :id, '<i class="fa fa-hashtag"></i> ID'.html_safe, 
                { per_page: params[:per_page], custom_per_page: params[:custom_per_page], show_blocked_users: params[:show_blocked_users] }, 
                { class: 'btn btn-outline-secondary btn-sm' }) %>
          </div>
        </div>
      </div>

      <!-- Filtros adicionales -->
      <div class="row mb-3">
        <div class="col-md-12">
          <label class="form-label"><i class="fa fa-filter"></i> <strong>Filtros adicionales</strong></label>
          <div class="d-flex flex-wrap align-items-center" style="gap: 20px;">
            <div class="form-check form-switch d-flex align-items-center" style="margin: 0;">
              <%= check_box_tag :show_blocked_users, '1', @show_blocked_users, 
                  onclick: "this.form.submit();", 
                  class: 'form-check-input',
                  style: 'margin-top: 0;',
                  id: 'show_blocked_users_checkbox' %>
              <%= label_tag :show_blocked_users, '🚫 Solo bloqueados', class: 'form-check-label', style: 'margin-left: 8px; margin-bottom: 0;' %>
            </div>
          </div>
        </div>
      </div>

      <!-- Botón limpiar filtros -->
      <div class="row mb-3">
        <div class="col-md-12 text-end">
          <%= link_to fake_users_path, method: 'get', class: 'btn btn-outline-danger' do %>
            <i class="fa fa-times"></i> Limpiar todos los filtros
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Acciones de selección -->
<div class="card shadow-sm" style="margin-bottom: 25px;">
  <div class="card-body">
    <div class="row">
      <div class="col-md-12">
        <label class="form-label"><strong>Acciones de selección</strong></label>
        <div style="display: flex; flex-direction: column; gap: 10px; align-items: flex-start;">
          <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAll()" style="min-width: 200px;">
            <i class="fa fa-check-square"></i> Seleccionar todos
          </button>
          <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deselectAll()" style="min-width: 200px;">
            <i class="fa fa-square"></i> Deseleccionar todos
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Lista de usuarios fake en tarjetas -->
<div class="row">
  <div class="col-12">
    <% if @users.any? %>
      <div id="fake-users-container">
        <% @users.each do |user| %>
          <div class="fake-user-card" data-user-id="<%= user.id %>" onclick="toggleCardSelection(event, this)">
            <input type="checkbox" 
                   class="user-selection-checkbox form-check-input" 
                   data-user-id="<%= user.id %>"
                   onchange="updateSelectionCount()"
                   onclick="event.stopPropagation()">
            
            <div class="user-header">
              <% if user.user_media.any? && user.user_media.first.file.present? %>
                <%= image_tag user.user_media.first.file.url, class: 'user-avatar' %>
              <% else %>
                <div class="user-avatar-placeholder">
                  <%= user.name.present? ? user.name[0].upcase : '?' %>
                </div>
              <% end %>
              
              <div class="user-name-email">
                <h3 class="user-name"><%= user.name || 'Sin nombre' %></h3>
                <p class="user-email"><%= user.email %></p>
              </div>
              
              <span class="user-id-badge">ID: <%= user.id %></span>
            </div>
            
            <div class="user-info-grid">
              <div class="info-item">
                <span class="info-label"><i class="fa fa-venus-mars"></i> Género</span>
                <span class="info-value">
                  <% case user.gender %>
                  <% when 'female' %>
                    👩 Mujer
                  <% when 'male' %>
                    👨 Hombre
                  <% when 'non_binary' %>
                    ⚧ No binario
                  <% when 'couple' %>
                    👫 Pareja
                  <% else %>
                    Sin especificar
                  <% end %>
                </span>
              </div>
              
              <div class="info-item">
                <span class="info-label"><i class="fa fa-calendar"></i> Fecha nacimiento</span>
                <span class="info-value"><%= user.birthday ? user.birthday.strftime('%d/%m/%Y') : 'No especificada' %></span>
              </div>
              
              <div class="info-item">
                <span class="info-label"><i class="fa fa-map-marker-alt"></i> Ubicación</span>
                <span class="info-value">
                  <%= user.location_city.present? ? user.location_city : '-' %>, 
                  <%= user.location_country.present? ? user.location_country : '-' %>
                </span>
              </div>
              
              <div class="info-item">
                <span class="info-label"><i class="fa fa-map-pin"></i> Coordenadas</span>
                <span class="info-value">
                  <%= user.lat.present? && user.lng.present? ? "#{user.lat}, #{user.lng}" : 'Sin coordenadas' %>
                </span>
              </div>
              
              <div class="info-item">
                <span class="info-label"><i class="fa fa-calendar-plus"></i> Registrado</span>
                <span class="info-value"><%= user.created_at.strftime('%d/%m/%Y %H:%M') %></span>
              </div>
              
              <div class="info-item">
                <span class="info-label"><i class="fa fa-sign-in-alt"></i> Último acceso</span>
                <span class="info-value">
                  <%= user.last_sign_in_at ? user.last_sign_in_at.strftime('%d/%m/%Y %H:%M') : 'Nunca' %>
                </span>
              </div>
              
              <div class="info-item">
                <span class="info-label"><i class="fa fa-info-circle"></i> Estado</span>
                <span class="info-value">
                  <% if user.blocked %>
                    <span style="color: red;">🚫 Bloqueado</span>
                  <% else %>
                    <span style="color: green;">✅ Activo</span>
                  <% end %>
                </span>
              </div>
              
              <div class="info-item">
                <span class="info-label"><i class="fa fa-eye"></i> Acciones</span>
                <span class="info-value">
                  <%= link_to show_user_path(user.id), class: 'btn btn-sm btn-success', style: 'color: white !important;', target: '_blank', onclick: 'event.stopPropagation();' do %>
                    <i class="fa fa-eye" style="color: white !important;"></i> Ver detalles
                  <% end %>
                </span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
      
      <!-- Espacio inferior para la barra flotante -->
      <div style="margin-top: 30px; margin-bottom: 80px;"></div>
    <% else %>
      <div class="alert alert-info" role="alert">
        <i class="fa fa-info-circle"></i> No se encontraron usuarios fake con los filtros especificados.
      </div>
    <% end %>
  </div>
</div>

<!-- Barra de acciones masivas (fija en la parte inferior) -->
<div class="bulk-actions-bar" id="bulkActionsBar">
  <div class="selected-count">
    <i class="fa fa-check-square"></i> 
    <span id="selectedCount">0</span> usuario(s) seleccionado(s)
  </div>
  <div style="display: flex; gap: 10px;">
    <button type="button" class="btn btn-light" onclick="openLocationModal()">
      <i class="fa fa-map-marker-alt"></i> Cambiar ubicación
    </button>
    <button type="button" class="btn btn-outline-light" onclick="deselectAll()">
      <i class="fa fa-times"></i> Cancelar
    </button>
  </div>
</div>

<!-- Modal para cambio de ubicación masivo -->
<div class="modal fade" id="locationModal" tabindex="-1" aria-labelledby="locationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
        <h5 class="modal-title" id="locationModalLabel">
          <i class="fa fa-map-marker-alt"></i> Cambiar ubicación masiva
        </h5>
        <button type="button" class="btn-close" onclick="closeLocationModal()" aria-label="Close" style="filter: brightness(0) invert(1); font-size: 24px; opacity: 1;">×</button>
      </div>
      
      <%= form_with url: bulk_update_location_fake_users_path, method: :post, id: 'bulkLocationForm' do |f| %>
        <div class="modal-body">
          <div id="selectedUsersList" style="margin-bottom: 20px; padding: 15px; background: #f8f9fa; border-radius: 8px;">
            <!-- Se llenará dinámicamente con JavaScript -->
          </div>
          
          <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 15px; border-radius: 8px; margin-bottom: 15px;">
            <strong style="color: white; display: block; margin-bottom: 10px; font-size: 14px;">🌍 Ubicaciones rápidas:</strong> 
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
              <button type="button" onclick="setModalLocation('39.4699', '-0.3763', 'Valencia', 'España'); return false;" class="btn btn-sm btn-light">📍 Valencia</button>
              <button type="button" onclick="setModalLocation('40.4168', '-3.7038', 'Madrid', 'España'); return false;" class="btn btn-sm btn-light">📍 Madrid</button>
              <button type="button" onclick="setModalLocation('41.3851', '2.1734', 'Barcelona', 'España'); return false;" class="btn btn-sm btn-light">📍 Barcelona</button>
              <button type="button" onclick="setModalLocation('37.3891', '-5.9845', 'Sevilla', 'España'); return false;" class="btn btn-sm btn-light">📍 Sevilla</button>
              <button type="button" onclick="setModalLocation('43.2630', '-2.9350', 'Bilbao', 'España'); return false;" class="btn btn-sm btn-light">📍 Bilbao</button>
              <button type="button" onclick="setModalLocation('36.7213', '-4.4214', 'Málaga', 'España'); return false;" class="btn btn-sm btn-light">📍 Málaga</button>
            </div>
          </div>
          
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label class="form-label"><strong>Latitud</strong></label>
                <%= text_field_tag :lat, '', class: 'form-control', placeholder: 'Ej: 39.4699', id: 'modal_lat', required: true %>
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label class="form-label"><strong>Longitud</strong></label>
                <%= text_field_tag :lng, '', class: 'form-control', placeholder: 'Ej: -0.3763', id: 'modal_lng', required: true %>
              </div>
            </div>
          </div>
          
          <div class="row">
            <div class="col-md-6">
              <div class="mb-3">
                <label class="form-label"><strong>Ciudad</strong></label>
                <%= text_field_tag :location_city, '', class: 'form-control', placeholder: 'Ej: Valencia', id: 'modal_location_city', required: true %>
              </div>
            </div>
            <div class="col-md-6">
              <div class="mb-3">
                <label class="form-label"><strong>País</strong></label>
                <%= text_field_tag :location_country, '', class: 'form-control', placeholder: 'Ej: España', id: 'modal_location_country', required: true %>
              </div>
            </div>
          </div>
        </div>
        
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" onclick="closeLocationModal()">
            <i class="fa fa-times"></i> Cancelar
          </button>
          <button type="submit" class="btn btn-primary">
            <i class="fa fa-check"></i> Actualizar ubicación
          </button>
        </div>
      <% end %>
    </div>
  </div>
</div>

<script>
  function updateSelectionCount() {
    const checkboxes = document.querySelectorAll('.user-selection-checkbox:checked');
    const count = checkboxes.length;
    const bulkBar = document.getElementById('bulkActionsBar');
    const countSpan = document.getElementById('selectedCount');
    
    countSpan.textContent = count;
    
    if (count > 0) {
      bulkBar.classList.add('show');
    } else {
      bulkBar.classList.remove('show');
    }
    
    // Actualizar clases de las tarjetas
    document.querySelectorAll('.fake-user-card').forEach(card => {
      const checkbox = card.querySelector('.user-selection-checkbox');
      if (checkbox && checkbox.checked) {
        card.classList.add('selected');
      } else {
        card.classList.remove('selected');
      }
    });
  }
  
  function selectAll() {
    document.querySelectorAll('.user-selection-checkbox').forEach(checkbox => {
      checkbox.checked = true;
    });
    updateSelectionCount();
  }
  
  function deselectAll() {
    document.querySelectorAll('.user-selection-checkbox').forEach(checkbox => {
      checkbox.checked = false;
    });
    updateSelectionCount();
  }
  
  function openLocationModal() {
    const checkboxes = document.querySelectorAll('.user-selection-checkbox:checked');
    const userIds = Array.from(checkboxes).map(cb => cb.dataset.userId);
    
    if (userIds.length === 0) {
      alert('Por favor selecciona al menos un usuario');
      return;
    }
    
    // Mostrar lista de usuarios seleccionados
    const usersList = document.getElementById('selectedUsersList');
    usersList.innerHTML = `
      <strong>Usuarios seleccionados (${userIds.length}):</strong>
      <div style="margin-top: 10px; max-height: 150px; overflow-y: auto;">
        ${userIds.map(id => {
          const card = document.querySelector(`.fake-user-card[data-user-id="${id}"]`);
          const name = card.querySelector('.user-name').textContent;
          const email = card.querySelector('.user-email').textContent;
          return `
            <div style="padding: 5px 0; border-bottom: 1px solid #dee2e6;">
              <strong>${name}</strong> (${email})
            </div>
          `;
        }).join('')}
      </div>
    `;
    
    // Agregar campos ocultos con los IDs
    const form = document.getElementById('bulkLocationForm');
    // Remover campos antiguos
    form.querySelectorAll('input[name="user_ids[]"]').forEach(input => input.remove());
    // Agregar nuevos campos
    userIds.forEach(id => {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = 'user_ids[]';
      input.value = id;
      form.appendChild(input);
    });
    
    // Abrir modal
    const modal = new bootstrap.Modal(document.getElementById('locationModal'));
    modal.show();
  }
  
  function setModalLocation(lat, lng, city, country) {
    document.getElementById('modal_lat').value = lat;
    document.getElementById('modal_lng').value = lng;
    document.getElementById('modal_location_city').value = city;
    document.getElementById('modal_location_country').value = country;
  }
  
  function closeLocationModal() {
    const modal = bootstrap.Modal.getInstance(document.getElementById('locationModal'));
    if (modal) {
      modal.hide();
    }
  }
  
  function toggleCardSelection(event, card) {
    // No hacer nada si se hizo clic en un botón, link o input
    if (event.target.closest('a, button, input')) {
      return;
    }
    
    const checkbox = card.querySelector('.user-selection-checkbox');
    if (checkbox) {
      checkbox.checked = !checkbox.checked;
      updateSelectionCount();
    }
  }
</script>
