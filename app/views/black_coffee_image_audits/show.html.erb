<style>
  .image-audit-card {
    border: 0;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
  }

  .image-audit-label {
    color: #64748b;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .image-audit-value {
    color: #1f2937;
    font-size: 28px;
    font-weight: 800;
    line-height: 1;
  }

  .image-audit-report {
    background: #0f172a;
    border: 0;
    border-radius: 12px;
    color: #dbeafe;
    font-family: Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    min-height: 220px;
  }

  .image-audit-url {
    max-width: 420px;
    overflow-wrap: anywhere;
  }

  @media (max-width: 767px) {
    .image-audit-actions {
      display: grid;
      gap: 8px;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .image-audit-actions .btn,
    .image-audit-actions input[type="submit"] {
      min-height: 44px;
      width: 100%;
    }

    .image-audit-table thead {
      display: none;
    }

    .image-audit-table,
    .image-audit-table tbody,
    .image-audit-table tr,
    .image-audit-table td {
      display: block;
      width: 100%;
    }

    .image-audit-table tr {
      border-bottom: 1px solid #e5e7eb;
      padding: 12px 0;
    }

    .image-audit-table td {
      border-top: 0;
      padding: 6px 12px;
    }

    .image-audit-table td::before {
      color: #64748b;
      content: attr(data-label);
      display: block;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.06em;
      margin-bottom: 2px;
      text-transform: uppercase;
    }
  }
</style>

<% report_lines = @failed_items.map do |item|
     [
       "venue_id=#{item.venue_id}",
       "local=#{item.venue_name}",
       "fallo=#{item.error_type_label}",
       "http=#{item.http_status.presence || 'n/a'}",
       "mensaje=#{item.error_message}",
       "url=#{item.image_url.presence || 'sin_url'}"
     ].join(' | ')
   end %>

<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Imagenes</p>
    <h2 class="mb-0">Auditoria de imagenes #<%= @batch.id %></h2>
    <p class="text-muted mb-0">Ping de imagenes de locales pendientes y reporte de fallos para revision.</p>
  </div>
  <div class="image-audit-actions mt-3 mt-md-0">
    <%= link_to 'Volver a auditorias', black_coffee_image_audits_path, class: 'btn btn-outline-secondary mr-2' %>
    <%= link_to 'Revision de locales', black_coffee_reviews_path, class: 'btn btn-outline-primary' %>
  </div>
</div>

<% if @batch.error_message.present? %>
  <div class="alert alert-danger">
    <strong>La auditoria encontro un error interno:</strong>
    <%= @batch.error_message %>
  </div>
<% end %>

<div class="row mb-4">
  <div class="col-6 col-lg-2 mb-3">
    <div class="card image-audit-card h-100">
      <div class="card-body">
        <div class="image-audit-label">Estado</div>
        <span class="badge badge-<%= @batch.status_badge_class %> p-2 mt-2"><%= @batch.status_label %></span>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-2 mb-3">
    <div class="card image-audit-card h-100">
      <div class="card-body">
        <div class="image-audit-label">Locales</div>
        <div class="image-audit-value"><%= number_with_delimiter(@batch.processed_venues) %>/<%= number_with_delimiter(@batch.total_venues) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-2 mb-3">
    <div class="card image-audit-card h-100">
      <div class="card-body">
        <div class="image-audit-label">Imagenes</div>
        <div class="image-audit-value"><%= number_with_delimiter(@batch.checked_images) %>/<%= number_with_delimiter(@batch.total_images) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-2 mb-3">
    <div class="card image-audit-card h-100">
      <div class="card-body">
        <div class="image-audit-label">Locales con fallo</div>
        <div class="image-audit-value text-danger"><%= number_with_delimiter(@batch.failed_venues_count) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-2 mb-3">
    <div class="card image-audit-card h-100">
      <div class="card-body">
        <div class="image-audit-label">Imagenes con fallo</div>
        <div class="image-audit-value text-danger"><%= number_with_delimiter(@batch.failed_images_count) %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-2 mb-3">
    <div class="card image-audit-card h-100">
      <div class="card-body">
        <div class="image-audit-label">Rechazados</div>
        <div class="image-audit-value"><%= number_with_delimiter(@batch.rejected_venues_count) %></div>
      </div>
    </div>
  </div>
</div>

<div class="card image-audit-card mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
      <div class="mb-3 mb-md-0">
        <h4 class="mb-1">Progreso de comprobacion</h4>
        <p class="text-muted mb-0">
          Se comprueba con HEAD y solo se usa GET parcial si el servidor bloquea HEAD.
        </p>
      </div>
      <div class="image-audit-actions">
        <% unless @batch.finished? %>
          <%= form_with url: advance_black_coffee_image_audit_path(@batch), method: :post, local: true, class: 'd-inline-block mr-2' do %>
            <div class="input-group">
              <%= number_field_tag :limit,
                                   BlackCoffeePendingImageAuditRunner::DEFAULT_LIMIT,
                                   min: 1,
                                   max: BlackCoffeePendingImageAuditRunner::MAX_LIMIT,
                                   class: 'form-control',
                                   style: 'max-width: 110px;' %>
              <div class="input-group-append">
                <%= submit_tag 'Procesar siguiente bloque', class: 'btn btn-primary text-white' %>
              </div>
            </div>
          <% end %>
        <% end %>

        <%= form_with url: reject_failed_black_coffee_image_audit_path(@batch), method: :post, local: true, class: 'd-inline-block' do %>
          <%= submit_tag 'Rechazar locales con fallos',
                         class: 'btn btn-danger text-white',
                         disabled: @batch.failed_venues_count.to_i.zero? || @batch.rejected? || @batch.pending_checks?,
                         data: { confirm: "Se marcaran #{@batch.failed_venues_count} locales pendientes como rechazados con motivo Fotos incorrectas o muy malas. Esta accion no borra locales. Continuar?" } %>
        <% end %>
      </div>
    </div>
    <div class="progress" style="height: 18px;">
      <div class="progress-bar bg-info"
           role="progressbar"
           style="width: <%= @batch.progress_percentage %>%;"
           aria-valuenow="<%= @batch.progress_percentage %>"
           aria-valuemin="0"
           aria-valuemax="100">
        <%= @batch.progress_percentage %>%
      </div>
    </div>
    <p class="text-muted small mt-2 mb-0">
      Para aplicar rechazos primero termina todos los checks. Solo se rechazaran locales que sigan en estado pendiente.
    </p>
  </div>
</div>

<div class="row">
  <div class="col-lg-4 mb-4">
    <div class="card image-audit-card h-100">
      <div class="card-header bg-white">
        <h4 class="mb-0">Tipos de fallo</h4>
      </div>
      <div class="card-body">
        <% if @error_breakdown.any? %>
          <% @error_breakdown.each do |error_type, count| %>
            <div class="d-flex justify-content-between align-items-center border-bottom py-2">
              <div>
                <strong><%= BlackCoffeeImageAuditItem::ERROR_TYPE_LABELS[error_type.to_s] || error_type %></strong>
                <div class="text-muted small"><%= error_type.presence || 'sin_detalle' %></div>
              </div>
              <span class="badge badge-danger p-2"><%= number_with_delimiter(count) %></span>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted mb-0">Todavia no hay fallos detectados.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-8 mb-4">
    <div class="card image-audit-card h-100">
      <div class="card-header bg-white">
        <h4 class="mb-0">Reporte rapido para diagnostico</h4>
      </div>
      <div class="card-body">
        <p class="text-muted">
          Muestra hasta 200 fallos para poder revisar patrones de URL, HTTP o proveedor.
        </p>
        <%= text_area_tag :image_audit_report,
                          report_lines.join("\n"),
                          class: 'form-control image-audit-report',
                          readonly: true,
                          rows: 10,
                          placeholder: 'El reporte aparecera aqui cuando existan fallos.' %>
      </div>
    </div>
  </div>
</div>

<div class="card image-audit-card">
  <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center">
    <h4 class="mb-0">Imagenes con problemas</h4>
    <span class="text-muted small">Mostrando maximo 200 filas</span>
  </div>
  <div class="table-responsive">
    <table class="table table-hover mb-0 image-audit-table">
      <thead>
        <tr>
          <th>Local</th>
          <th>Fallo</th>
          <th>HTTP</th>
          <th>Mensaje</th>
          <th>URL</th>
          <th>Fecha</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if @failed_items.any? %>
          <% @failed_items.each do |item| %>
            <tr>
              <td data-label="Local">
                <strong><%= item.venue_name %></strong>
                <div class="text-muted small">ID: <%= item.venue_id %></div>
              </td>
              <td data-label="Fallo">
                <span class="badge badge-danger p-2"><%= item.error_type_label %></span>
              </td>
              <td data-label="HTTP"><%= item.http_status.presence || 'n/a' %></td>
              <td data-label="Mensaje"><%= item.error_message.presence || 'Sin mensaje' %></td>
              <td data-label="URL" class="image-audit-url">
                <% if item.image_url.present? %>
                  <%= link_to truncate(item.image_url, length: 80), item.image_url, target: '_blank', rel: 'noopener' %>
                <% else %>
                  <span class="text-muted">Sin URL</span>
                <% end %>
              </td>
              <td data-label="Fecha"><%= item.checked_at&.strftime('%d/%m/%Y %H:%M') || '-' %></td>
              <td data-label="Acciones" class="text-right">
                <%= link_to 'Ver local', black_coffee_venue_path(item.venue_id), class: 'btn btn-sm btn-outline-primary' %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="7" class="text-center text-muted py-5">No hay imagenes fallidas registradas en esta auditoria.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
