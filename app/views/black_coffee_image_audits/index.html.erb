<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Imagenes</p>
    <h2 class="mb-0">Auditoria de imagenes pendientes</h2>
    <p class="text-muted mb-0">Comprueba imagenes de locales pendientes y separa los que tienen problemas.</p>
  </div>
  <div class="mt-3 mt-md-0">
    <%= link_to 'Volver a revision', black_coffee_reviews_path, class: 'btn btn-outline-secondary mr-2' %>
    <%= link_to 'Locales', black_coffee_venues_path, class: 'btn btn-outline-dark' %>
  </div>
</div>

<div class="alert alert-warning">
  <strong>Herramienta de revision no destructiva.</strong>
  Esta auditoria no borra locales. Solo comprueba URLs de imagen de locales con
  <span class="badge badge-warning">Pendiente</span> y luego permite marcarlos como
  <span class="badge badge-danger">Rechazado</span> con motivo <strong>Fotos incorrectas o muy malas</strong>.
  Las URLs temporales de Google Places se detectan sin hacer peticiones de red para evitar gasto recurrente.
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body d-flex flex-wrap justify-content-between align-items-center">
    <div class="mb-3 mb-md-0">
      <div class="text-muted text-uppercase font-weight-bold">Locales pendientes actuales</div>
      <div class="display-4 font-weight-bold mb-0"><%= number_with_delimiter(@pending_venues_count) %></div>
      <div class="text-muted">Solo estos entraran en una nueva auditoria.</div>
    </div>
    <%= form_with url: black_coffee_image_audits_path, method: :post, local: true do %>
      <%= submit_tag 'Crear auditoria de imagenes',
                     class: 'btn btn-danger btn-lg text-white',
                     data: { confirm: "Se creara una auditoria para #{@pending_venues_count} locales pendientes. Continuar?" } %>
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-header bg-white">
    <h4 class="mb-0">Procesos recientes de imagenes</h4>
    <p class="text-muted mb-0">
      Incluye auditorias de imagenes e internalizaciones, para que tambien veas procesos completados, cancelados o iniciados desde la herramienta de conversion.
    </p>
  </div>
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>#</th>
          <th>Tipo</th>
          <th>Estado</th>
          <th>Progreso</th>
          <th>Locales con fallo</th>
          <th>Imagenes con fallo</th>
          <th>Rechazados</th>
          <th>Fecha</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if @recent_image_processes.any? %>
          <% @recent_image_processes.each do |process| %>
            <tr>
              <td><strong>#<%= process[:id] %></strong></td>
              <td><span class="badge badge-light border p-2"><%= process[:type] %></span></td>
              <td><span class="badge badge-<%= process[:badge_class] %> p-2"><%= process[:status_label] %></span></td>
              <td>
                <strong><%= process[:progress_percentage] %>%</strong>
                <div class="text-muted small"><%= number_with_delimiter(process[:processed]) %>/<%= number_with_delimiter(process[:total]) %> <%= process[:unit] %></div>
              </td>
              <td class="text-danger"><%= number_with_delimiter(process[:failed_venues_count]) %></td>
              <td class="text-danger"><%= number_with_delimiter(process[:failed_images_count]) %></td>
              <td><%= process[:rejected_venues_count].nil? ? '-' : number_with_delimiter(process[:rejected_venues_count]) %></td>
              <td><%= process[:created_at].strftime('%d/%m/%Y %H:%M') %></td>
              <td class="text-right">
                <%= link_to process[:action_label], process[:path], class: 'btn btn-sm btn-outline-primary' %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="text-center text-muted py-5">Todavia no hay procesos de imagenes.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
