<style>
  .black-coffee-image-card {
    border: 0;
    border-radius: 18px;
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
  }

  .black-coffee-image-label {
    color: #64748b;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .black-coffee-image-value {
    color: #1f2937;
    font-size: 42px;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .black-coffee-image-tool {
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    height: 100%;
    padding: 22px;
  }

  .black-coffee-image-tool-warning {
    background: #fffbeb;
    border-color: #facc15;
  }

  .black-coffee-image-tool-info {
    background: #ecfeff;
    border-color: #67e8f9;
  }

  .black-coffee-image-tool-title {
    color: #111827;
    font-size: 24px;
    font-weight: 800;
    line-height: 1.1;
  }

  .black-coffee-image-tool-copy {
    color: #4b5563;
    font-size: 15px;
    line-height: 1.45;
  }

  .black-coffee-image-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
  }

  @media (max-width: 767px) {
    .black-coffee-image-actions {
      display: grid;
      grid-template-columns: 1fr;
      width: 100%;
    }

    .black-coffee-image-actions .btn,
    .black-coffee-image-actions input[type="submit"] {
      min-height: 44px;
      width: 100%;
    }

    .black-coffee-image-value {
      font-size: 34px;
    }

    .black-coffee-image-table thead {
      display: none;
    }

    .black-coffee-image-table,
    .black-coffee-image-table tbody,
    .black-coffee-image-table tr,
    .black-coffee-image-table td {
      display: block;
      width: 100%;
    }

    .black-coffee-image-table tr {
      border-bottom: 1px solid #e5e7eb;
      padding: 12px 0;
    }

    .black-coffee-image-table td {
      border-top: 0;
      padding: 6px 12px;
    }

    .black-coffee-image-table td::before {
      color: #64748b;
      content: attr(data-label);
      display: block;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.06em;
      margin-bottom: 2px;
      text-transform: uppercase;
    }
  }
</style>

<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Imagenes</p>
    <h2 class="mb-0">Herramientas de imagenes Black Coffee</h2>
    <p class="text-muted mb-0">Audita imagenes pendientes e internaliza links externos desde un unico panel.</p>
  </div>
  <div class="black-coffee-image-actions mt-3 mt-md-0">
    <%= link_to 'Volver a revision', black_coffee_reviews_path, class: 'btn btn-outline-secondary mr-2' %>
    <%= link_to 'Locales', black_coffee_venues_path, class: 'btn btn-outline-dark' %>
  </div>
</div>

<div class="card black-coffee-image-card mb-4">
  <div class="card-header bg-white">
    <h4 class="mb-0">Acciones de imagenes</h4>
    <p class="text-muted mb-0">Son herramientas distintas, pero ahora quedan agrupadas para reducir ruido visual. Cada una conserva su flujo interno actual.</p>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-lg-6 mb-3 mb-lg-0">
        <div class="black-coffee-image-tool black-coffee-image-tool-warning">
          <div class="black-coffee-image-label mb-2">Revision no destructiva</div>
          <h3 class="black-coffee-image-tool-title mb-2">Auditar imagenes pendientes</h3>
          <p class="black-coffee-image-tool-copy">
            Comprueba URLs de imagen de locales en estado <span class="badge badge-warning">Pendiente</span> y permite rechazarlos luego con motivo <strong>Fotos incorrectas o muy malas</strong>.
            Las URLs temporales de Google Places se detectan sin peticiones de red.
          </p>
          <div class="row align-items-end mt-3">
            <div class="col-md-6 mb-3 mb-md-0">
              <div class="black-coffee-image-label">Locales pendientes</div>
              <div class="black-coffee-image-value"><%= number_with_delimiter(@pending_venues_count) %></div>
              <div class="text-muted small">Solo estos entran en una nueva auditoria.</div>
            </div>
            <div class="col-md-6 text-md-right">
              <%= form_with url: black_coffee_image_audits_path, method: :post, local: true do %>
                <%= submit_tag 'Crear auditoria',
                               class: 'btn btn-danger btn-lg text-white',
                               data: { confirm: "Se creara una auditoria para #{@pending_venues_count} locales pendientes. Continuar?" } %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="black-coffee-image-tool black-coffee-image-tool-info">
          <div class="black-coffee-image-label mb-2">Conversion de links externos</div>
          <h3 class="black-coffee-image-tool-title mb-2">Internalizar imagenes enlazadas</h3>
          <p class="black-coffee-image-tool-copy">
            Crea un lote con imagenes Black Coffee que siguen como link externo. Al procesar, valida HTTP 200, tipo imagen, tamano maximo y contenido no vacio.
            Si funciona, reemplaza el link por archivo interno; si falla, queda sin cambios.
          </p>
          <div class="row align-items-end mt-3">
            <div class="col-md-7 mb-3 mb-md-0">
              <div class="row">
                <div class="col-6">
                  <div class="black-coffee-image-label">Imagenes link</div>
                  <div class="black-coffee-image-value"><%= number_with_delimiter(@linked_images_count) %></div>
                </div>
                <div class="col-6">
                  <div class="black-coffee-image-label">Locales</div>
                  <div class="black-coffee-image-value"><%= number_with_delimiter(@linked_venues_count) %></div>
                </div>
              </div>
            </div>
            <div class="col-md-5 text-md-right">
              <%= form_with url: black_coffee_image_internalizations_path, method: :post, local: true do %>
                <%= submit_tag 'Crear lote',
                               class: 'btn btn-primary btn-lg text-white',
                               disabled: @linked_images_count.to_i.zero?,
                               data: { confirm: "Se creara un lote con #{@linked_images_count} imagenes enlazadas. No se descargan todavia; se procesan despues por bloques. Continuar?" } %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card black-coffee-image-card">
  <div class="card-header bg-white">
    <h4 class="mb-0">Procesos recientes de imagenes</h4>
    <p class="text-muted mb-0">
      Incluye auditorias de imagenes e internalizaciones, para que tambien veas procesos completados, cancelados o iniciados desde la herramienta de conversion.
    </p>
  </div>
  <div class="table-responsive">
    <table class="table table-hover mb-0 black-coffee-image-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Tipo</th>
          <th>Estado</th>
          <th>Progreso</th>
          <th>Locales con fallo</th>
          <th>Imagenes con fallo</th>
          <th>Rechazados</th>
          <th>Fecha</th>
          <th class="text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% if @recent_image_processes.any? %>
          <% @recent_image_processes.each do |process| %>
            <tr>
              <td data-label="#"><strong>#<%= process[:id] %></strong></td>
              <td data-label="Tipo"><span class="badge badge-light border p-2"><%= process[:type] %></span></td>
              <td data-label="Estado"><span class="badge badge-<%= process[:badge_class] %> p-2"><%= process[:status_label] %></span></td>
              <td data-label="Progreso">
                <strong><%= process[:progress_percentage] %>%</strong>
                <div class="text-muted small"><%= number_with_delimiter(process[:processed]) %>/<%= number_with_delimiter(process[:total]) %> <%= process[:unit] %></div>
              </td>
              <td data-label="Locales con fallo" class="text-danger"><%= number_with_delimiter(process[:failed_venues_count]) %></td>
              <td data-label="Imagenes con fallo" class="text-danger"><%= number_with_delimiter(process[:failed_images_count]) %></td>
              <td data-label="Rechazados"><%= process[:rejected_venues_count].nil? ? '-' : number_with_delimiter(process[:rejected_venues_count]) %></td>
              <td data-label="Fecha"><%= process[:created_at].strftime('%d/%m/%Y %H:%M') %></td>
              <td data-label="Acciones" class="text-right">
                <%= link_to process[:action_label], process[:path], class: 'btn btn-sm btn-outline-primary' %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="9" class="text-center text-muted py-5">Todavia no hay procesos de imagenes.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
