<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div>
    <p class="text-muted mb-1">Black Coffee / Sincronizacion Google</p>
    <h2 class="mb-0">Lote #<%= @batch.id %></h2>
  </div>
  <div class="mt-3 mt-md-0">
    <%= link_to 'Volver a la utilidad', black_coffee_venue_google_syncs_path, class: 'btn btn-outline-dark mr-2' %>
    <% if @batch.active? %>
      <button type="button" class="btn btn-success text-white" id="venue-google-sync-continue-button">Seguir procesando</button>
    <% elsif @batch.retryable? %>
      <%= button_to 'Reintentar fallos',
                    retry_black_coffee_venue_google_sync_path(@batch),
                    method: :post,
                    class: 'btn btn-danger text-white',
                    form_class: 'd-inline-block',
                    data: { confirm: 'Se reintentaran solo los locales que hayan quedado pendientes o fallado. Continuar?' } %>
    <% end %>
  </div>
</div>

<div class="alert alert-info">
  Este lote actualiza informacion directamente desde Google por bloques cortos para evitar caidas y limitar mejor el consumo.
  Si algun local no trae descripcion desde Google, se deja vacia y la app ocultara esa seccion.
</div>

<div id="black-coffee-venue-google-sync"
     data-advance-url="<%= advance_black_coffee_venue_google_sync_path(@batch) %>"
     data-status-url="<%= status_black_coffee_venue_google_sync_path(@batch) %>">
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
      <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <div>
          <strong>Progreso de la sincronizacion</strong>
          <div class="text-muted small" id="venue-google-sync-live-note">
            Estado actual del refresco de locales conectados a Google.
          </div>
        </div>
        <span class="badge badge-secondary p-2" id="venue-google-sync-status-badge"><%= @batch.status %></span>
      </div>

      <div class="progress mb-3" style="height: 14px;">
        <div class="progress-bar progress-bar-striped progress-bar-animated"
             id="venue-google-sync-progress-bar"
             role="progressbar"
             style="width: <%= [@batch.completion_percentage, 100].min %>%"
             aria-valuenow="<%= @batch.completion_percentage %>"
             aria-valuemin="0"
             aria-valuemax="100"></div>
      </div>

      <div class="row text-center">
        <div class="col-md-2 col-6 mb-3 mb-md-0">
          <div class="text-muted small text-uppercase">Avance</div>
          <h4 class="mb-0" id="venue-google-sync-progress-value"><%= @batch.completion_percentage %>%</h4>
        </div>
        <div class="col-md-2 col-6 mb-3 mb-md-0">
          <div class="text-muted small text-uppercase">Procesados</div>
          <h4 class="mb-0" id="venue-google-sync-processed-value"><%= number_with_delimiter(@batch.processed_venues_count) %>/<%= number_with_delimiter(@batch.total_venues_count) %></h4>
        </div>
        <div class="col-md-2 col-6">
          <div class="text-muted small text-uppercase">Actualizados</div>
          <h4 class="mb-0 text-success" id="venue-google-sync-synced-value"><%= number_with_delimiter(@batch.synced_venues_count) %></h4>
        </div>
        <div class="col-md-2 col-6">
          <div class="text-muted small text-uppercase">Sin cambios</div>
          <h4 class="mb-0 text-secondary" id="venue-google-sync-skipped-value"><%= number_with_delimiter(@batch.skipped_venues_count) %></h4>
        </div>
        <div class="col-md-2 col-6 mt-3 mt-md-0">
          <div class="text-muted small text-uppercase">Fallidos</div>
          <h4 class="mb-0 text-danger" id="venue-google-sync-failed-value"><%= number_with_delimiter(@batch.failed_venues_count) %></h4>
        </div>
        <div class="col-md-2 col-6 mt-3 mt-md-0">
          <div class="text-muted small text-uppercase">Requests</div>
          <h4 class="mb-0" id="venue-google-sync-requests-value"><%= number_with_delimiter(@batch.requests_count) %></h4>
        </div>
      </div>

      <div class="row text-center mt-3">
        <div class="col-md-4 col-12 mb-2 mb-md-0">
          <div class="text-muted small text-uppercase">Pendientes en este lote</div>
          <h5 class="mb-0" id="venue-google-sync-pending-value"><%= number_with_delimiter(@batch.pending_venues_count) %></h5>
        </div>
        <div class="col-md-4 col-6">
          <div class="text-muted small text-uppercase">Modo</div>
          <h5 class="mb-0" id="venue-google-sync-mode-value"><%= @batch.connected_scope? ? 'Todos los conectados' : 'Seleccion manual' %></h5>
        </div>
        <div class="col-md-4 col-6">
          <div class="text-muted small text-uppercase">Ultimo local</div>
          <h5 class="mb-0" id="venue-google-sync-last-id-value"><%= @batch.last_processed_venue_id.presence || '-' %></h5>
        </div>
      </div>

      <div class="mt-3 small text-muted" id="venue-google-sync-current-line">
        <% if @batch.current_venue_name.present? %>
          Procesando ahora: <strong><%= @batch.current_venue_name %></strong>
        <% elsif @batch.finished? %>
          No quedan locales pendientes en este lote.
        <% else %>
          Esperando al siguiente bloque de sincronizacion...
        <% end %>
      </div>

      <div class="mt-3" id="venue-google-sync-error-container" style="<%= @batch.error_message.present? ? '' : 'display: none;' %>">
        <div class="alert alert-danger mb-0" id="venue-google-sync-error-message"><%= @batch.error_message %></div>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="venue-google-sync-initial-state"><%= raw json_escape(@progress_payload.to_json) %></script>

<script>
  (function() {
    const container = document.getElementById('black-coffee-venue-google-sync');
    const initialStateNode = document.getElementById('venue-google-sync-initial-state');
    if (!container || !initialStateNode) return;

    const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
    const formatter = new Intl.NumberFormat('es-ES');
    let state = JSON.parse(initialStateNode.textContent);
    let pollTimer = null;
    let requestInFlight = false;

    const statusBadge = document.getElementById('venue-google-sync-status-badge');
    const progressBar = document.getElementById('venue-google-sync-progress-bar');
    const progressValue = document.getElementById('venue-google-sync-progress-value');
    const processedValue = document.getElementById('venue-google-sync-processed-value');
    const syncedValue = document.getElementById('venue-google-sync-synced-value');
    const skippedValue = document.getElementById('venue-google-sync-skipped-value');
    const failedValue = document.getElementById('venue-google-sync-failed-value');
    const requestsValue = document.getElementById('venue-google-sync-requests-value');
    const pendingValue = document.getElementById('venue-google-sync-pending-value');
    const modeValue = document.getElementById('venue-google-sync-mode-value');
    const lastIdValue = document.getElementById('venue-google-sync-last-id-value');
    const currentLine = document.getElementById('venue-google-sync-current-line');
    const liveNote = document.getElementById('venue-google-sync-live-note');
    const errorContainer = document.getElementById('venue-google-sync-error-container');
    const errorMessage = document.getElementById('venue-google-sync-error-message');
    const continueButton = document.getElementById('venue-google-sync-continue-button');

    function badgeClass(status) {
      if (status === 'completed') return 'badge badge-success p-2';
      if (status === 'failed') return 'badge badge-danger p-2';
      if (status === 'running') return 'badge badge-primary p-2';
      if (status === 'cancelled') return 'badge badge-dark p-2';
      return 'badge badge-secondary p-2';
    }

    function progressClass(status, active) {
      if (status === 'completed') return 'progress-bar bg-success';
      if (status === 'failed') return 'progress-bar bg-danger';
      if (active) return 'progress-bar bg-primary progress-bar-striped progress-bar-animated';
      return 'progress-bar bg-secondary';
    }

    function render(data) {
      state = data;

      statusBadge.className = badgeClass(data.status);
      statusBadge.textContent = data.status;

      progressBar.className = progressClass(data.status, data.active);
      progressBar.style.width = `${Math.min(data.completionPercentage || 0, 100)}%`;
      progressBar.setAttribute('aria-valuenow', data.completionPercentage || 0);

      progressValue.textContent = `${data.completionPercentage || 0}%`;
      processedValue.textContent = `${formatter.format(data.processedVenues || 0)}/${formatter.format(data.totalVenues || 0)}`;
      syncedValue.textContent = formatter.format(data.syncedVenues || 0);
      skippedValue.textContent = formatter.format(data.skippedVenues || 0);
      failedValue.textContent = formatter.format(data.failedVenues || 0);
      requestsValue.textContent = formatter.format(data.requestsCount || 0);
      pendingValue.textContent = formatter.format(data.pendingVenues || 0);
      modeValue.textContent = data.selectionMode === 'connected_scope' ? 'Todos los conectados' : 'Seleccion manual';
      lastIdValue.textContent = data.lastProcessedVenueId || '-';

      if (data.currentVenueName) {
        currentLine.innerHTML = `Procesando ahora: <strong>${data.currentVenueName}</strong>`;
      } else if (data.finished) {
        currentLine.textContent = 'No quedan locales pendientes en este lote.';
      } else {
        currentLine.textContent = 'Esperando al siguiente bloque de sincronizacion...';
      }

      if (data.active) {
        liveNote.textContent = 'Procesando bloques cortos automaticamente. Asi evitamos caidas y controlamos mejor el ritmo de peticiones a Google.';
      } else if (data.status === 'completed') {
        liveNote.textContent = 'Lote completado. Ya puedes volver al panel de locales o lanzar otra sincronizacion.';
      } else if (data.status === 'failed') {
        liveNote.textContent = 'La sincronizacion se detuvo con error. El progreso ya guardado no se pierde y puedes reintentar solo los fallos.';
      } else {
        liveNote.textContent = 'Proceso en pausa.';
      }

      if (data.errorMessage) {
        errorContainer.style.display = '';
        errorMessage.textContent = data.errorMessage;
      } else {
        errorContainer.style.display = 'none';
        errorMessage.textContent = '';
      }

      if (continueButton) {
        continueButton.disabled = !data.active && data.status !== 'pending' && data.status !== 'running';
      }
    }

    function scheduleNext(delayMs) {
      window.clearTimeout(pollTimer);
      if (!state.active) return;
      pollTimer = window.setTimeout(tick, delayMs);
    }

    function tick() {
      if (requestInFlight || !state.active) return;
      requestInFlight = true;

      fetch(container.dataset.advanceUrl, {
        method: 'POST',
        headers: {
          'Accept': 'application/json',
          'X-CSRF-Token': csrfToken
        },
        credentials: 'same-origin'
      })
        .then(response => response.json().then(data => ({ ok: response.ok, data })))
        .then(({ ok, data }) => {
          render(data);
          if (!ok) {
            scheduleNext(3000);
            return;
          }
          scheduleNext(1000);
        })
        .catch(() => {
          liveNote.textContent = 'Hubo un problema temporal de conexion. Reintentando en unos segundos...';
          scheduleNext(3000);
        })
        .finally(() => {
          requestInFlight = false;
        });
    }

    if (continueButton) {
      continueButton.addEventListener('click', function() {
        if (requestInFlight) return;
        tick();
      });
    }

    render(state);
    if (state.active) {
      scheduleNext(600);
    }
  })();
</script>
