<% totals = @audit_report[:totals] %>
<% issues = @audit_report[:issues] %>
<% live_google = @audit_report[:live_google] || {} %>
<% estimated_recount_requests = totals[:expected_cells].to_i %>
<% severity_badges = { critical: 'danger', warning: 'warning', info: 'info' } %>
<% live_scope_options = [
  ['Muestra inteligente', 'smart'],
  ['Solo incidencias guardadas', 'issues'],
  ['Todo Espana', 'all']
] %>

<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div class="alert alert-<%= live_google[:enabled] ? 'warning' : 'info' %> mb-3 mb-md-0 flex-grow-1 mr-md-3">
    <% if live_google[:enabled] %>
      <strong>Auditoria con Google activa.</strong>
      Este analisis hizo <%= live_google[:executed_google_requests].to_i %> peticiones reales estimadas/ejecutadas a Google para validar una muestra de conteos.
      Los resultados live no se guardan automaticamente; sirven para decidir que comunidades recalcular.
    <% else %>
      <strong>Auditoria sin coste Google.</strong>
      Este analisis usa solo datos guardados en la base de datos: totales Google ya calculados, candidatos importados y contadores internos.
    <% end %>
  </div>
  <div class="mt-3 mt-md-0">
    <% if live_google[:enabled] %>
      <%= link_to 'Auditoria sin Google', audit_black_coffee_google_imports_path, class: 'btn btn-outline-secondary mr-2' %>
    <% end %>
    <% if @api_key_present %>
      <%= button_to 'Recalcular todos los totales', refresh_all_region_google_counts_black_coffee_google_imports_path, method: :post, class: 'btn btn-outline-warning', form_class: 'd-inline-block mr-2 mb-2', data: { confirm: "Esto recalculara todas las comunidades y hara al menos #{estimated_recount_requests} peticiones reales a Places Aggregate API. Si falta algun Google Place ID regional, puede hacer alguna peticion extra. Continuar?" } %>
    <% else %>
      <button class="btn btn-outline-secondary mr-2 mb-2" disabled>Configura API key para recalcular</button>
    <% end %>
    <%= link_to 'Volver al importador', black_coffee_google_imports_path, class: 'btn btn-outline-dark' %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-header bg-white">
    <strong>Validacion live con Google</strong>
  </div>
  <div class="card-body">
    <p class="text-muted mb-3">
      Ejecuta una auditoria live solo cuando quieras gastar llamadas reales de Places Aggregate API. El limite controla cuantas celdas comunidad/categoria se revisan; si falta el Google Region ID puede haber una peticion extra por comunidad.
    </p>
    <%= form_with url: audit_black_coffee_google_imports_path, method: :get, local: true, class: 'row align-items-end' do %>
      <%= hidden_field_tag :live_google, '1' %>
      <div class="form-group col-md-4 mb-3">
        <%= label_tag :live_scope, 'Alcance live' %>
        <%= select_tag :live_scope, options_for_select(live_scope_options, @live_scope), class: 'form-control' %>
      </div>
      <div class="form-group col-md-3 mb-3">
        <%= label_tag :live_limit, 'Maximo de celdas' %>
        <%= number_field_tag :live_limit, @live_limit, min: 1, max: BlackCoffeeGoogleImportAudit::MAX_LIVE_LIMIT, class: 'form-control' %>
      </div>
      <div class="form-group col-md-5 mb-3">
        <% if @api_key_present %>
          <%= submit_tag 'Auditar con Google', class: 'btn btn-warning btn-block', data: { confirm: 'Esto hara peticiones reales a Google Places Aggregate API. Revisa el limite antes de continuar. Continuar?' } %>
        <% else %>
          <button class="btn btn-outline-secondary btn-block" disabled>Configura API key para auditoria live</button>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
      <div>
        <strong>Resumen del precalculo</strong>
        <div class="text-muted small">Generado: <%= @audit_report[:generated_at].strftime('%d/%m/%Y %H:%M') %></div>
      </div>
      <span class="badge badge-<%= totals[:critical_issues].positive? ? 'danger' : (totals[:warning_issues].positive? ? 'warning' : 'success') %> p-2">
        <%= totals[:critical_issues].positive? ? 'Revisar' : (totals[:warning_issues].positive? ? 'Con avisos' : 'Consistente') %>
      </span>
    </div>

    <div class="row text-center">
      <div class="col-md-3 col-6 mb-3">
        <div class="text-muted small text-uppercase">Celdas calculadas</div>
        <h4 class="mb-0"><%= totals[:counted_cells] %>/<%= totals[:expected_cells] %></h4>
      </div>
      <div class="col-md-3 col-6 mb-3">
        <div class="text-muted small text-uppercase">Total Google</div>
        <h4 class="mb-0"><%= number_with_delimiter(totals[:google_total_count]) %></h4>
      </div>
      <div class="col-md-3 col-6 mb-3">
        <div class="text-muted small text-uppercase">Importados</div>
        <h4 class="mb-0 text-success"><%= number_with_delimiter(totals[:approved_count]) %></h4>
      </div>
      <div class="col-md-3 col-6 mb-3">
        <div class="text-muted small text-uppercase">Progreso</div>
        <h4 class="mb-0"><%= totals[:percentage] %>%</h4>
      </div>
    </div>

    <div class="row text-center">
      <div class="col-md-4 col-12 mb-2">
        <span class="badge badge-danger p-2">Criticos: <%= totals[:critical_issues] %></span>
      </div>
      <div class="col-md-4 col-12 mb-2">
        <span class="badge badge-warning p-2">Avisos: <%= totals[:warning_issues] %></span>
      </div>
      <div class="col-md-4 col-12 mb-2">
        <span class="badge badge-info p-2">Notas: <%= totals[:info_issues] %></span>
      </div>
    </div>
  </div>
</div>

<% if live_google[:enabled] %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center">
      <strong>Resultado live Google</strong>
      <span class="text-muted small">
        Alcance: <%= live_google[:scope] %> - Limite: <%= live_google[:limit] %>
      </span>
    </div>
    <div class="card-body">
      <div class="row text-center mb-3">
        <div class="col-md-3 col-6 mb-3">
          <div class="text-muted small text-uppercase">Celdas revisadas</div>
          <h4 class="mb-0"><%= live_google[:checked_cells].to_i %>/<%= live_google[:selected_cells].to_i %></h4>
        </div>
        <div class="col-md-3 col-6 mb-3">
          <div class="text-muted small text-uppercase">Peticiones Google</div>
          <h4 class="mb-0"><%= live_google[:executed_google_requests].to_i %></h4>
          <div class="text-muted small">estimadas: <%= live_google[:estimated_google_requests].to_i %></div>
        </div>
        <div class="col-md-3 col-6 mb-3">
          <div class="text-muted small text-uppercase">Diferencias</div>
          <h4 class="mb-0 text-warning"><%= live_google[:differences].to_i %></h4>
        </div>
        <div class="col-md-3 col-6 mb-3">
          <div class="text-muted small text-uppercase">Errores live</div>
          <h4 class="mb-0 text-danger"><%= live_google[:errors].to_i %></h4>
        </div>
      </div>

      <% if live_google[:skipped_by_limit].to_i.positive? %>
        <div class="alert alert-secondary py-2">
          Se omitieron <%= live_google[:skipped_by_limit].to_i %> celdas por el limite configurado. Sube el maximo si quieres revisar mas.
        </div>
      <% end %>

      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead>
            <tr>
              <th>Comunidad</th>
              <th>Categoria</th>
              <th>Guardado</th>
              <th>Google live</th>
              <th>Delta</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody>
            <% if live_google[:results].present? %>
              <% live_google[:results].each do |result| %>
                <% status_class =
                  case result[:status]
                  when 'same' then 'success'
                  when 'different' then (result[:significant_difference] ? 'warning' : 'info')
                  when 'missing_stored' then 'warning'
                  else 'danger'
                  end
                %>
                <tr>
                  <td><%= result.dig(:region, :name) %></td>
                  <td><%= result[:label] %></td>
                  <td><%= result[:stored_count].nil? ? '-' : number_with_delimiter(result[:stored_count]) %></td>
                  <td><%= result[:live_count].nil? ? '-' : number_with_delimiter(result[:live_count]) %></td>
                  <td>
                    <% if result[:difference].nil? %>
                      -
                    <% else %>
                      <%= number_with_delimiter(result[:difference]) %>
                      <% if result[:difference_percentage].present? %>
                        (<%= result[:difference_percentage] %>%)
                      <% end %>
                    <% end %>
                  </td>
                  <td>
                    <span class="badge badge-<%= status_class %>"><%= result[:status] %></span>
                    <% if result[:switched_to_circle] %>
                      <span class="badge badge-info">fallback circulo</span>
                    <% end %>
                    <% if result[:error_message].present? %>
                      <details class="mt-2">
                        <summary>Detalle error</summary>
                        <pre class="bg-dark text-white rounded p-2 mt-1 mb-0" style="white-space: pre-wrap; max-height: 300px; overflow: auto;"><%= result[:error_details].presence || result[:error_message] %></pre>
                      </details>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="6" class="text-center text-muted py-4">
                  No hubo celdas live seleccionadas para este alcance.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% end %>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-header bg-white">
    <strong>Recomendaciones</strong>
  </div>
  <div class="card-body">
    <% @audit_report[:recommendations].each do |recommendation| %>
      <div class="alert alert-secondary py-2 mb-2"><%= recommendation %></div>
    <% end %>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <strong>Incidencias detectadas</strong>
    <span class="text-muted small"><%= issues.size %> registros</span>
  </div>
  <div class="card-body table-responsive p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Severidad</th>
          <th>Comunidad</th>
          <th>Categoria</th>
          <th>Problema</th>
          <th>Sugerencia</th>
        </tr>
      </thead>
      <tbody>
        <% if issues.any? %>
          <% issues.each do |issue| %>
            <tr>
              <td><span class="badge badge-<%= severity_badges[issue[:severity]] || 'secondary' %>"><%= issue[:severity] %></span></td>
              <td><%= issue[:region] || '-' %></td>
              <td><%= issue[:category_label] || '-' %></td>
              <td><%= issue[:message] %></td>
              <td><%= issue[:suggestion] %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" class="text-center text-muted py-4">No se detectaron incidencias.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-header bg-white">
    <strong>Detalle por comunidad</strong>
  </div>
  <div class="card-body">
    <div class="row">
      <% @audit_report[:summaries].each do |summary| %>
        <% region = summary[:region] %>
        <div class="col-xl-4 col-md-6 mb-3">
          <div class="border rounded h-100 p-3">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="mb-0"><%= region[:name] %></h5>
              <span class="badge badge-<%= summary[:counted_categories] == summary[:expected_categories] ? 'success' : 'warning' %>">
                <%= summary[:counted_categories] %>/<%= summary[:expected_categories] %>
              </span>
            </div>
            <div class="small text-muted mb-2">
              Estrategia: <%= summary[:strategy] %> · Total Google: <%= number_with_delimiter(summary[:google_total_count]) %> · Importados: <%= number_with_delimiter(summary[:approved_count]) %> · <%= summary[:percentage] %>%
            </div>
            <% if region[:google_count_location_note].present? %>
              <div class="text-warning small mb-2"><%= region[:google_count_location_note] %></div>
            <% end %>

            <% summary[:categories].each do |category| %>
              <% badge_class = category[:google_error].present? ? 'danger' : (category[:google_total_known] ? 'light' : 'warning') %>
              <span class="badge badge-<%= badge_class %> mr-1 mb-2 p-2" title="<%= category[:google_error] || 'OK' %>">
                <%= category[:label] %>:
                <% if category[:google_error].present? %>
                  error
                <% elsif category[:google_total_known] %>
                  <%= category[:approved_count] %>/<%= category[:google_total_count] %>
                <% else %>
                  sin total
                <% end %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-header bg-white">
    <strong>Reporte tecnico copiable</strong>
  </div>
  <div class="card-body">
    <textarea class="form-control" rows="18" readonly><%= @audit_json %></textarea>
  </div>
</div>
