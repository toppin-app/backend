<% category_labels = @categories.map { |label, value| [value, label] }.to_h %>

<div class="d-flex flex-wrap justify-content-between align-items-start mb-4">
  <div class="alert alert-info mb-3 mb-md-0 flex-grow-1 mr-md-3">
    <strong>Alcance actual: Espana.</strong>
    Este importador trabaja por comunidades autonomas y categorias de Black Coffee. Nada se publica hasta aprobarlo.
    Los contadores son internos: candidatos ya encontrados en nuestra base de datos, no el total vivo de Google Maps.
  </div>
  <div class="mt-3 mt-md-0">
    <%= link_to 'Volver a locales', black_coffee_venues_path, class: 'btn btn-outline-dark' %>
  </div>
</div>

<% unless @api_key_present %>
  <div class="alert alert-warning">
    Falta configurar <strong>GOOGLE_PLACES_API_KEY</strong> o <strong>GOOGLE_MAPS_API_KEY</strong> en el servidor. Puedes ver el util, pero las busquedas fallaran hasta agregar la clave.
  </div>
<% end %>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
      <div>
        <strong>Progreso total del importador</strong>
        <div class="text-muted small">
          No hacemos consultas extra a Google para calcular el universo total y evitar coste.
        </div>
      </div>
      <span class="badge badge-primary p-2"><%= @overall_progress[:completion_percentage] %>% importado</span>
    </div>

    <div class="progress mb-3" style="height: 10px;">
      <div class="progress-bar bg-primary" role="progressbar" style="width: <%= [@overall_progress[:completion_percentage], 100].min %>%;" aria-valuenow="<%= @overall_progress[:completion_percentage] %>" aria-valuemin="0" aria-valuemax="100"></div>
    </div>

    <div class="row text-center">
      <div class="col-md-3 col-6 mb-3 mb-md-0">
        <div class="text-muted small text-uppercase">Candidatos encontrados</div>
        <h4 class="mb-0"><%= number_with_delimiter(@overall_progress[:total_candidates]) %></h4>
      </div>
      <div class="col-md-3 col-6 mb-3 mb-md-0">
        <div class="text-muted small text-uppercase">Importados</div>
        <h4 class="mb-0 text-success"><%= number_with_delimiter(@overall_progress[:approved_count]) %></h4>
      </div>
      <div class="col-md-3 col-6">
        <div class="text-muted small text-uppercase">Pendientes de revisar</div>
        <h4 class="mb-0 text-warning"><%= number_with_delimiter(@overall_progress[:remaining_count]) %></h4>
      </div>
      <div class="col-md-3 col-6">
        <div class="text-muted small text-uppercase">Rechazados / duplicados</div>
        <h4 class="mb-0 text-secondary"><%= number_with_delimiter(@overall_progress[:rejected_count] + @overall_progress[:duplicate_count]) %></h4>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-4 mb-4">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-header bg-dark text-white">
        <strong>Nueva busqueda</strong>
      </div>
      <div class="card-body">
        <%= form_with url: black_coffee_google_imports_path, method: :post, local: true do %>
          <div class="form-group">
            <%= label_tag :region_id, 'Comunidad autonoma' %>
            <%= select_tag :region_id, options_from_collection_for_select(@regions, :id, :name, params[:region_id]), class: 'form-control' %>
          </div>

          <div class="form-group">
            <%= label_tag :category, 'Categoria Black Coffee' %>
            <%= select_tag :category, options_for_select(@categories, params[:category]), class: 'form-control' %>
          </div>

          <div class="form-group">
            <%= label_tag :limit, 'Cantidad maxima para probar' %>
            <%= number_field_tag :limit, params[:limit].presence || 10, min: 1, max: GooglePlacesBlackCoffeeClient::MAX_RESULTS, class: 'form-control' %>
            <small class="text-muted">Maximo <%= GooglePlacesBlackCoffeeClient::MAX_RESULTS %> por busqueda para controlar coste y revision.</small>
          </div>

          <div class="form-group">
            <%= label_tag :query_override, 'Busqueda personalizada (opcional)' %>
            <%= text_field_tag :query_override, params[:query_override], class: 'form-control', placeholder: 'Ej: restaurantes romanticos' %>
            <small class="text-muted">Si lo dejas vacio se usa la busqueda base de la categoria.</small>
          </div>

          <%= submit_tag 'Buscar candidatos', class: 'btn btn-primary btn-block text-white' %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-8 mb-4">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-header bg-white">
        <strong>Ultimas corridas</strong>
      </div>
      <div class="card-body table-responsive p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th>#</th>
              <th>Region</th>
              <th>Categoria</th>
              <th>Estado</th>
              <th>Candidatos</th>
              <th>Fecha</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if @recent_runs.any? %>
              <% @recent_runs.each do |run| %>
                <tr>
                  <td><%= run.id %></td>
                  <td><%= run.black_coffee_import_region.name %></td>
                  <td><%= category_labels[run.category] || run.category %></td>
                  <td>
                    <span class="badge badge-<%= run.status == 'completed' ? 'success' : (run.status == 'failed' ? 'danger' : 'secondary') %>">
                      <%= run.status %>
                    </span>
                  </td>
                  <td><%= run.candidate_count %></td>
                  <td><%= run.created_at.strftime('%d/%m/%Y %H:%M') %></td>
                  <td class="text-right">
                    <%= link_to 'Revisar', black_coffee_google_import_path(run), class: 'btn btn-sm btn-outline-primary' %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="7" class="text-center text-muted py-4">Todavia no hay corridas de importacion.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0">
  <div class="card-header bg-white">
    <strong>Progreso por comunidad</strong>
    <span class="text-muted ml-2">Se marca por categoria segun candidatos encontrados, pendientes y aprobados en la base de datos.</span>
  </div>
  <div class="card-body">
    <div class="row">
      <% @regions.each do |region| %>
        <% states_by_category = region.region_categories.index_by(&:category) %>
        <% progress = @region_progress[region.id] || { completion_percentage: 0, approved_count: 0, remaining_count: 0, total_candidates: 0 } %>
        <div class="col-xl-4 col-md-6 mb-3">
          <div class="border rounded h-100 p-3">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="mb-0"><%= region.name %></h5>
              <div class="text-right">
                <span class="badge badge-<%= region.status == 'imported' ? 'success' : (region.status == 'reviewed' ? 'info' : 'light') %>">
                  <%= region.status %>
                </span>
                <div class="small text-muted mt-1"><%= progress[:completion_percentage].to_i %>% importado</div>
              </div>
            </div>

            <div class="progress mb-2" style="height: 8px;">
              <div class="progress-bar bg-success" role="progressbar" style="width: <%= [progress[:completion_percentage].to_i, 100].min %>%;" aria-valuenow="<%= progress[:completion_percentage].to_i %>" aria-valuemin="0" aria-valuemax="100"></div>
            </div>

            <div class="small text-muted mb-3">
              Importados: <%= number_with_delimiter(progress[:approved_count].to_i) %> ·
              Pendientes: <%= number_with_delimiter(progress[:remaining_count].to_i) %> ·
              Candidatos: <%= number_with_delimiter(progress[:total_candidates].to_i) %>
            </div>

            <div>
              <% @categories.each do |label, value| %>
                <% state = states_by_category[value] %>
                <% badge_class =
                  if state&.approved_count.to_i.positive?
                    'success'
                  elsif state&.pending_count.to_i.positive?
                    'warning'
                  elsif state&.total_candidates.to_i.positive?
                    'secondary'
                  else
                    'light'
                  end
                %>
                <span class="badge badge-<%= badge_class %> mr-1 mb-2 p-2" title="Pendientes: <%= state&.pending_count.to_i %> | Aprobados: <%= state&.approved_count.to_i %> | Duplicados: <%= state&.duplicate_count.to_i %>">
                  <%= label %>: <%= state&.approved_count.to_i %>/<%= state&.total_candidates.to_i %>
                </span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
